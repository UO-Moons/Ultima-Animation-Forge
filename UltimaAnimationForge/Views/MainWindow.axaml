<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:UltimaAnimationForge.ViewModels"
        xmlns:converters="clr-namespace:UltimaAnimationForge.Converters"
        xmlns:tabs="clr-namespace:UltimaAnimationForge.Views.Tabs"
        x:Class="UltimaAnimationForge.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1500"
        Height="940"
        MinWidth="1180"
        MinHeight="760"
        Background="#1B1F25"
        Foreground="White"
        RequestedThemeVariant="Dark"
        Title="Ultima Animation Forge Alpha 26"
        DragDrop.AllowDrop="True"
        KeyDown="Window_KeyDown"
        mc:Ignorable="d">

    <Window.Resources>
        <converters:BoolToSelectionBrushConverter x:Key="BoolToSelectionBrushConverter"/>
        <converters:IsMulMultiSourceConverter x:Key="IsMulMultiSourceConverter"/>
    </Window.Resources>

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFolderCommand}" />
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveChangesCommand}" />
        <KeyBinding Gesture="Ctrl+E" Command="{Binding ExportFramesCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+E" Command="{Binding ExportVdCommand}" />
        <KeyBinding Gesture="Ctrl+I" Command="{Binding ImportVdCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+I" Command="{Binding ImportVdToUopCommand}" />
        <KeyBinding Gesture="Ctrl+P" Command="{Binding PlayCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+P" Command="{Binding PauseCommand}" />
        <KeyBinding Gesture="Ctrl+Left" Command="{Binding PreviousFrameCommand}" />
        <KeyBinding Gesture="Ctrl+Right" Command="{Binding NextFrameCommand}" />
        <KeyBinding Gesture="Ctrl+R" Command="{Binding ReplaceSelectedFrameCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+R" Command="{Binding ImportPngSequenceCommand}" />
        <KeyBinding Gesture="Ctrl+Delete" Command="{Binding DeleteAnimationCommand}" />
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoFrameEditCommand}" />

        <KeyBinding Gesture="Alt+1" Command="{Binding Direction0Command}" />
        <KeyBinding Gesture="Alt+2" Command="{Binding Direction1Command}" />
        <KeyBinding Gesture="Alt+3" Command="{Binding Direction2Command}" />
        <KeyBinding Gesture="Alt+4" Command="{Binding Direction3Command}" />
        <KeyBinding Gesture="Alt+5" Command="{Binding Direction4Command}" />

        <KeyBinding Gesture="Alt+C" Command="{Binding ToggleCheckerCommand}" />
        <KeyBinding Gesture="Alt+L" Command="{Binding ToggleLoopCommand}" />
    </Window.KeyBindings>

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#3A424D" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#56606D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="32" />
        </Style>

        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#46505D" />
        </Style>

        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#2E353F" />
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="#101419" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#505A66" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#101419" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#505A66" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="32" />
        </Style>

        <Style Selector="Slider">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="ContextMenu">
            <Setter Property="Background" Value="#232A32" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#56606D" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="ContextMenu MenuItem">
            <Setter Property="Background" Value="#232A32" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="ContextMenu MenuItem:pointerover">
            <Setter Property="Background" Value="#46505D" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="ContextMenu MenuItem:disabled">
            <Setter Property="Foreground" Value="#7F8790" />
        </Style>

        <Style Selector="MenuItem.topAction">
            <Setter Property="Background" Value="#334052" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderBrush" Value="#56606D" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="MenuItem.topAction:pointerover">
            <Setter Property="Background" Value="#46546A" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="Separator">
            <Setter Property="Background" Value="#56606D" />
        </Style>

        <Style Selector="ListBox">
            <Setter Property="Background" Value="#1F242B" />
            <Setter Property="BorderBrush" Value="#303844" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="#24303B" />
        </Style>

        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="#1B3E58" />
        </Style>

        <Style Selector="ListBoxItem:selected:pointerover">
            <Setter Property="Background" Value="#254F6F" />
        </Style>

        <Style Selector="ListBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="{TemplateBinding Background}" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="#232A32" />
            <Setter Property="BorderBrush" Value="#343D49" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="ListBoxItem:pointerover Border.card">
            <Setter Property="Background" Value="#283440" />
            <Setter Property="BorderBrush" Value="#66839C" />
        </Style>

        <Style Selector="ListBoxItem:selected Border.card">
            <Setter Property="Background" Value="#22455F" />
            <Setter Property="BorderBrush" Value="#73D0FF" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>

        <Style Selector="ListBoxItem:selected:pointerover Border.card">
            <Setter Property="Background" Value="#2C5372" />
            <Setter Property="BorderBrush" Value="#94DEFF" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>

        <Style Selector="Border.selectionBar">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBoxItem:pointerover Border.selectionBar">
            <Setter Property="Background" Value="#57718B" />
        </Style>

        <Style Selector="ListBoxItem:selected Border.selectionBar">
            <Setter Property="Background" Value="#73D0FF" />
        </Style>

        <Style Selector="ListBoxItem:selected:pointerover Border.selectionBar">
            <Setter Property="Background" Value="#94DEFF" />
        </Style>

        <Style Selector="TextBlock.subtleText">
            <Setter Property="Foreground" Value="#A9BED0" />
        </Style>

        <Style Selector="ListBoxItem:selected TextBlock.subtleText">
            <Setter Property="Foreground" Value="#DDF4FF" />
        </Style>

        <Style Selector="ListBox.thumbnailList">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="ListBox.thumbnailList ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.thumbnailList ListBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="{TemplateBinding Background}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style Selector="Border.thumbCard">
            <Setter Property="Background" Value="#182028" />
            <Setter Property="BorderBrush" Value="#37424D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Width" Value="58" />
            <Setter Property="Height" Value="78" />
        </Style>

        <Style Selector="ListBox.thumbnailList ListBoxItem:pointerover Border.thumbCard">
            <Setter Property="Background" Value="#22303B" />
            <Setter Property="BorderBrush" Value="#6D8AA2" />
        </Style>

        <Style Selector="ListBox.thumbnailList ListBoxItem:selected Border.thumbCard">
            <Setter Property="Background" Value="#1E3A4E" />
            <Setter Property="BorderBrush" Value="#7DD8FF" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>

        <Style Selector="ListBox.thumbnailList ListBoxItem:selected:pointerover Border.thumbCard">
            <Setter Property="Background" Value="#284A62" />
            <Setter Property="BorderBrush" Value="#9BE3FF" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>

        <Style Selector="Border.thumbImageHost">
            <Setter Property="Background" Value="#0F1419" />
            <Setter Property="BorderBrush" Value="#2D3741" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style Selector="TextBlock.thumbLabel">
            <Setter Property="Foreground" Value="#D6E2ED" />
        </Style>

        <Style Selector="ListBox.thumbnailList ListBoxItem:selected TextBlock.thumbLabel">
            <Setter Property="Foreground" Value="White" />
        </Style>


        <Style Selector="ListBox.animationBrowserList">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="ListBox.animationBrowserList ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.animationBrowserList ListBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="{TemplateBinding Background}" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="Border.animationBrowserTile">
            <Setter Property="Background" Value="#252A31" />
            <Setter Property="BorderBrush" Value="#3A404A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style Selector="ListBox.animationBrowserList ListBoxItem:pointerover Border.animationBrowserTile">
            <Setter Property="Background" Value="#2E3945" />
            <Setter Property="BorderBrush" Value="#66839C" />
        </Style>

        <Style Selector="ListBox.animationBrowserList ListBoxItem:selected Border.animationBrowserTile">
            <Setter Property="Background" Value="#22455F" />
            <Setter Property="BorderBrush" Value="#73D0FF" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>

        <Style Selector="Expander">
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="Expander /template/ ToggleButton">
            <Setter Property="Background" Value="#232A32" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Grid.pendingArt">
            <Setter Property="Background" Value="#332020"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*">

        <!-- profile/action bar -->
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,360"
              ColumnSpacing="8">

            <TextBlock Grid.Column="0"
                       Text="Profile"
                       VerticalAlignment="Center"
                       Foreground="#D5DCE4" />

            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding ProfileOptions}"
                      SelectedIndex="{Binding SelectedProfileIndex, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      Width="110" />

            <Button Grid.Column="2"
                    Content="Manage Profiles"
                    Command="{Binding ManageProfilesCommand}"
                    MinHeight="32"
                    Padding="12,6" />

            <Button Grid.Column="3"
                    Content="Open UO Folder"
                    Command="{Binding OpenFolderCommand}"
                    MinHeight="32"
                    Padding="12,6" />

            <Button Grid.Column="4"
                    Content="?"
                    Command="{Binding HelpCommand}"
                    Width="38"
                    Height="32"
                    MinHeight="32"
                    Padding="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Show help and shortcuts" />

            <WrapPanel Grid.Column="5"
                       Orientation="Horizontal"
                       VerticalAlignment="Center"
                       IsVisible="{Binding ShowAnimationEditorPanel}">

                <Button Content="Save Changes"
                        Command="{Binding SaveChangesCommand}"
                        IsEnabled="{Binding CanSaveChanges}"
                        MinHeight="32"
                        MinWidth="118"
                        Padding="12,6"
                        Margin="0,0,8,0" />

                <Button Content="Preview Window"
                        Command="{Binding PopOutPreviewCommand}"
                        MinHeight="32"
                        MinWidth="132"
                        Padding="12,6"
                        Margin="0,0,8,0" />

                <Menu Background="Transparent"
                      Margin="0,0,8,0">
                    <MenuItem Header="Edit ▼"
                              Classes="topAction"
                              MinHeight="32"
                              MinWidth="78"
                              Padding="12,6">
                        <MenuItem Header="MUL Slot View"
                                  ToggleType="CheckBox"
                                  IsChecked="{Binding ShowMulSlotView, Mode=TwoWay}" />
                        <Separator />
                        <MenuItem Header="Replace Frame"
                                  Command="{Binding ReplaceSelectedFrameCommand}"
                                  IsVisible="{Binding ShowAnimationView}" />
                        <MenuItem Header="Remove Frame"
                                  Command="{Binding RemoveSelectedFrameCommand}"
                                  IsVisible="{Binding ShowAnimationView}" />
                        <MenuItem Header="Import PNG Sequence"
                                  Command="{Binding ImportPngSequenceCommand}"
                                  IsVisible="{Binding ShowAnimationView}" />
                        <Separator IsVisible="{Binding ShowAnimationView}" />
                        <MenuItem Header="Undo"
                                  Command="{Binding UndoFrameEditCommand}"
                                  IsEnabled="{Binding CanUndoFrameEdit}"
                                  IsVisible="{Binding ShowAnimationView}" />
                    </MenuItem>
                </Menu>

                <Menu Background="Transparent">
                    <MenuItem Header="Import / Export ▼"
                              Classes="topAction"
                              MinHeight="32"
                              MinWidth="150"
                              Padding="12,6">
                        <MenuItem Header="Open EC / KR Package Viewer"
                                  Command="{Binding OpenMythicPackageViewerCommand}" />
                        <Separator />
                        <MenuItem Header="Create Empty MUL/IDX"
                                  Command="{Binding CreateEmptyLegacyMulIdxCommand}" />
                        <Separator />
                        <MenuItem Header="Export Frames"
                                  Command="{Binding ExportFramesCommand}" />
                        <MenuItem Header="Export VD"
                                  Command="{Binding ExportVdCommand}"
                                  IsVisible="{Binding ShowAnimationView}" />
                        <Separator />
                        <MenuItem Header="Import VD"
                                  Command="{Binding ImportVdCommand}"
                                  IsVisible="{Binding ShowSlotView}" />
                        <MenuItem Header="Import UOP VD"
                                  Command="{Binding ImportVdToUopCommand}"
                                  IsVisible="{Binding ShowSlotView}" />
                        <MenuItem Header="Import Sprite Sheet"
                                  Command="{Binding ImportSpriteSheetCommand}" />
                        <Separator />
                        <MenuItem Header="Delete Animation"
                                  Command="{Binding DeleteAnimationCommand}"
                                  IsVisible="{Binding ShowAnimationView}" />
                    </MenuItem>
                </Menu>
            </WrapPanel>

            <Button Grid.Column="6"
                    Content="Uox3 - Discord"
                    Command="{Binding OpenDiscordCommand}"
                    MinHeight="32"
                    MinWidth="128"
                    Padding="12,6" />

            <Border Grid.Column="9"
                    Background="#1A1F25"
                    BorderBrush="#39414D"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,8"
                    Margin="8,0,0,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding HeaderStatusText}"
                               Foreground="#EDF1F5"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="2" />
                    <TextBlock Text="{Binding UnsavedChangesText}"
                               Foreground="#F2C14E"
                               FontWeight="Bold"
                               IsVisible="{Binding HasAnyUnsavedChanges}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- tool tabs -->
        <Border Grid.Row="1"
                Background="#1B2027"
                BorderBrush="#343B46"
                BorderThickness="0,0,0,1"
                Padding="8,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="2">
                    <Button Content="Animations"
                            Command="{Binding ShowAnimationEditorCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="Animation Browser"
                            Command="{Binding ShowAnimationBrowserCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="Gumps"
                            Command="{Binding ShowGumpEditorCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="TileData"
                            Command="{Binding ShowTileDataCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="Art"
                            Command="{Binding ShowArtCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="AnimData"
                            Command="{Binding ShowAnimDataCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="Hues"
                            Command="{Binding ShowHueEditorCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="Lights"
                            Command="{Binding ShowLightCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="Cliloc"
                            Command="{Binding ShowClilocCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="RadarCol"
                            Command="{Binding ShowRadarColCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="Multis"
                            Command="{Binding ShowMultisCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="Sounds"
                            Command="{Binding ShowSoundsCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="Map"
                            Command="{Binding ShowMapsCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="Map Maker"
                            Command="{Binding ShowMapMakerCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="Wearables"
                            Command="{Binding ShowWearableWizardCommand}"/>

                    <Button Content="Gump Builder"
                            Command="{Binding ShowGumpBuilderCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- filters -->
        <Border Grid.Row="2"
                Background="#1E232A"
                BorderBrush="#343B46"
                BorderThickness="0,0,0,1"
                Padding="12,10"
                IsVisible="{Binding ShowAnimationEditorPanel}">
            <Grid ColumnDefinitions="Auto,144,12,Auto,98,12,Auto,100,118,12,Auto,128,18,Auto,8,Auto,132,8,Auto,176,8,Auto,124,8,Auto,108,*"
                  VerticalAlignment="Center">

                <!-- File -->
                <TextBlock Grid.Column="0"
                           Text="File"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#D5DCE4" />

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AnimationFileOptions}"
                          SelectedItem="{Binding SelectedAnimationFile}"
                          VerticalAlignment="Center" />

                <!-- Type -->
                <TextBlock Grid.Column="3"
                           Text="Type"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#D5DCE4"
                           IsVisible="{Binding ShowAnimationOnlyControls}" />

                <ComboBox Grid.Column="4"
                          ItemsSource="{Binding BodyTypeOptions}"
                          SelectedItem="{Binding SelectedBodyType}"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowAnimationOnlyControls}" />

                <!-- Direction -->
                <TextBlock Grid.Column="6"
                           Text="Dir"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#D5DCE4"
                           IsVisible="{Binding ShowActionDirectionControls}" />

                <Slider Grid.Column="7"
                        Minimum="0"
                        Maximum="4"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Value="{Binding SelectedDirectionSliderValue}"
                        VerticalAlignment="Center"
                        IsVisible="{Binding ShowActionDirectionControls}" />

                <ComboBox Grid.Column="8"
                          ItemsSource="{Binding DirectionOptions}"
                          SelectedItem="{Binding SelectedDirection}"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowActionDirectionControls}" />

                <!-- Action -->
                <TextBlock Grid.Column="10"
                           Text="Action"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#D5DCE4"
                           IsVisible="{Binding ShowActionDirectionControls}" />

                <ComboBox Grid.Column="11"
                          ItemsSource="{Binding ActionOptions}"
                          SelectedItem="{Binding SelectedAction}"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowActionDirectionControls}" />

                <!-- Compare target -->
                <TextBlock Grid.Column="13"
                           Text="{Binding CompareTargetHeaderText}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"
                           Foreground="#9FB2C8"
                           FontWeight="SemiBold"
                           IsVisible="{Binding ShowCompareSelectorBar}" />

                <TextBlock Grid.Column="15"
                           Text="File"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           Foreground="#D5DCE4"
                           IsVisible="{Binding ShowCompareSelectorBar}" />

                <ComboBox Grid.Column="16"
                          Width="132"
                          ItemsSource="{Binding CompareAnimationFileOptions}"
                          SelectedItem="{Binding CompareSelectedAnimationFile}"
                          Margin="0,0,6,0"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowCompareSelectorBar}" />

                <TextBlock Grid.Column="18"
                           Text="Body"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           Foreground="#D5DCE4"
                           IsVisible="{Binding ShowCompareSelectorBar}" />

                <ComboBox Grid.Column="19"
                          Width="176"
                          ItemsSource="{Binding CompareAnimationEntries}"
                          SelectedItem="{Binding CompareSelectedAnimation}"
                          Margin="0,0,6,0"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowCompareSelectorBar}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="0">
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Column="21"
                           Text="Action"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           Foreground="#D5DCE4"
                           IsVisible="{Binding ShowCompareSelectorBar}" />

                <ComboBox Grid.Column="22"
                          Width="124"
                          ItemsSource="{Binding CompareActionOptions}"
                          SelectedItem="{Binding CompareSelectedAction}"
                          Margin="0,0,6,0"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowCompareSelectorBar}" />

                <TextBlock Grid.Column="24"
                           Text="Dir"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           Foreground="#D5DCE4"
                           IsVisible="{Binding ShowCompareSelectorBar}" />

                <ComboBox Grid.Column="25"
                          Width="108"
                          ItemsSource="{Binding CompareDirectionOptions}"
                          SelectedItem="{Binding CompareSelectedDirection}"
                          Margin="0,0,6,0"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowCompareSelectorBar}" />
            </Grid>
        </Border>

        <!-- live preview row -->
        <Border Grid.Row="4"
                Background="#1E232A"
                BorderBrush="#343B46"
                BorderThickness="0,0,0,1"
                Padding="12,8"
                IsVisible="{Binding ShowAnimationEditorPanel}">
            <StackPanel Spacing="8">
                <TextBlock Text="Live Preview"
                           FontWeight="Bold"
                           Foreground="#D5DCE4" />

                <WrapPanel Orientation="Horizontal"
                           VerticalAlignment="Center">
                    <CheckBox Content="Sharpen"
                              IsChecked="{Binding LivePreviewSharpenEnabled}"
                              VerticalAlignment="Center"
                              Margin="0,0,6,0" />

                    <NumericUpDown Width="70"
                                   Minimum="0"
                                   Maximum="5"
                                   Increment="0.1"
                                   FormatString="0.0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding LivePreviewSharpenAmountValue, Mode=TwoWay}"
                                   Margin="0,0,8,0" />

                    <ComboBox Width="100"
                              SelectedIndex="{Binding LivePreviewSharpenModeIndex}"
                              Margin="0,0,12,0">
                        <ComboBoxItem Content="Gaussian" />
                        <ComboBoxItem Content="Pixel" />
                    </ComboBox>

                    <CheckBox Content="Contrast"
                              IsChecked="{Binding LivePreviewContrastEnabled}"
                              VerticalAlignment="Center"
                              Margin="0,0,6,0" />

                    <NumericUpDown Width="70"
                                   Minimum="0"
                                   Maximum="2"
                                   Increment="0.05"
                                   FormatString="0.00"
                                   ShowButtonSpinner="False"
                                   Value="{Binding LivePreviewContrastAmountValue, Mode=TwoWay}"
                                   Margin="0,0,12,0" />

                    <CheckBox Content="Outline"
                              IsChecked="{Binding LivePreviewOutlineEnabled}"
                              VerticalAlignment="Center"
                              Margin="0,0,6,0" />

                    <NumericUpDown Width="70"
                                   Minimum="0"
                                   Maximum="1"
                                   Increment="0.05"
                                   FormatString="0.00"
                                   ShowButtonSpinner="False"
                                   Value="{Binding LivePreviewOutlineStrengthValue, Mode=TwoWay}"
                                   Margin="0,0,18,0" />

                    <TextBlock Text="Mode"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <ComboBox Width="150"
                              ItemsSource="{Binding CompareOverlaySyncModeOptions}"
                              SelectedItem="{Binding CompareOverlaySyncMode}"
                              Margin="0,0,6,0" />

                    <TextBlock Text="F"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4"
                               IsVisible="{Binding IsCompareOverlayManualFrameMode}" />

                    <NumericUpDown Width="70"
                                   Minimum="0"
                                   Maximum="999"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding CompareOverlayFrameIndex, Mode=TwoWay}"
                                   Margin="0,0,6,0"
                                   IsVisible="{Binding IsCompareOverlayManualFrameMode}" />

                    <TextBlock Text="Selected"
                               VerticalAlignment="Center"
                               Foreground="#D5DCE4"
                               Margin="10,0,4,0"/>

                    <TextBlock Text="X"
                               VerticalAlignment="Center"
                               Foreground="#D5DCE4"/>

                    <NumericUpDown Width="60"
                                   Minimum="-500"
                                   Maximum="500"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding SelectedAnimationOffsetXText, Mode=TwoWay}"
                                   Margin="0,0,4,0"/>

                    <TextBlock Text="Y"
                               VerticalAlignment="Center"
                               Foreground="#D5DCE4"/>

                    <NumericUpDown Width="60"
                                   Minimum="-500"
                                   Maximum="500"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding SelectedAnimationOffsetYText, Mode=TwoWay}"
                                   Margin="0,0,6,0"/>

                    <Menu Background="Transparent">
                        <MenuItem Header="Selected ▼"
                                  Classes="topAction">
                            <MenuItem Header="Apply Offset To Frame"
                                      Command="{Binding ApplySelectedAnimationOffsetToCurrentFrameCommand}" />
                            <MenuItem Header="Apply Offset To Direction"
                                      Command="{Binding ApplySelectedAnimationOffsetToCurrentDirectionCommand}" />
                            <MenuItem Header="Clear Selected Offset"
                                      Command="{Binding ClearSelectedAnimationOffsetCommand}" />
                        </MenuItem>
                    </Menu>

                    <TextBlock Text="Compare"
                               VerticalAlignment="Center"
                               Foreground="#D5DCE4"
                               Margin="10,0,4,0"/>

                    <TextBlock Text="X"
                               VerticalAlignment="Center"
                               Foreground="#D5DCE4"/>

                    <NumericUpDown Width="60"
                                   Minimum="-500"
                                   Maximum="500"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding CompareOverlayOffsetXText, Mode=TwoWay}"
                                   Margin="0,0,4,0"/>

                    <TextBlock Text="Y"
                               VerticalAlignment="Center"
                               Foreground="#D5DCE4"/>

                    <NumericUpDown Width="60"
                                   Minimum="-500"
                                   Maximum="500"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding CompareOverlayOffsetYText, Mode=TwoWay}"
                                   Margin="0,0,6,0"/>

                    <TextBlock Text="Opacity"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <NumericUpDown Width="78"
                                   Minimum="0"
                                   Maximum="100"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding CompareOverlayOpacityPercentText, Mode=TwoWay}"
                                   Margin="0,0,8,0" />

                    <Menu Background="Transparent">
                        <MenuItem Header="Compare ▼"
                                  Classes="topAction">
                            <MenuItem Header="Mount Rider Align"
                                      Command="{Binding SetupMountRiderAlignmentCommand}" />
                            <MenuItem Header="Apply Current Rider Offset To All Frames"
                                      Command="{Binding ApplyCurrentComparePoseToAllFramesCommand}" />
                            <Separator />
                            <MenuItem Header="Compare On"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding CompareOverlayEnabled, Mode=TwoWay}" />
                            <MenuItem Header="Side-by-Side Preview"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding CompareSideBySideEnabled, Mode=TwoWay}" />
                            <MenuItem Header="Clear Compare"
                                      Command="{Binding ClearCompareOverlayCommand}" />
                            <MenuItem Header="Apply Compare To Frame"
                                      Command="{Binding ApplyCompareOverlayToCurrentFrameCommand}" />
                            <MenuItem Header="Apply Compare To Direction"
                                      Command="{Binding ApplyCompareOverlayToCurrentDirectionCommand}" />
                            <Separator />
                            <MenuItem Header="Save Compare Pose For Frame"
                                      Command="{Binding SaveComparePoseForCurrentFrameCommand}" />
                            <MenuItem Header="Copy Compare Pose From Previous"
                                      Command="{Binding CopyComparePoseFromPreviousFrameCommand}" />
                            <MenuItem Header="Clear Compare Pose For Frame"
                                      Command="{Binding ClearComparePoseForCurrentFrameCommand}" />
                            <Separator />
                            <MenuItem Header="{Binding CompareOverlayDragModeButtonText}"
                                      Command="{Binding ToggleCompareOverlayDragModeCommand}" />
                        </MenuItem>
                    </Menu>

                    <TextBlock Text="X"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <NumericUpDown Width="70"
                                   Minimum="-500"
                                   Maximum="500"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding PropOverlayOffsetXValue, Mode=TwoWay}"
                                   Margin="0,0,6,0" />

                    <TextBlock Text="Y"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <NumericUpDown Width="70"
                                   Minimum="-500"
                                   Maximum="500"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding PropOverlayOffsetYValue, Mode=TwoWay}"
                                   Margin="0,0,6,0" />

                    <TextBlock Text="Scale"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <NumericUpDown Width="78"
                                   Minimum="1"
                                   Maximum="800"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding PropOverlayScalePercentValue, Mode=TwoWay}"
                                   Margin="0,0,6,0" />

                    <TextBlock Text="Rot"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <NumericUpDown Width="78"
                                   Minimum="-180"
                                   Maximum="180"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding PropOverlayRotationDegreesValue, Mode=TwoWay}"
                                   Margin="0,0,6,0" />

                    <TextBlock Text="Pivot X"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <NumericUpDown Width="78"
                                   Minimum="-500"
                                   Maximum="500"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding PropOverlayPivotXValue, Mode=TwoWay}"
                                   Margin="0,0,6,0" />

                    <TextBlock Text="Pivot Y"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <NumericUpDown Width="78"
                                   Minimum="-500"
                                   Maximum="500"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding PropOverlayPivotYValue, Mode=TwoWay}"
                                   Margin="0,0,8,0" />

                    <CheckBox Content="Flip H"
                              IsChecked="{Binding PropOverlayFlipHorizontal}"
                              VerticalAlignment="Center"
                              Margin="0,0,6,0" />

                    <CheckBox Content="Flip V"
                              IsChecked="{Binding PropOverlayFlipVertical}"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0" />

                    <ComboBox Width="88"
                              SelectedIndex="{Binding PropOverlayDrawOrderIndex}"
                              Margin="0,0,8,0">
                        <ComboBoxItem Content="Behind" />
                        <ComboBoxItem Content="Front" />
                    </ComboBox>

                    <Menu Background="Transparent">
                        <MenuItem Header="Preview ▼"
                                  Classes="topAction">
                            <MenuItem Header="Apply To Direction"
                                      Command="{Binding ApplyLivePreviewToCurrentDirectionCommand}" />
                            <MenuItem Header="Apply To Full Animation"
                                      Command="{Binding ApplyLivePreviewToFullAnimationCommand}" />
                            <Separator />
                            <MenuItem Header="Reset Preview Effects"
                                      Command="{Binding ResetLivePreviewCommand}" />
                        </MenuItem>
                    </Menu>

                    <Button Content="Hue..."
                            Command="{Binding ConfigureLivePreviewHueCommand}"
                            Margin="0,0,6,0" />

                    <TextBlock Text="{Binding LivePreviewHueText}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Foreground="#D5DCE4" />

                    <Button Content="Scale..."
                            Command="{Binding ConfigureLivePreviewScaleCommand}"
                            Margin="0,0,6,0" />

                    <TextBlock Text="{Binding LivePreviewScaleText}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Foreground="#D5DCE4" />

                    <Menu Background="Transparent">
                        <MenuItem Header="Props ▼"
                                  Classes="topAction">
                            <MenuItem Header="Prop On"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding PropOverlayEnabled, Mode=TwoWay}" />
                            <MenuItem Header="Load Prop..."
                                      Command="{Binding LoadPropOverlayCommand}" />
                            <MenuItem Header="Clear Prop"
                                      Command="{Binding ClearPropOverlayCommand}" />
                            <Separator />
                            <MenuItem Header="Apply Prop"
                                      Command="{Binding ApplyPropOverlayToCurrentFrameCommand}" />
                            <MenuItem Header="Apply Prop To Direction"
                                      Command="{Binding ApplyPropOverlayToCurrentDirectionCommand}" />
                            <Separator />
                            <MenuItem Header="{Binding PreviewDragModeButtonText}"
                                      Command="{Binding ToggleCompareOverlayDragModeCommand}" />
                            <Separator />
                            <MenuItem Header="Set Pose"
                                      Command="{Binding SavePropPoseForCurrentFrameCommand}" />
                            <MenuItem Header="Copy Previous Pose"
                                      Command="{Binding CopyPropPoseFromPreviousFrameCommand}" />
                            <MenuItem Header="Clear Pose"
                                      Command="{Binding ClearPropPoseForCurrentFrameCommand}" />
                        </MenuItem>
                    </Menu>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- main content -->
        <Grid Grid.Row="5"
              ColumnDefinitions="280,*,310">

            <!-- left -->
            <Border Grid.Column="0"
                    Background="#1E232A"
                    BorderBrush="#343B46"
                    BorderThickness="0,0,1,0"
                    Padding="10"
                    IsVisible="{Binding ShowAnimationEditorPanel}">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                    <TextBlock Grid.Row="0"
                               Text="Animations"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"
                               IsVisible="{Binding ShowAnimationView}" />

                    <TextBlock Grid.Row="0"
                               Text="{Binding SlotPaneTitle}"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"
                               IsVisible="{Binding ShowSlotView}" />

                    <TextBox Grid.Row="1"
                             Watermark="Search animations or MUL slots..."
                             Text="{Binding SearchText}"
                             Margin="0,0,0,10" />

                    <WrapPanel Grid.Row="2"
                               Margin="0,0,0,10"
                               IsVisible="{Binding ShowMulSlotList}"
                               VerticalAlignment="Center">
                        <TextBlock Text="Show:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Foreground="#D5DCE4" />

                        <CheckBox Content="H"
                                  IsChecked="{Binding MulSlotShowHFilter}"
                                  Margin="0,0,10,0" />

                        <CheckBox Content="L"
                                  IsChecked="{Binding MulSlotShowLFilter}"
                                  Margin="0,0,10,0" />

                        <CheckBox Content="P"
                                  IsChecked="{Binding MulSlotShowPFilter}" />
                        <Button Content="Clear Selected"
                                Command="{Binding ClearSelectedMulSlotCommand}"
                                IsVisible="{Binding ShowMulSlotView}" />
                    </WrapPanel>

                    <Grid Grid.Row="3">
                        <ListBox ItemsSource="{Binding AnimationEntries}"
                                 SelectedItem="{Binding SelectedAnimation}"
                                 IsVisible="{Binding ShowAnimationView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="card">
                                        <Grid ColumnDefinitions="6,*">
                                            <Border Classes="selectionBar"
                                                    Grid.Column="0"
                                                    CornerRadius="8,0,0,8" />

                                            <StackPanel Grid.Column="1"
                                                        Spacing="2"
                                                        Margin="10,8,10,8">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="White" />
                                                <TextBlock Classes="subtleText"
                                                           Text="{Binding SecondaryText}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox Name="MulSlotListBox"
                                 ItemsSource="{Binding MulSlotEntries}"
                                 SelectedItem="{Binding SelectedMulSlot}"
                                 IsVisible="{Binding ShowMulSlotList}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="card">
                                        <Grid ColumnDefinitions="6,*">
                                            <Border Classes="selectionBar"
                                                    Grid.Column="0"
                                                    CornerRadius="8,0,0,8" />

                                            <StackPanel Grid.Column="1"
                                                        Spacing="2"
                                                        Margin="10,8,10,8">
                                                <TextBlock Text="{Binding DisplayText}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="White" />
                                                <TextBlock Classes="subtleText"
                                                           Text="{Binding FileName}"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox ItemsSource="{Binding UopBodyEntries}"
                                 SelectedItem="{Binding SelectedUopBodySlot}"
                                 IsVisible="{Binding ShowUopSlotList}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="card">
                                        <Grid ColumnDefinitions="6,*">
                                            <Border Classes="selectionBar"
                                                    Grid.Column="0"
                                                    CornerRadius="8,0,0,8" />

                                            <StackPanel Grid.Column="1"
                                                        Spacing="2"
                                                        Margin="10,8,10,8">
                                                <TextBlock Text="{Binding DisplayText}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="White" />
                                                <TextBlock Classes="subtleText"
                                                           Text="{Binding SecondaryText}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <!-- Maps Tab -->
            <Grid Grid.Column="0"
                  Grid.ColumnSpan="3"
                  IsVisible="{Binding ShowMapsPanel}"
                  ColumnDefinitions="150,*,110"
                  RowDefinitions="*"
                  Margin="0"
                  ColumnSpacing="6"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">

                <!-- Left Panel -->
                <Border Grid.Column="0"
                        Background="#20262E"
                        BorderBrush="#343B46"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8">

                    <StackPanel Spacing="8">

                        <TextBlock Text="Map Viewer"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="#E4EAF2"/>

                        <TextBlock Text="Map" Foreground="#AAB4C0"/>

                        <ComboBox ItemsSource="{Binding MapOptions}"
                                  SelectedItem="{Binding SelectedMapOption}"
                                  DisplayMemberBinding="{Binding DisplayText}"
                                  FontSize="12"/>

                        <Grid ColumnDefinitions="72,72"
                              ColumnSpacing="6">

                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="X" Foreground="#AAB4C0"/>
                                <NumericUpDown Value="{Binding MapViewX, Mode=TwoWay}"
                                               Minimum="0"
                                               Maximum="7168"
                                               Increment="64"
                                               FormatString="0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock Text="Y" Foreground="#AAB4C0"/>
                                <NumericUpDown Value="{Binding MapViewY, Mode=TwoWay}"
                                               Minimum="0"
                                               Maximum="4096"
                                               Increment="64"
                                               FormatString="0"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Zoom" Foreground="#AAB4C0"/>

                        <NumericUpDown Value="{Binding MapZoom, Mode=TwoWay}"
                                       Minimum="0.125"
                                       Maximum="4"
                                       Increment="0.125"
                                       FormatString="0.000"/>

                        <Grid ColumnDefinitions="44,44,44"
                              RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="4"
                              ColumnSpacing="4"
                              HorizontalAlignment="Center">

                            <Button Grid.Row="0" Grid.Column="1" Content="↑" Width="44" Command="{Binding MapMoveUpCommand}"/>
                            <Button Grid.Row="1" Grid.Column="0" Content="←" Width="44" Command="{Binding MapMoveLeftCommand}"/>
                            <Button Grid.Row="1" Grid.Column="1" Content="●" Width="44" Command="{Binding MapGoOriginCommand}"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="→" Width="44" Command="{Binding MapMoveRightCommand}"/>
                            <Button Grid.Row="2" Grid.Column="1" Content="↓" Width="44" Command="{Binding MapMoveDownCommand}"/>
                        </Grid>

                        <Separator/>

                        <TextBlock Text="Altitude Mode"
                                   Foreground="#AAB4C0"/>

                        <ComboBox ItemsSource="{Binding MapAltitudeModes}"
                                  SelectedItem="{Binding SelectedMapAltitudeMode}"/>

                        <TextBlock Text="Altitude Preset"
                                   Foreground="#AAB4C0"/>

                        <ComboBox ItemsSource="{Binding MapAltitudePresets}"
                                  SelectedItem="{Binding SelectedMapAltitudePreset}"/>

                        <TextBlock Text="Intensity"
                                   Foreground="#AAB4C0"/>

                        <NumericUpDown Value="{Binding MapAltitudeIntensity, Mode=TwoWay}"
                                       Minimum="1"
                                       Maximum="20"
                                       Increment="1"
                                       FormatString="0"/>

                        <CheckBox Content="Show statics"
                                  IsChecked="{Binding MapShowStatics}"/>

                        <Button Content="Refresh Map"
                                Command="{Binding RefreshMapPreviewCommand}"/>
                    </StackPanel>
                </Border>

                <!-- Main Map Area -->
                <Border Grid.Column="1"
                        Background="#111317"
                        BorderBrush="#343B46"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="6">

                    <Grid RowDefinitions="Auto,*"
                          RowSpacing="6">

                        <Border Grid.Row="0"
                                Background="#171C22"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="6">

                            <TextBlock Text="{Binding MapStatusText}"
                                       Foreground="#AAB4C0"/>
                        </Border>

                        <Border Grid.Row="1"
                                Background="#0B0E12"
                                PointerPressed="MapPreview_PointerPressed"
                                PointerMoved="MapPreview_PointerMoved"
                                PointerWheelChanged="MapPreview_PointerWheelChanged"
                                ClipToBounds="True">

                            <Viewbox Stretch="Fill"
                                     StretchDirection="Both"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch">

                                <Image Source="{Binding MapPreviewBitmap}"
                                       Stretch="Fill"/>
                            </Viewbox>
                        </Border>
                    </Grid>
                </Border>

                <!-- Right Panel -->
                <Border Grid.Column="2"
                        Background="#20262E"
                        BorderBrush="#343B46"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8">

                    <StackPanel Spacing="8">

                        <TextBlock Text="View Tools"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="#E4EAF2"/>

                        <Button Content="Zoom Full"
                                HorizontalAlignment="Stretch"
                                Command="{Binding MapZoomFullCommand}"/>

                        <Button Content="Zoom 50%"
                                HorizontalAlignment="Stretch"
                                Command="{Binding MapZoomHalfCommand}"/>

                        <Button Content="Zoom 100%"
                                HorizontalAlignment="Stretch"
                                Command="{Binding MapZoomOneCommand}"/>

                        <Button Content="Origin"
                                HorizontalAlignment="Stretch"
                                Command="{Binding MapGoOriginCommand}"/>

                        <Separator/>

                        <TextBlock Text="Map Info"
                                   FontWeight="Bold"
                                   Foreground="#E4EAF2"/>

                        <Separator/>

                        <TextBlock Text="Tile Inspector"
                                   FontWeight="Bold"
                                   Foreground="#E4EAF2"/>

                        <TextBlock Text="{Binding MapTileDetailsText}"
                                   TextWrapping="Wrap"
                                   Foreground="#AAB4C0"/>

                        <Separator/>

                        <TextBlock Text="Markers"
                                   FontWeight="Bold"
                                   Foreground="#E4EAF2"/>

                        <TextBox Text="{Binding NewMapMarkerLabel, Mode=TwoWay}"
                                 Watermark="Marker label"/>

                        <TextBlock Text="{Binding PendingMapMarkerText}"
                                   TextWrapping="Wrap"
                                   Foreground="#AAB4C0"/>

                        <Button Content="Pick Spot On Map"
                                Command="{Binding StartPlaceMapMarkerCommand}"/>

                        <TextBox Text="{Binding NewMapMarkerLabel, Mode=TwoWay}"
                                 Watermark="Marker label"/>

                        <Button Content="Add Marker"
                                Command="{Binding AddMapMarkerCommand}"/>

                        <Button Content="Go To Marker"
                                Command="{Binding GoToMapMarkerCommand}"/>

                        <Button Content="Remove Marker"
                                Command="{Binding RemoveMapMarkerCommand}"/>

                        <ListBox ItemsSource="{Binding MapMarkers}"
                                 SelectedItem="{Binding SelectedMapMarker}"
                                 Height="160">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayText}"
                                               Foreground="#DCE6F1"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="{Binding MapStatusText}"
                                   TextWrapping="Wrap"
                                   Foreground="#AAB4C0"/>

                    </StackPanel>
                </Border>
            </Grid>

            <!-- center -->
            <Grid Grid.Column="1"
                  Grid.ColumnSpan="2"
                  ColumnDefinitions="*,310"
                  Margin="14">

                <!-- Animation Browser -->
                <Grid Grid.Column="0"
                      Grid.ColumnSpan="2"
                      RowDefinitions="Auto,*"
                      Margin="-294,0,0,0"
                      IsVisible="{Binding ShowAnimationBrowserPanel}">

                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="Auto,220,12,Auto,150,12,Auto,150,*,Auto"
                              VerticalAlignment="Center">

                            <TextBlock Grid.Column="0"
                                       Text="Animation Browser"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0" />

                            <TextBox Grid.Column="1"
                                     Watermark="Search body, name, source..."
                                     Text="{Binding AnimationBrowserSearchText}"
                                     VerticalAlignment="Center" />

                            <TextBlock Grid.Column="3"
                                       Text="Source"
                                       Foreground="#D5DCE4"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />

                            <ComboBox Grid.Column="4"
                                      ItemsSource="{Binding AnimationBrowserSourceFilters}"
                                      SelectedItem="{Binding AnimationBrowserSourceFilter}"
                                      VerticalAlignment="Center" />

                            <TextBlock Grid.Column="6"
                                       Text="Type"
                                       Foreground="#D5DCE4"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />

                            <ComboBox Grid.Column="7"
                                      ItemsSource="{Binding AnimationBrowserTypeFilters}"
                                      SelectedItem="{Binding AnimationBrowserTypeFilter}"
                                      VerticalAlignment="Center" />

                            <TextBlock Grid.Column="9"
                                       Text="{Binding AnimationBrowserCountText}"
                                       Foreground="#A9BED0"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,130,20,Auto,20,Auto,100,20,Auto,Auto,12,115,92,12,Auto,*"
                              VerticalAlignment="Center">

                            <TextBlock Grid.Column="0"
                                       Text="Sort"
                                       Foreground="#D5DCE4"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AnimationBrowserSortModeOptions}"
                                      SelectedItem="{Binding AnimationBrowserSortMode}"
                                      VerticalAlignment="Center" />

                            <CheckBox Grid.Column="3"
                                      Content="Show Missing"
                                      IsChecked="{Binding AnimationBrowserShowMissingSlots}"
                                      VerticalAlignment="Center" />

                            <TextBlock Grid.Column="5"
                                       Text="Size"
                                       Foreground="#D5DCE4"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />

                            <ComboBox Grid.Column="6"
                                      ItemsSource="{Binding AnimationBrowserTileSizeOptions}"
                                      SelectedItem="{Binding AnimationBrowserTileSize}"
                                      VerticalAlignment="Center" />

                            <Button Grid.Column="8"
                                    Content="Refresh Thumbnails"
                                    Command="{Binding RefreshAnimationBrowserThumbnailsCommand}"
                                    Padding="10,6"
                                    VerticalAlignment="Center" />

                            <CheckBox Grid.Column="11"
                                      Content="Hover Preview"
                                      IsChecked="{Binding AnimationBrowserHoverPreviewEnabled}"
                                      VerticalAlignment="Center" />

                            <ComboBox Grid.Column="12"
                                      Width="90"
                                      ItemsSource="{Binding AnimationBrowserHoverSpeedOptions}"
                                      SelectedItem="{Binding AnimationBrowserHoverSpeed}"
                                      VerticalAlignment="Center" />

                            <CheckBox Grid.Column="14"
                                      Content="Names"
                                      IsChecked="{Binding AnimationBrowserShowNames}"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="#1E232A"
                            BorderBrush="#343B46"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">

                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">

                            <ListBox ItemsSource="{Binding AnimationBrowserTiles}"
                                     SelectedItem="{Binding SelectedAnimationBrowserTile}"
                                     Classes="animationBrowserList">

                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Classes="animationBrowserTile"
                                                Width="{Binding $parent[Window].DataContext.AnimationBrowserTileWidth}"
                                                Height="{Binding $parent[Window].DataContext.AnimationBrowserTileHeight}"
                                                Tag="{Binding $parent[Window].DataContext}"
                                                PointerEntered="AnimationBrowserTile_PointerEntered"
                                                PointerExited="AnimationBrowserTile_PointerExited">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Open in Editor"
                                                              Command="{Binding $parent[Window].DataContext.OpenAnimationBrowserTileCommand}"
                                                              CommandParameter="{Binding}" />

                                                    <MenuItem Header="Open Detached Preview"
                                                              Command="{Binding $parent[Window].DataContext.OpenAnimationBrowserTileDetachedPreviewCommand}"
                                                              CommandParameter="{Binding}" />

                                                    <MenuItem Header="Edit Name"
                                                              Click="EditAnimationBrowserNameMenuItem_Click"
                                                              Tag="{Binding}" />

                                                    <MenuItem Header="Refresh This Thumbnail"
                                                              Command="{Binding $parent[Window].DataContext.RefreshAnimationBrowserTileThumbnailCommand}"
                                                              CommandParameter="{Binding}" />

                                                    <Separator />

                                                    <MenuItem Header="Export Frames"
                                                              Command="{Binding $parent[Window].DataContext.ExportAnimationBrowserTileFramesCommand}"
                                                              CommandParameter="{Binding}" />

                                                    <MenuItem Header="Export VD"
                                                              Command="{Binding $parent[Window].DataContext.ExportAnimationBrowserTileVdCommand}"
                                                              CommandParameter="{Binding}" />

                                                    <Separator />

                                                    <MenuItem Header="Delete Animation"
                                                              Command="{Binding $parent[Window].DataContext.DeleteAnimationBrowserTileCommand}"
                                                              CommandParameter="{Binding}" />

                                                    <MenuItem Header="Copy Body ID"
                                                              Click="CopyAnimationBrowserBodyIdMenuItem_Click"
                                                              Tag="{Binding}" />

                                                    <MenuItem Header="Copy Source File"
                                                              Click="CopyAnimationBrowserSourceFileMenuItem_Click"
                                                              Tag="{Binding}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid RowDefinitions="*,Auto">
                                                <Border Grid.Row="0"
                                                        Background="#101419"
                                                        BorderBrush="#343B46"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Padding="2">
                                                    <Grid Width="{Binding $parent[Window].DataContext.AnimationBrowserImageHostSize}"
                                                          Height="{Binding $parent[Window].DataContext.AnimationBrowserImageHostSize}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center">
                                                        <Image Source="{Binding Thumbnail}"
                                                               Width="{Binding $parent[Window].DataContext.AnimationBrowserImageBoxSize}"
                                                               Height="{Binding $parent[Window].DataContext.AnimationBrowserImageBoxSize}"
                                                               Stretch="Uniform"
                                                               RenderOptions.BitmapInterpolationMode="None"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding !IsMissingSlot}" />

                                                        <TextBlock Text="MISSING"
                                                                   IsVisible="{Binding IsMissingSlot}"
                                                                   Foreground="#7F8790"
                                                                   FontSize="9"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>

                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding DisplayName}"
                                                           Foreground="White"
                                                           FontSize="10"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,1,0,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Grid Grid.Column="0"
                      Grid.ColumnSpan="2"
                      IsVisible="{Binding ShowGumpEditorPanel}"
                      Margin="-294,0,0,0"
                      RowDefinitions="Auto,*">

                    <Border Grid.Row="0"
                            Background="#1E232A"
                            BorderBrush="#343B46"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">

                            <ComboBox Width="145"
                                      ItemsSource="{Binding GumpSharpenModes}"
                                      SelectedItem="{Binding SelectedGumpSharpenMode}"/>

                            <Button Content="Sharpen"
                                    Command="{Binding SharpenSelectedGumpCommand}"/>

                            <Button Content="Contrast +"
                                    Command="{Binding IncreaseGumpContrastCommand}"/>

                            <Button Content="Contrast -"
                                    Command="{Binding DecreaseGumpContrastCommand}"/>

                            <Button Content="Brighten"
                                    Command="{Binding BrightenGumpCommand}"/>

                            <Button Content="Darken"
                                    Command="{Binding DarkenGumpCommand}"/>

                            <Button Content="Sat +"
                                    Command="{Binding IncreaseGumpSaturationCommand}"/>

                            <Button Content="Sat -"
                                    Command="{Binding DecreaseGumpSaturationCommand}"/>

                            <Button Content="Outline"
                                    Command="{Binding OutlineGumpCommand}"/>

                            <Button Content="Load Overlay Image"
                                    Command="{Binding LoadGumpOverlayImageCommand}"/>

                            <TextBlock Text="Overlay Opacity %"
                                       Foreground="#AAB4C0"
                                       VerticalAlignment="Center"/>

                            <NumericUpDown Minimum="0"
                                           Maximum="100"
                                           Increment="5"
                                           Width="125"
                                           Value="{Binding GumpOverlayOpacityPercent}"/>

                            <ComboBox Width="120"
                                      ItemsSource="{Binding GumpOverlayBlendModes}"
                                      SelectedItem="{Binding SelectedGumpOverlayBlendMode}"/>

                            <Button Content="Apply Overlay To Gump"
                                    Command="{Binding ApplyOverlayToGumpCommand}"/>

                            <Button Content="Save Edit"
                                    Command="{Binding SaveGumpEditCommand}"/>

                            <Button Content="Reset Edit"
                                    Command="{Binding ResetGumpEditPreviewCommand}"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="300,*,260"
                          Background="#111317">

                        <Border Grid.Column="0"
                                BorderBrush="#343B46"
                                BorderThickness="0,0,1,0"
                                Background="#161A20"
                                Padding="8">
                            <Grid RowDefinitions="Auto,*">

                                <StackPanel Grid.Row="0"
                                            Spacing="6"
                                            Margin="0,0,0,8">
                                    <TextBlock Text="Search"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2"/>

                                    <TextBox Watermark="Gump ID..."
                                             Text="{Binding GumpSearchText}"/>
                                </StackPanel>

                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding GumpEntries}"
                                         SelectedItem="{Binding SelectedGump}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="Auto,*"
                                                  Margin="6">
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsSelectedForExport}"
                                                          IsVisible="{Binding IsValid}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,8,0"/>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DisplayText}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#E4EAF2"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="1">

                            <!-- normal centered single preview -->
                            <ScrollViewer IsVisible="{Binding !ShowGumpParallelView}"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <Grid HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="16">

                                    <Border Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            Padding="20">
                                        <Canvas Width="300"
                                                Height="400">

                                            <Image Source="{Binding PaperdollTemplateBitmap}"
                                                   IsVisible="{Binding ShowPaperdollTemplate}"
                                                   Opacity="{Binding PaperdollTemplateOpacity}"
                                                   Canvas.Left="{Binding PaperdollTemplateOffsetX}"
                                                   Canvas.Top="{Binding PaperdollTemplateOffsetY}"
                                                   Stretch="None"/>

                                            <Image Source="{Binding SelectedGumpBitmap}"
                                                   Canvas.Left="{Binding GumpWearableOffsetX}"
                                                   Canvas.Top="{Binding GumpWearableOffsetY}"
                                                   Stretch="None"/>
                                        </Canvas>
                                    </Border>
                                </Grid>
                            </ScrollViewer>

                            <!-- parallel preview -->
                            <Grid IsVisible="{Binding ShowGumpParallelView}"
                                  ColumnDefinitions="*,*">

                                <ScrollViewer Grid.Column="0"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Spacing="8">
                                        <TextBlock Text="Selected"
                                                   HorizontalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="#E4EAF2"/>
                                        <Border Margin="16"
                                                Background="#20242B"
                                                BorderBrush="#343B46"
                                                BorderThickness="1"
                                                Padding="20">
                                            <Image Source="{Binding SelectedGumpBitmap}"
                                                   Stretch="None"/>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>

                                <ScrollViewer Grid.Column="1"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Spacing="8">
                                        <TextBlock Text="{Binding GumpParallelPairText}"
                                                   HorizontalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="#E4EAF2"/>
                                        <Border Margin="16"
                                                Background="#20242B"
                                                BorderBrush="#343B46"
                                                BorderThickness="1"
                                                Padding="20">
                                            <Image Source="{Binding PairedGumpBitmap}"
                                                   Stretch="None"/>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>

                            </Grid>
                        </Grid>

                        <Border Grid.Column="2"
                                Background="#1A1F26"
                                BorderBrush="#343B46"
                                BorderThickness="1,0,0,0"
                                Padding="12">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Spacing="8">

                                    <TextBlock Text="Gump Info"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2"/>

                                    <Border Background="#202733"
                                            BorderBrush="#343B46"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10">
                                        <StackPanel Spacing="8">
                                            <CheckBox Content="Show free slots"
                                                      IsChecked="{Binding ShowFreeGumpSlots}"/>

                                            <ComboBox Width="180"
                                                      SelectedIndex="{Binding SelectedGumpFreeSlotMode}"
                                                      IsVisible="{Binding ShowFreeGumpSlots}">
                                                <ComboBoxItem Content="All Free"/>
                                                <ComboBoxItem Content="Male Wearables"/>
                                                <ComboBoxItem Content="Female Wearables"/>
                                            </ComboBox>

                                            <CheckBox Content="Parallel wearable view"
                                                      IsChecked="{Binding ShowGumpParallelView}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#202733"
                                            BorderBrush="#343B46"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10">
                                        <StackPanel Spacing="8">

                                            <TextBlock Text="Paperdoll Template"
                                                       FontWeight="Bold"
                                                       Foreground="#AAB4C0"/>

                                            <CheckBox Content="Show paperdoll template"
                                                      IsChecked="{Binding ShowPaperdollTemplate}"/>

                                            <StackPanel Spacing="8"
                                                        IsVisible="{Binding ShowPaperdollTemplate}">

                                                <TextBlock Text="Template Gump ID"
                                                           FontWeight="Bold"
                                                           Foreground="#AAB4C0"/>

                                                <NumericUpDown Minimum="0"
                                                               Maximum="65535"
                                                               Value="{Binding PaperdollTemplateGumpId}"
                                                               Width="180"/>

                                                <TextBlock Text="Template Opacity"
                                                           FontWeight="Bold"
                                                           Foreground="#AAB4C0"/>

                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding PaperdollTemplateOpacity}"
                                                        Width="180"/>

                                                <TextBlock Text="Template Offset"
                                                           FontWeight="Bold"
                                                           Foreground="#AAB4C0"/>

                                                <TextBlock Text="{Binding PaperdollTemplateOffsetX, StringFormat='Template X: {0}'}"
                                                           Foreground="#E4EAF2"/>

                                                <TextBlock Text="{Binding PaperdollTemplateOffsetY, StringFormat='Template Y: {0}'}"
                                                           Foreground="#E4EAF2"/>

                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="6">
                                                    <Button Content="←"
                                                            Command="{Binding NudgePaperdollTemplateLeftCommand}"/>
                                                    <Button Content="→"
                                                            Command="{Binding NudgePaperdollTemplateRightCommand}"/>
                                                    <Button Content="↑"
                                                            Command="{Binding NudgePaperdollTemplateUpCommand}"/>
                                                    <Button Content="↓"
                                                            Command="{Binding NudgePaperdollTemplateDownCommand}"/>
                                                </StackPanel>

                                                <Button Content="Reset Template Offset"
                                                        Command="{Binding ResetPaperdollTemplateOffsetCommand}"/>

                                                <TextBlock Text="Wearable Offset"
                                                           FontWeight="Bold"
                                                           Foreground="#AAB4C0"/>

                                                <TextBlock Text="{Binding GumpWearableOffsetX, StringFormat='X: {0}'}"
                                                           Foreground="#E4EAF2"/>

                                                <TextBlock Text="{Binding GumpWearableOffsetY, StringFormat='Y: {0}'}"
                                                           Foreground="#E4EAF2"/>

                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="6">
                                                    <Button Content="←"
                                                            Command="{Binding NudgeGumpLeftCommand}"/>
                                                    <Button Content="→"
                                                            Command="{Binding NudgeGumpRightCommand}"/>
                                                    <Button Content="↑"
                                                            Command="{Binding NudgeGumpUpCommand}"/>
                                                    <Button Content="↓"
                                                            Command="{Binding NudgeGumpDownCommand}"/>
                                                </StackPanel>

                                                <Button Content="Reset Offset"
                                                        Command="{Binding ResetGumpWearableOffsetCommand}"/>

                                                <TextBlock Text="Wearable Scale"
                                                           FontWeight="Bold"
                                                           Foreground="#AAB4C0"/>

                                                <NumericUpDown Minimum="10"
                                                               Maximum="400"
                                                               Increment="5"
                                                               Value="{Binding GumpWearableScalePercent}"
                                                               Width="180"/>

                                                <Button Content="Apply Scale"
                                                        Command="{Binding ApplyGumpPreviewScaleCommand}"/>

                                                <Button Content="Save Offset To Gump"
                                                        Command="{Binding SaveGumpOffsetCommand}"/>

                                                <Button Content="Load Source Image"
                                                        Command="{Binding LoadSourceImageForGumpCommand}"/>

                                                <Button Content="Remove White BG"
                                                        Command="{Binding RemoveWhiteBackgroundFromGumpCommand}"/>

                                                <Button Content="Auto Trim"
                                                        Command="{Binding AutoTrimGumpPreviewCommand}"/>

                                                <Button Content="Save Preview To Gump"
                                                        Command="{Binding SaveGumpEditCommand}"/>

                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="Slots"
                                               FontWeight="Bold"
                                               Foreground="#AAB4C0"/>
                                    <TextBlock Text="{Binding GumpSlotSummaryText}"
                                               Foreground="#E4EAF2"/>

                                    <TextBlock Text="Wearable Free Slots"
                                               FontWeight="Bold"
                                               Foreground="#AAB4C0"/>

                                    <TextBlock Text="{Binding GumpWearableSlotSummaryText}"
                                               Foreground="#E4EAF2"/>

                                    <Border Background="#202733"
                                            BorderBrush="#343B46"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10">
                                        <StackPanel Spacing="6">

                                            <TextBlock Text="ID"
                                                       FontWeight="Bold"
                                                       Foreground="#AAB4C0"/>
                                            <TextBlock Text="{Binding SelectedGump.GumpId}"
                                                       Foreground="#E4EAF2"/>

                                            <TextBlock Text="Hex"
                                                       FontWeight="Bold"
                                                       Foreground="#AAB4C0"/>
                                            <TextBlock Text="{Binding SelectedGump.HexId}"
                                                       Foreground="#E4EAF2"/>

                                            <TextBlock Text="Size"
                                                       FontWeight="Bold"
                                                       Foreground="#AAB4C0"/>
                                            <TextBlock Text="{Binding SelectedGump.SizeText}"
                                                       Foreground="#E4EAF2"/>

                                            <TextBlock Text="Bytes"
                                                       FontWeight="Bold"
                                                       Foreground="#AAB4C0"/>
                                            <TextBlock Text="{Binding SelectedGump.LengthText}"
                                                       Foreground="#E4EAF2"/>

                                            <TextBlock Text="Source File"
                                                       FontWeight="Bold"
                                                       Foreground="#AAB4C0"/>

                                            <TextBlock Text="{Binding SelectedGump.SourceFile}"
                                                       TextWrapping="Wrap"
                                                       Foreground="#E4EAF2"/>

                                            <Button Command="{Binding ExportSelectedGumpCommand}"
                                                    Margin="0,10,0,0">
                                                <TextBlock Text="Export PNG"/>
                                            </Button>

                                            <Button Command="{Binding ExportCheckedGumpsCommand}"
                                                    Margin="0,6,0,0">
                                                <TextBlock Text="Export Checked"/>
                                            </Button>

                                            <Button Command="{Binding ImportCheckedGumpsCommand}"
                                                    Margin="0,6,0,0">
                                                <TextBlock Text="Mass Import Checked"/>
                                            </Button>

                                            <Button Command="{Binding ImportPngToGumpCommand}"
                                                    Margin="0,6,0,0">
                                                <TextBlock Text="Import / Replace Image"/>
                                            </Button>

                                            <Button Command="{Binding RemoveSelectedGumpCommand}"
                                                    Margin="0,6,0,0">
                                                <TextBlock Text="Remove / Free Slot"/>
                                            </Button>

                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Map Maker Tab -->
                <Grid IsVisible="{Binding ShowMapMakerPanel}"
                      RowDefinitions="*"
                      Margin="8"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">

                    <Grid ColumnDefinitions="240,*,220"
                          ColumnSpacing="8">

                        <!-- Left terrain panel -->
                        <Border Grid.Column="0"
                                Background="#20262E"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8">

                            <Grid RowDefinitions="Auto,*">
                                <TextBlock Grid.Row="0"
                                           Text="Dragon Terrain"
                                           FontWeight="Bold"
                                           Foreground="#E6EDF3"
                                           Margin="0,0,0,8" />

                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding DragonTerrainColors}"
                                         SelectedItem="{Binding SelectedDragonTerrainColor, Mode=TwoWay}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="28,*"
                                                  ColumnSpacing="8"
                                                  Margin="0,3">
                                                <Border Grid.Column="0"
                                                        Width="22"
                                                        Height="22"
                                                        Background="{Binding Brush}" />

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DisplayText}"
                                                           Foreground="#D8E1EA"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- Map canvas -->
                        <Border Grid.Column="1"
                                MinWidth="800"
                                MinHeight="700"
                                Background="#111317"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8"
                                ClipToBounds="True"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">

                            <Grid RowDefinitions="*,Auto"
                                  RowSpacing="6">

                                <ScrollViewer Grid.Row="0"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">

                                    <Image Source="{Binding DragonMapBitmap}"
                                           Tag="{Binding DragonMapRefreshKey}"
                                           Width="{Binding DragonMapImageWidth}"
                                           Height="{Binding DragonMapImageHeight}"
                                           Stretch="Fill"
                                           RenderOptions.BitmapInterpolationMode="None"
                                           PointerPressed="DragonMapPointerPressed"
                                           PointerMoved="DragonMapPointerMoved" />

                                </ScrollViewer>

                                <TextBlock Grid.Row="1"
                                           Text="{Binding DragonMapHoverStatusText}"
                                           Foreground="#9FB3C8"
                                           FontSize="12" />
                            </Grid>
                        </Border>

                        <!-- Right tools panel -->
                        <Border Grid.Column="2"
                                Background="#20262E"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8">

                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="8">

                                    <TextBlock Text="Map Tools"
                                               FontWeight="Bold"
                                               Foreground="#E6EDF3" />

                                    <Button Content="New Dragon Map"
                                            Command="{Binding NewDragonMapCommand}" />

                                    <Button Content="Open BMP"
                                            Click="OpenDragonMapButton_Click" />

                                    <Button Content="Save BMP"
                                            Click="SaveDragonMapButton_Click" />

                                    <Button Content="Export map0 MUL"
                                            Click="ExportDragonMapMulButton_Click" />

                                    <Button Content="Validate"
                                            Command="{Binding ValidateDragonMapCommand}" />

                                    <Button Content="Undo"
                                            Command="{Binding UndoDragonMapCommand}" />

                                    <Button Content="Fill Canvas"
                                            Command="{Binding FillDragonMapCanvasCommand}" />

                                    <Separator />

                                    <TextBlock Text="Tool"
                                               Foreground="#C7D1DB" />

                                    <ComboBox ItemsSource="{Binding DragonMapTools}"
                                              SelectedItem="{Binding SelectedDragonMapTool, Mode=TwoWay}" />

                                    <TextBlock Text="Brush Size"
                                               Foreground="#C7D1DB" />

                                    <NumericUpDown Minimum="1"
                                                   Maximum="128"
                                                   Increment="1"
                                                   FormatString="0"
                                                   Value="{Binding DragonBrushSize, Mode=TwoWay}" />

                                    <TextBlock Text="Brush Shape"
                                               Foreground="#C7D1DB" />

                                    <ComboBox ItemsSource="{Binding DragonBrushShapes}"
                                              SelectedItem="{Binding SelectedDragonBrushShape, Mode=TwoWay}" />

                                    <TextBlock Text="Stamp"
                                               Foreground="#C7D1DB" />

                                    <ComboBox ItemsSource="{Binding DragonMapStamps}"
                                              SelectedItem="{Binding SelectedDragonMapStamp, Mode=TwoWay}" />

                                    <TextBlock Text="Zoom"
                                               Foreground="#C7D1DB" />

                                    <NumericUpDown Minimum="0.05"
                                                   Maximum="4"
                                                   Increment="0.05"
                                                   FormatString="0.00"
                                                   Value="{Binding DragonMapZoom, Mode=TwoWay}" />

                                    <TextBlock Text="{Binding DragonMapZoomText}"
                                               Foreground="#9FB3C8" />

                                    <Separator />

                                    <TextBlock Text="{Binding DragonMapStatusText}"
                                               TextWrapping="Wrap"
                                               Foreground="#9FB3C8" />

                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Sound Tab -->
                <Grid IsVisible="{Binding ShowSoundsPanel}"
                      RowDefinitions="Auto,*"
                      RowSpacing="8"
                      Margin="8">

                    <!-- Top Sound Toolbar -->
                    <Border Grid.Row="0"
                            Background="#20262E"
                            BorderBrush="#343B46"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10">

                        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,Auto,Auto"
                              ColumnSpacing="8">

                            <Button Grid.Column="0"
                                    Content="Load Sounds"
                                    Command="{Binding LoadSoundsCommand}" />

                            <Button Grid.Column="1"
                                    Content="Save Sounds"
                                    Command="{Binding SaveSoundsCommand}" />

                            <Button Grid.Column="2"
                                    Content="Import Audio"
                                    Command="{Binding ImportSelectedSoundCommand}" />

                            <Button Grid.Column="3"
                                    Content="Export Selected"
                                    Command="{Binding ExportSelectedSoundCommand}" />

                            <Button Grid.Column="4"
                                    Content="Export All"
                                    Command="{Binding ExportAllSoundsCommand}" />

                            <Button Grid.Column="5"
                                    Content="Find Free"
                                    Command="{Binding FindFirstFreeSoundSlotCommand}" />

                            <TextBox Grid.Column="6"
                                     Watermark="Search sound ID, hex, or name..."
                                     Text="{Binding SoundSearchText, Mode=TwoWay}" />

                            <CheckBox Grid.Column="7"
                                      Content="Free"
                                      IsChecked="{Binding ShowFreeSoundSlots}" />

                            <CheckBox Grid.Column="8"
                                      Content="Sort Name"
                                      IsChecked="{Binding SortSoundsByName}" />

                            <Button Grid.Column="9"
                                    Content="Remove"
                                    Command="{Binding RemoveSelectedSoundCommand}" />
                        </Grid>
                    </Border>

                    <!-- Main Layout -->
                    <Grid Grid.Row="1"
                          ColumnDefinitions="360,360,*"
                          ColumnSpacing="8">

                        <!-- Sound List -->
                        <Border Grid.Column="0"
                                Background="#181D24"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8">

                            <Grid RowDefinitions="Auto,*"
                                  RowSpacing="8">

                                <TextBlock Text="Sounds"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#E4EAF2" />

                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding SoundEntries}"
                                         SelectedItem="{Binding SelectedSoundEntry}"
                                         BorderThickness="0"
                                         Background="Transparent">

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid RowDefinitions="Auto,Auto">
                                                <TextBlock Text="{Binding DisplayText}"
                                                           Foreground="#E4EAF2" />

                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding LengthText}"
                                                           Foreground="#8F9AA8"
                                                           FontSize="11" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- Music List -->
                        <Border Grid.Column="1"
                                Background="#181D24"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8">

                            <Grid RowDefinitions="Auto,Auto,*,Auto"
                                  RowSpacing="8">

                                <TextBlock Text="Music / MP3"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#E4EAF2" />

                                <Grid Grid.Row="1"
                                      ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">

                                    <TextBox Grid.Column="0"
                                             Watermark="Search music ID or name..."
                                             Text="{Binding MusicSearchText, Mode=TwoWay}" />

                                    <Button Grid.Column="1"
                                            Content="Load"
                                            Command="{Binding LoadMusicCommand}" />
                                </Grid>

                                <ListBox Grid.Row="2"
                                         ItemsSource="{Binding MusicEntries}"
                                         SelectedItem="{Binding SelectedMusicEntry}"
                                         BorderThickness="0"
                                         Background="Transparent">

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid RowDefinitions="Auto,Auto">
                                                <TextBlock Text="{Binding DisplayText}"
                                                           Foreground="#E4EAF2" />

                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding StatusText}"
                                                           Foreground="#8F9AA8"
                                                           FontSize="11" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Grid.Row="3"
                                           Text="{Binding MusicStatusText}"
                                           Foreground="#8F9AA8"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </Border>

                        <!-- Right Tools / Details -->
                        <Border Grid.Column="2"
                                Background="#20262E"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">

                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="12">

                                    <TextBlock Text="Audio Tools"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2" />

                                    <!-- Sound Preview -->
                                    <Border Background="#181D24"
                                            BorderBrush="#3A4350"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10">

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Sound Preview"
                                                       FontWeight="Bold"
                                                       Foreground="#E4EAF2" />

                                            <TextBlock Text="{Binding SelectedSoundInfoText}"
                                                       Foreground="#AAB4C0"
                                                       TextWrapping="Wrap" />

                                            <Border Background="#11161D"
                                                    BorderBrush="#3A4350"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Height="108"
                                                    Padding="6">

                                                <Image Source="{Binding SoundWaveformBitmap}"
                                                       Stretch="Fill"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Stretch" />
                                            </Border>

                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8">
                                                <Button Content="Play Sound"
                                                        Command="{Binding PlaySelectedSoundCommand}" />

                                                <Button Content="Stop"
                                                        Command="{Binding StopSoundCommand}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Required Format -->
                                    <Border Background="#181D24"
                                            BorderBrush="#3A4350"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="8">

                                        <TextBlock
                                        Text="UO Format: PCM WAV  |  Mono  |  22050 Hz  |  16-bit"
                                        Foreground="#AAB4C0"/>
                                    </Border>

                                    <!-- Music Controls -->
                                    <Border Background="#181D24"
                                            BorderBrush="#3A4350"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10">

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Music Controls"
                                                       FontWeight="Bold"
                                                       Foreground="#E4EAF2" />

                                            <WrapPanel>
                                                <Button Content="Import Music"
                                                        Margin="0,0,8,8"
                                                        Command="{Binding ImportMusicCommand}" />

                                                <CheckBox Content="Loop"
                                                          Margin="0,0,8,8"
                                                          IsChecked="{Binding ImportedMusicShouldLoop}" />

                                                <Button Content="Play Music"
                                                        Margin="0,0,8,8"
                                                        Command="{Binding PlaySelectedMusicCommand}" />

                                                <Button Content="Stop Music"
                                                        Margin="0,0,8,8"
                                                        Command="{Binding StopMusicCommand}" />

                                                <Button Content="Music → Sound"
                                                        Margin="0,0,8,8"
                                                        Command="{Binding ConvertSelectedMusicToSoundCommand}" />

                                                <Button Content="Remove Music"
                                                        Margin="0,0,8,8"
                                                        Command="{Binding RemoveSelectedMusicCommand}" />

                                                <CheckBox Content="Delete MP3"
                                                          Margin="0,0,8,8"
                                                          IsChecked="{Binding DeleteMusicFileOnRemove}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Edit Music Config Entry -->
                                    <Border Background="#181D24"
                                            BorderBrush="#3A4350"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10">

                                        <Grid RowDefinitions="Auto,Auto,Auto"
                                              RowSpacing="10">

                                            <TextBlock Text="Edit Music Config Entry"
                                                       FontWeight="Bold"
                                                       Foreground="#E4EAF2" />

                                            <Grid Grid.Row="1"
                                                  ColumnDefinitions="80,*"
                                                  RowDefinitions="Auto,Auto,Auto"
                                                  ColumnSpacing="10"
                                                  RowSpacing="8">

                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="0"
                                                           Text="ID"
                                                           VerticalAlignment="Center"
                                                           Foreground="#AAB4C0" />

                                                <NumericUpDown Grid.Row="0"
                                                               Grid.Column="1"
                                                               Width="140"
                                                               HorizontalAlignment="Left"
                                                               Value="{Binding EditableMusicId, Mode=TwoWay}"
                                                               Minimum="0"
                                                               Maximum="9999"
                                                               FormatString="0" />

                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="0"
                                                           Text="File"
                                                           VerticalAlignment="Center"
                                                           Foreground="#AAB4C0" />

                                                <TextBox Grid.Row="1"
                                                         Grid.Column="1"
                                                         MinWidth="320"
                                                         HorizontalAlignment="Stretch"
                                                         Text="{Binding EditableMusicFileName, Mode=TwoWay}" />

                                                <CheckBox Grid.Row="2"
                                                          Grid.Column="1"
                                                          Content="Loop"
                                                          IsChecked="{Binding EditableMusicLoop}" />
                                            </Grid>

                                            <Button Grid.Row="2"
                                                    Content="Save Entry"
                                                    HorizontalAlignment="Left"
                                                    Command="{Binding SaveSelectedMusicEntryCommand}" />
                                        </Grid>
                                    </Border>

                                    <!-- Music Info -->
                                    <Border Background="#181D24"
                                            BorderBrush="#3A4350"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10">

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Selected Music Info"
                                                       FontWeight="Bold"
                                                       Foreground="#E4EAF2" />

                                            <TextBlock Text="{Binding SelectedMusicInfoText}"
                                                       Foreground="#AAB4C0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="{Binding SoundStatusText}"
                                               Foreground="#8F9AA8"
                                               TextWrapping="Wrap" />

                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Cliloc Tab -->
                <Grid Grid.Column="0"
                      Grid.ColumnSpan="3"
                      Margin="-270,10,10,10"
                      RowDefinitions="Auto,*"
                      RowSpacing="10"
                      IsVisible="{Binding ShowClilocPanel}">

                    <Border Grid.Row="0"
                            Background="#20262E"
                            BorderBrush="#3A4350"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">

                        <Grid RowDefinitions="Auto,8,Auto"
                              RowSpacing="0">

                            <!-- Row 1: common controls -->
                            <ScrollViewer Grid.Row="0"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">

                                    <TextBlock Text="Search"
                                               Foreground="#D5DCE4"
                                               VerticalAlignment="Center"/>

                                    <TextBox Width="260"
                                             Watermark="ID, hex, category, or text"
                                             Text="{Binding ClilocSearchText, Mode=TwoWay}"/>

                                    <CheckBox Content="Use UOX3 Dictionary Mode"
                                              IsChecked="{Binding UseUoxDictionaryMode}"
                                              VerticalAlignment="Center"/>

                                    <CheckBox Content="Duplicates"
                                              IsChecked="{Binding ShowOnlyDuplicateClilocs}"
                                              VerticalAlignment="Center"/>

                                    <CheckBox Content="Empty"
                                              IsChecked="{Binding ShowOnlyEmptyClilocs}"
                                              VerticalAlignment="Center"/>

                                    <Separator Width="1"
                                               Height="24"
                                               Background="#3A4350"/>

                                    <Button Content="Import"
                                            Command="{Binding ImportClilocCommand}"/>

                                    <Button Content="Export"
                                            Command="{Binding ExportClilocCommand}"/>

                                    <Button Content="Save"
                                            Command="{Binding SaveClilocCommand}"/>

                                    <Button Content="Add Entry"
                                            Command="{Binding AddClilocEntryCommand}"/>

                                    <Button Content="Delete Entry"
                                            Command="{Binding DeleteClilocEntryCommand}"/>

                                    <TextBox Width="110"
                                             Watermark="Jump ID"
                                             Text="{Binding JumpToClilocText, Mode=TwoWay}"/>

                                    <Button Content="Go"
                                            Command="{Binding JumpToClilocCommand}"/>

                                </StackPanel>
                            </ScrollViewer>

                            <!-- Row 2: mode-specific controls -->
                            <ScrollViewer Grid.Row="2"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">

                                <Grid>
                                    <!-- Normal cliloc controls -->
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                IsVisible="{Binding ShowClilocFileControls}">

                                        <TextBlock Text="Cliloc File"
                                                   Foreground="#AAB4C0"
                                                   VerticalAlignment="Center"/>

                                        <ComboBox Width="160"
                                                  ItemsSource="{Binding ClilocFileOptions}"
                                                  SelectedItem="{Binding SelectedClilocFile}"/>

                                        <Button Content="Load Cliloc"
                                                Command="{Binding LoadClilocCommand}"/>

                                    </StackPanel>

                                    <!-- UOX3 dictionary controls -->
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                IsVisible="{Binding ShowUoxDictionaryControls}">

                                        <Button Content="Select UOX3 Folder"
                                                Command="{Binding SelectUoxDictionaryFolderCommand}"/>

                                        <ComboBox Width="220"
                                                  ItemsSource="{Binding DictionaryFileOptions}"
                                                  SelectedItem="{Binding SelectedDictionaryFile}"/>

                                        <Button Content="Load Dictionary"
                                                Command="{Binding LoadDictionaryCommand}"/>

                                        <TextBlock Text="Category"
                                                   Foreground="#AAB4C0"
                                                   VerticalAlignment="Center"/>

                                        <ComboBox Width="180"
                                                  ItemsSource="{Binding UoxDictionaryCategoryOptions}"
                                                  SelectedItem="{Binding SelectedUoxDictionaryCategory}"/>

                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>

                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="520,10,*">

                        <Border Grid.Column="0"
                                Background="#171B21"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="8">
                            <ListBox ItemsSource="{Binding FilteredClilocEntries}"
                                     SelectedItem="{Binding SelectedClilocEntry}"
                                     Background="#11151A">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="90,90,80,*" Margin="4">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Number}"
                                                       Foreground="#86C5FF"/>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding NumberHex}"
                                                       Foreground="#AAB4C0"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding RowStatus}"
                                                       Foreground="#FFD580"/>

                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Text}"
                                                       Foreground="#EDF1F5"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <Border Grid.Column="2"
                                Background="#20262E"
                                BorderBrush="#3A4350"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14">
                            <Grid RowDefinitions="Auto,*,Auto"
                                  RowSpacing="12">

                                <StackPanel Grid.Row="0" Spacing="8">
                                    <TextBlock Text="{Binding ClilocEditorTitle}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#EDF1F5"/>

                                    <TextBlock Text="{Binding SelectedClilocEntry.Number}"
                                               Foreground="#86C5FF"/>

                                    <TextBlock Text="{Binding SelectedClilocEntry.NumberHex}"
                                               Foreground="#AAB4C0"/>
                                </StackPanel>

                                <TextBox Grid.Row="1"
                                         Text="{Binding SelectedClilocEntry.Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="220"/>

                                <Border Grid.Row="2"
                                        Background="#171B21"
                                        BorderBrush="#343B46"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding FreeNumberTitle}"
                                                   FontWeight="Bold"
                                                   Foreground="#EDF1F5"/>

                                        <Button Content="{Binding FindFreeNumbersButtonText}"
                                                Command="{Binding FindFreeClilocNumbersCommand}"/>

                                        <ListBox ItemsSource="{Binding FreeClilocNumbers}"
                                                 SelectedItem="{Binding SelectedFreeClilocNumber}"
                                                 Height="180"
                                                 Background="#11151A"/>

                                        <Button Content="{Binding UseFreeNumberButtonText}"
                                                Command="{Binding AddClilocEntryFromFreeNumberCommand}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Light Tab -->
                <Grid Grid.Column="0"
                      Grid.ColumnSpan="2"
                      IsVisible="{Binding ShowLightPanel}"
                      Margin="-294,0,0,0"
                      RowDefinitions="Auto,*">

                    <Border Grid.Row="0" Background="#1E232A" Padding="12,8">
                        <WrapPanel Orientation="Horizontal">
                            <Button Content="Load" Command="{Binding LoadLightsCommand}" Margin="0,0,6,6"/>
                            <Button Content="Save" Command="{Binding SaveLightsCommand}" Margin="0,0,6,6"/>
                            <Button Content="Reset" Command="{Binding ResetLightsCommand}" Margin="0,0,6,6"/>
                            <Button Content="Undo" Command="{Binding UndoLightEditCommand}" Margin="0,0,6,6"/>
                            <Button Content="Redo" Command="{Binding RedoLightEditCommand}" Margin="0,0,6,6"/>

                            <CheckBox Content="Show Removed"
                                      IsChecked="{Binding ShowRemovedLightSlots, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,6"/>

                            <Button Content="Import PNG" Command="{Binding ImportSelectedLightPngCommand}" Margin="0,0,6,6"/>
                            <Button Content="Export PNG" Command="{Binding ExportSelectedLightPngCommand}" Margin="0,0,10,6"/>

                            <TextBlock Text="W" VerticalAlignment="Center" Foreground="#AAB4C0" Margin="0,0,4,6"/>
                            <NumericUpDown Value="{Binding NewLightWidth, Mode=TwoWay}"
                                           Minimum="8"
                                           Maximum="600"
                                           Width="120"
                                           FormatString="0"/>

                            <TextBlock Text="H" VerticalAlignment="Center" Foreground="#AAB4C0" Margin="0,0,4,6"/>
                            <NumericUpDown Value="{Binding NewLightHeight, Mode=TwoWay}"                Minimum="8"
                                           Maximum="600"
                                           Width="120"
                                           FormatString="0"/>

                            <TextBlock Text="Strength" VerticalAlignment="Center" Foreground="#AAB4C0" Margin="0,0,4,6"/>
                            <NumericUpDown Value="{Binding LightPresetStrength, Mode=TwoWay}" Minimum="1" Maximum="31" Width="120" FormatString="0" Margin="0,0,10,6"/>

                            <Button Content="Light Tools" Margin="0,0,10,6">
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuItem Header="New Blank" Command="{Binding CreateBlankLightCommand}" />
                                        <MenuItem Header="Clear Selected" Command="{Binding ClearSelectedLightCommand}" />
                                        <MenuItem Header="Remove Selected" Command="{Binding RemoveSelectedLightCommand}" />

                                        <MenuItem Header="Round Preset" Command="{Binding CreateRoundLightCommand}" />
                                        <MenuItem Header="Window Preset" Command="{Binding CreateWindowLightCommand}" />
                                        <MenuItem Header="Door Slit Preset" Command="{Binding CreateDoorSlitLightCommand}" />

                                        <MenuItem Header="Soften Selected" Command="{Binding SoftenSelectedLightCommand}" />
                                        <MenuItem Header="Sharpen Selected" Command="{Binding SharpenSelectedLightCommand}" />
                                        <MenuItem Header="Flip Horizontal" Command="{Binding FlipSelectedLightHorizontalCommand}" />
                                        <MenuItem Header="Flip Vertical" Command="{Binding FlipSelectedLightVerticalCommand}" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>

                            <TextBlock Text="Brush" VerticalAlignment="Center" Foreground="#AAB4C0" Margin="0,0,4,6"/>
                            <NumericUpDown Value="{Binding LightBrushSize, Mode=TwoWay}" Minimum="1" Maximum="100" Width="120" FormatString="0" Margin="0,0,6,6"/>

                            <TextBlock Text="Paint" VerticalAlignment="Center" Foreground="#AAB4C0" Margin="0,0,4,6"/>
                            <NumericUpDown Value="{Binding LightBrushStrength, Mode=TwoWay}" Minimum="1" Maximum="31" Width="120" FormatString="0" Margin="0,0,6,6"/>

                            <CheckBox Content="Erase"
                                      IsChecked="{Binding LightBrushErase, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,6,6"/>
                        </WrapPanel>
                    </Border>

                    <Grid Grid.Row="1" ColumnDefinitions="300,*" Margin="10" ColumnSpacing="10">
                        <ListBox Grid.Column="0"
                                 ItemsSource="{Binding LightEntries}"
                                 SelectedItem="{Binding SelectedLightEntry}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayText}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SizeText}" Foreground="#AAB4C0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border x:Name="LightPreviewPaintSurface"
                                Grid.Column="1"
                                Background="#D0D0D0"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="20"
                                PointerPressed="LightPreviewPaintSurface_PointerPressed"
                                PointerMoved="LightPreviewPaintSurface_PointerMoved"
                                PointerReleased="LightPreviewPaintSurface_PointerReleased">

                            <Image x:Name="LightPreviewImage"
                                   Source="{Binding SelectedLightEntry.Preview, TargetNullValue={x:Null}}"
                                   Stretch="None"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Hues Tab -->
                <tabs:HueEditorTab Grid.Column="0"
                                   Grid.ColumnSpan="3"
                                   Margin="-270,10,10,10"
                                   IsVisible="{Binding ShowHueEditorPanel}" />

                <!-- Gump Builder Tab -->
                <Grid Grid.Column="0"
                      Grid.ColumnSpan="3"
                      IsVisible="{Binding ShowGumpBuilderPanel}"
                      RowDefinitions="Auto,*"
                      RowSpacing="8"
                      Margin="-294,10,10,10"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">

                    <Border Grid.Row="0"
                            Background="#202733"
                            BorderBrush="#344052"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8">
                        <WrapPanel>
                            <Button Content="Add Background" Command="{Binding AddGumpBuilderBackgroundCommand}" />
                            <Button Content="Add Selected Gump" Command="{Binding LoadSelectedGumpIntoBuilderCommand}" />
                            <Button Content="Add CheckerTrans" Command="{Binding AddGumpBuilderCheckerTransCommand}" />
                            <Button Content="Add Gump" Command="{Binding AddGumpBuilderOpenGumpPickerCommand}" />
                            <Button Content="Add Picture" Command="{Binding AddGumpBuilderImageCommand}" />
                            <Button Content="Add PicInPic" Command="{Binding AddGumpBuilderPicInPicCommand}" />
                            <Button Content="Add Button" Command="{Binding AddGumpBuilderButtonCommand}" />
                            <Button Content="Add Button TileArt" Command="{Binding AddGumpBuilderButtonTileArtCommand}" />
                            <Button Content="Add Page Button"
                                    Command="{Binding AddGumpBuilderPageButtonCommand}" />
                            <Button Content="Add Text" Command="{Binding AddGumpBuilderLabelCommand}" />
                            <Button Content="Add Cropped Text"
                                    Command="{Binding AddGumpBuilderCroppedTextCommand}" />
                            <Button Content="Add HTML" Command="{Binding AddGumpBuilderHtmlCommand}" />
                            <Button Content="Add XMF HTML"
                                    Command="{Binding AddGumpBuilderXmfHtmlCommand}" />

                            <Button Content="Add XMF Color"
                                    Command="{Binding AddGumpBuilderXmfHtmlColorCommand}" />

                            <Button Content="Add XMF Tok"
                                    Command="{Binding AddGumpBuilderXmfHtmlTokCommand}" />
                            <Button Content="Add Text Entry" Command="{Binding AddGumpBuilderTextEntryCommand}" />
                            <Button Content="Add Checkbox" Command="{Binding AddGumpBuilderCheckboxCommand}" />
                            <Button Content="Add Radio" Command="{Binding AddGumpBuilderRadioCommand}" />
                            <Button Content="Add Group" Command="{Binding AddGumpBuilderGroupStartCommand}" />
                            <Button Content="End Group" Command="{Binding AddGumpBuilderGroupEndCommand}" />
                            <Button Content="Add Page" Command="{Binding AddGumpBuilderPageCommand}" />
                            <Button Content="Add Item Property" Command="{Binding AddGumpBuilderItemPropertyCommand}" />
                            <Button Content="Add ToolTip" Command="{Binding AddGumpBuilderClilocToolTipCommand}" />
                            <Button Content="Add Tiled" Command="{Binding AddGumpBuilderTiledImageCommand}" />
                            <Button Content="Move Up" Command="{Binding MoveSelectedGumpBuilderElementUpCommand}" />
                            <Button Content="Move Down" Command="{Binding MoveSelectedGumpBuilderElementDownCommand}" />
                            <Button Content="Delete" Command="{Binding DeleteSelectedGumpBuilderElementCommand}" />

                            <CheckBox Content="Snap"
                                      IsChecked="{Binding GumpBuilderSnapToGrid}"
                                      Foreground="#E4EAF2"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0"/>

                            <TextBlock Text="Grid"
                                       Foreground="#AAB4C0"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>

                            <NumericUpDown Value="{Binding GumpBuilderGridSize, Mode=TwoWay}"
                                           Minimum="1"
                                           Maximum="100"
                                           Width="70"/>

                            <Menu VerticalAlignment="Center"
                                  Margin="8,0,0,0">
                                <MenuItem Header="Export">
                                    <MenuItem Header="UOX3 JavaScript"
                                              Command="{Binding ShowGumpBuilderUox3ExportCommand}"/>
                                    <MenuItem Header="C#"
                                              Command="{Binding ShowGumpBuilderCSharpExportCommand}"/>
                                    <MenuItem Header="Sphere"
                                              Command="{Binding ShowGumpBuilderSphereExportCommand}"/>
                                    <MenuItem Header="POL"
                                              Command="{Binding ShowGumpBuilderPolExportCommand}"/>
                                </MenuItem>
                            </Menu>
                        </WrapPanel>
                    </Border>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="340,*,380"
                          ColumnSpacing="10"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">

                        <!-- Left: Elements + Properties -->
                        <Border Grid.Column="0"
                                Background="#202733"
                                BorderBrush="#344052"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="8">

                                    <TextBlock Text="Gump Options"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2"/>

                                    <CheckBox Content="MasterGump"
                                              IsChecked="{Binding GumpBuilderUseMasterGump}"
                                              Foreground="#E4EAF2"/>

                                    <NumericUpDown Value="{Binding GumpBuilderMasterGumpId, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="65535"/>

                                    <UniformGrid Columns="2"
                                                 RowSpacing="4"
                                                 ColumnSpacing="6">
                                        <CheckBox Content="NoClose"
                                                  IsChecked="{Binding GumpBuilderNoClose}"
                                                  Foreground="#E4EAF2"/>

                                        <CheckBox Content="NoDispose"
                                                  IsChecked="{Binding GumpBuilderNoDispose}"
                                                  Foreground="#E4EAF2"/>

                                        <CheckBox Content="NoMove"
                                                  IsChecked="{Binding GumpBuilderNoMove}"
                                                  Foreground="#E4EAF2"/>

                                        <CheckBox Content="NoResize"
                                                  IsChecked="{Binding GumpBuilderNoResize}"
                                                  Foreground="#E4EAF2"/>
                                    </UniformGrid>

                                    <Separator/>

                                    <TextBlock Text="Elements"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2"/>

                                    <ListBox ItemsSource="{Binding GumpBuilderElements}"
                                             SelectedItem="{Binding SelectedGumpBuilderElement}"
                                             Height="220">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="#E4EAF2"
                                                               FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding DisplayText}"
                                                               Foreground="#AAB4C0"
                                                               FontSize="11"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Separator/>

                                    <TextBlock Text="Properties"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2"/>

                                    <UniformGrid Columns="2"
                                                 ColumnSpacing="6"
                                                 RowSpacing="6">

                                        <TextBlock Text="X" Foreground="#AAB4C0"/>
                                        <TextBlock Text="Y" Foreground="#AAB4C0"/>

                                        <NumericUpDown Value="{Binding SelectedGumpBuilderElement.X, Mode=TwoWay}"
                                                       Minimum="-5000"
                                                       Maximum="5000"/>
                                        <NumericUpDown Value="{Binding SelectedGumpBuilderElement.Y, Mode=TwoWay}"
                                                       Minimum="-5000"
                                                       Maximum="5000"/>

                                        <TextBlock Text="Width" Foreground="#AAB4C0"/>
                                        <TextBlock Text="Height" Foreground="#AAB4C0"/>

                                        <NumericUpDown Value="{Binding SelectedGumpBuilderElement.Width, Mode=TwoWay}"
                                                       Minimum="1"
                                                       Maximum="5000"/>
                                        <NumericUpDown Value="{Binding SelectedGumpBuilderElement.Height, Mode=TwoWay}"
                                                       Minimum="1"
                                                       Maximum="5000"/>

                                        <TextBlock Text="Gump ID / Art ID" Foreground="#AAB4C0"/>
                                        <TextBlock Text="Hue" Foreground="#AAB4C0"/>

                                        <NumericUpDown Value="{Binding SelectedGumpBuilderElement.GumpId, Mode=TwoWay}"
                                                       Minimum="0"
                                                       Maximum="65535"/>
                                        <NumericUpDown Value="{Binding SelectedGumpBuilderElement.Hue, Mode=TwoWay}"
                                                       Minimum="0"
                                                       Maximum="65535"/>

                                        <TextBlock Text="Pressed Gump ID" Foreground="#AAB4C0"/>
                                        <NumericUpDown Value="{Binding SelectedGumpBuilderElement.PressedGumpId, Mode=TwoWay}"
                                                       Minimum="0"
                                                       Maximum="65535"/>

                                        <TextBlock Text="Button ID" Foreground="#AAB4C0"/>
                                        <NumericUpDown Value="{Binding SelectedGumpBuilderElement.ButtonId, Mode=TwoWay}"
                                                       Minimum="0"
                                                       Maximum="9999"/>

                                        <TextBlock Grid.Row="14" Grid.Column="0" Text="Group Number" Foreground="#AAB4C0"/>

                                        <NumericUpDown Grid.Row="15" Grid.Column="0"
                                                       Value="{Binding SelectedGumpBuilderElement.GroupNumber, Mode=TwoWay}"
                                                       Minimum="0"
                                                       Maximum="9999"/>

                                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Tile ID" Foreground="#AAB4C0"/>
                                        <TextBlock Grid.Row="10" Grid.Column="1" Text="Tile Hue" Foreground="#AAB4C0"/>

                                        <NumericUpDown Grid.Row="11" Grid.Column="0"
                                                       Value="{Binding SelectedGumpBuilderElement.TileId, Mode=TwoWay}"
                                                       Minimum="0"
                                                       Maximum="65535"/>

                                        <NumericUpDown Grid.Row="11" Grid.Column="1"
                                                       Value="{Binding SelectedGumpBuilderElement.Hue, Mode=TwoWay}"
                                                       Minimum="0"
                                                       Maximum="65535"/>

                                        <TextBlock Grid.Row="12" Grid.Column="0" Text="Tile X Offset" Foreground="#AAB4C0"/>
                                        <TextBlock Grid.Row="12" Grid.Column="1" Text="Tile Y Offset" Foreground="#AAB4C0"/>

                                        <NumericUpDown Grid.Row="13" Grid.Column="0"
                                                       Value="{Binding SelectedGumpBuilderElement.TileX, Mode=TwoWay}"
                                                       Minimum="-5000"
                                                       Maximum="5000"/>

                                        <NumericUpDown Grid.Row="13" Grid.Column="1"
                                                       Value="{Binding SelectedGumpBuilderElement.TileY, Mode=TwoWay}"
                                                       Minimum="-5000"
                                                       Maximum="5000"/>

                                        <TextBlock Grid.Row="16" Grid.Column="0" Text="Page Number" Foreground="#AAB4C0"/>
                                        <TextBlock Grid.Row="16" Grid.Column="1" Text="Cliloc Number" Foreground="#AAB4C0"/>

                                        <NumericUpDown Grid.Row="17" Grid.Column="0"
                                                       Value="{Binding SelectedGumpBuilderElement.PageNumber, Mode=TwoWay}"
                                                       Minimum="0"
                                                       Maximum="9999"/>

                                        <NumericUpDown Grid.Row="17" Grid.Column="1"
                                                       Value="{Binding SelectedGumpBuilderElement.ClilocNumber, Mode=TwoWay}"
                                                       Minimum="0"
                                                       Maximum="999999999"/>

                                        <TextBlock Text="Item Property Object"
                                                   Foreground="#AAB4C0"/>

                                        <TextBox Text="{Binding SelectedGumpBuilderElement.ItemPropertyObject, Mode=TwoWay}"/>

                                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Z" Foreground="#AAB4C0"/>

                                        <NumericUpDown Grid.Row="9" Grid.Column="0"
                                                       Value="{Binding SelectedGumpBuilderElement.Z, Mode=TwoWay}"
                                                       Minimum="-1000"
                                                       Maximum="1000"/>

                                        <TextBlock Grid.Row="18" Grid.Column="0" Text="Sprite X" Foreground="#AAB4C0"/>
                                        <TextBlock Grid.Row="18" Grid.Column="1" Text="Sprite Y" Foreground="#AAB4C0"/>

                                        <NumericUpDown Grid.Row="19" Grid.Column="0"
                                                       Value="{Binding SelectedGumpBuilderElement.SpriteX, Mode=TwoWay}"
                                                       Minimum="0"
                                                       Maximum="5000"/>

                                        <NumericUpDown Grid.Row="19" Grid.Column="1"
                                                       Value="{Binding SelectedGumpBuilderElement.SpriteY, Mode=TwoWay}"
                                                       Minimum="0"
                                                       Maximum="5000"/>

                                        <TextBlock Grid.Row="20" Grid.Column="0" Text="Text ID" Foreground="#AAB4C0"/>
                                        <TextBlock Grid.Row="20" Grid.Column="1" Text="Max Length" Foreground="#AAB4C0"/>

                                        <NumericUpDown Grid.Row="21" Grid.Column="0"
                                                       Value="{Binding SelectedGumpBuilderElement.TextId, Mode=TwoWay}"
                                                       Minimum="0"
                                                       Maximum="9999"/>

                                        <NumericUpDown Grid.Row="21" Grid.Column="1"
                                                       Value="{Binding SelectedGumpBuilderElement.MaxLength, Mode=TwoWay}"
                                                       Minimum="0"
                                                       Maximum="9999"/>

                                    </UniformGrid>

                                    <UniformGrid Columns="2"
                                                 ColumnSpacing="6"
                                                 RowSpacing="4">
                                        <CheckBox Content="Background"
                                                  IsChecked="{Binding SelectedGumpBuilderElement.HasBackground, Mode=TwoWay}"
                                                  Foreground="#E4EAF2"/>

                                        <CheckBox Content="Scrollbar"
                                                  IsChecked="{Binding SelectedGumpBuilderElement.HasScrollbar, Mode=TwoWay}"
                                                  Foreground="#E4EAF2"/>

                                        <CheckBox Content="Border"
                                                  IsChecked="{Binding SelectedGumpBuilderElement.HasBorder, Mode=TwoWay}"
                                                  Foreground="#E4EAF2"/>

                                        <TextBlock Text="RGB Colour"
                                                   Foreground="#AAB4C0"/>
                                    </UniformGrid>

                                    <NumericUpDown Value="{Binding SelectedGumpBuilderElement.RgbColour, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="16777215"/>

                                    <TextBlock Text="Cliloc Arg 1" Foreground="#AAB4C0"/>
                                    <TextBox Text="{Binding SelectedGumpBuilderElement.ClilocArg1, Mode=TwoWay}"/>

                                    <TextBlock Text="Cliloc Arg 2" Foreground="#AAB4C0"/>
                                    <TextBox Text="{Binding SelectedGumpBuilderElement.ClilocArg2, Mode=TwoWay}"/>

                                    <TextBlock Text="Cliloc Arg 3" Foreground="#AAB4C0"/>
                                    <TextBox Text="{Binding SelectedGumpBuilderElement.ClilocArg3, Mode=TwoWay}"/>

                                    <CheckBox Content="Limited Text Entry"
                                              IsChecked="{Binding SelectedGumpBuilderElement.LimitedTextEntry, Mode=TwoWay}"
                                              Foreground="#E4EAF2"/>

                                    <Button Content="Apply Picker Gump"
                                            Command="{Binding ApplySelectedPickerGumpToElementCommand}"/>

                                    <CheckBox Content="Default Checked"
                                              IsChecked="{Binding SelectedGumpBuilderElement.DefaultStatus, Mode=TwoWay}"
                                              Foreground="#E4EAF2"/>

                                    <TextBlock Text="Text" Foreground="#AAB4C0"/>
                                    <TextBox Text="{Binding SelectedGumpBuilderElement.Text, Mode=TwoWay}"
                                             AcceptsReturn="True"
                                             Height="90"/>

                                    <TextBlock Text="{Binding GumpBuilderStatusText}"
                                               Foreground="#AAB4C0"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Center: Big Canvas -->
                        <Border Grid.Column="1"
                                Background="#15191F"
                                BorderBrush="#344052"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12">

                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">

                                <Canvas Width="{Binding GumpBuilderWidth}"
                                        Height="{Binding GumpBuilderHeight}"
                                        Background="#101318"
                                        ClipToBounds="False">

                                    <ItemsControl x:Name="GumpBuilderItemsControl"
                                                  ItemsSource="{Binding GumpBuilderElements}"
                                                  Width="{Binding GumpBuilderWidth}"
                                                  Height="{Binding GumpBuilderHeight}">

                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="Transparent"
                                                        Cursor="SizeAll"
                                                        ZIndex="{Binding Z}"
                                                        PointerPressed="GumpBuilderElement_PointerPressed"
                                                        PointerMoved="GumpBuilderElement_PointerMoved"
                                                        PointerReleased="GumpBuilderElement_PointerReleased">

                                                    <Border.RenderTransform>
                                                        <TranslateTransform X="{Binding X}" Y="{Binding Y}"/>
                                                    </Border.RenderTransform>


                                                    <Border Padding="6"
                                                            Background="Transparent">

                                                        <Grid Width="{Binding Width}"
                                                              Height="{Binding Height}"
                                                              ClipToBounds="False">
                                                            <Image Source="{Binding Bitmap}"
                                                                   Stretch="None"
                                                                   UseLayoutRounding="False"
                                                                   RenderOptions.BitmapInterpolationMode="None"
                                                                   HorizontalAlignment="Left"
                                                                   VerticalAlignment="Top"/>

                                                            <Border Margin="-6"
                                                                    BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToSelectionBrushConverter}}"
                                                                    BorderThickness="1"
                                                                    Background="Transparent"
                                                                    IsVisible="{Binding IsSelected}"/>

                                                            <Border Background="#3366A6FF"
                                                                    Opacity="0.45"
                                                                    IsVisible="{Binding !HasBitmap}">
                                                                <TextBlock Text="{Binding Type}"
                                                                           Foreground="White"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>

                                                            <Border Width="8" Height="8" Background="White" BorderBrush="Black" BorderThickness="1"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-10,-10,0,0" IsVisible="{Binding IsSelected}" Tag="NW"
                                                                    PointerPressed="GumpBuilderResizeHandle_PointerPressed"
                                                                    PointerMoved="GumpBuilderResizeHandle_PointerMoved"
                                                                    PointerReleased="GumpBuilderResizeHandle_PointerReleased"/>

                                                            <Border Width="8" Height="8" Background="White" BorderBrush="Black" BorderThickness="1"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-10,0,0" IsVisible="{Binding IsSelected}" Tag="N"
                                                                    PointerPressed="GumpBuilderResizeHandle_PointerPressed"
                                                                    PointerMoved="GumpBuilderResizeHandle_PointerMoved"
                                                                    PointerReleased="GumpBuilderResizeHandle_PointerReleased"/>

                                                            <Border Width="8" Height="8" Background="White" BorderBrush="Black" BorderThickness="1"
                                                                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,0" IsVisible="{Binding IsSelected}" Tag="NE"
                                                                    PointerPressed="GumpBuilderResizeHandle_PointerPressed"
                                                                    PointerMoved="GumpBuilderResizeHandle_PointerMoved"
                                                                    PointerReleased="GumpBuilderResizeHandle_PointerReleased"/>

                                                            <Border Width="8" Height="8" Background="White" BorderBrush="Black" BorderThickness="1"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-10,0,0,0" IsVisible="{Binding IsSelected}" Tag="W"
                                                                    PointerPressed="GumpBuilderResizeHandle_PointerPressed"
                                                                    PointerMoved="GumpBuilderResizeHandle_PointerMoved"
                                                                    PointerReleased="GumpBuilderResizeHandle_PointerReleased"/>

                                                            <Border Width="8" Height="8" Background="White" BorderBrush="Black" BorderThickness="1"
                                                                    HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-10,0" IsVisible="{Binding IsSelected}" Tag="E"
                                                                    PointerPressed="GumpBuilderResizeHandle_PointerPressed"
                                                                    PointerMoved="GumpBuilderResizeHandle_PointerMoved"
                                                                    PointerReleased="GumpBuilderResizeHandle_PointerReleased"/>

                                                            <Border Width="8" Height="8" Background="White" BorderBrush="Black" BorderThickness="1"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-10,0,0,-10" IsVisible="{Binding IsSelected}" Tag="SW"
                                                                    PointerPressed="GumpBuilderResizeHandle_PointerPressed"
                                                                    PointerMoved="GumpBuilderResizeHandle_PointerMoved"
                                                                    PointerReleased="GumpBuilderResizeHandle_PointerReleased"/>

                                                            <Border Width="8" Height="8" Background="White" BorderBrush="Black" BorderThickness="1"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-10" IsVisible="{Binding IsSelected}" Tag="S"
                                                                    PointerPressed="GumpBuilderResizeHandle_PointerPressed"
                                                                    PointerMoved="GumpBuilderResizeHandle_PointerMoved"
                                                                    PointerReleased="GumpBuilderResizeHandle_PointerReleased"/>

                                                            <Border Width="8" Height="8" Background="White" BorderBrush="Black" BorderThickness="1"
                                                                    HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-10,-10" IsVisible="{Binding IsSelected}" Tag="SE"
                                                                    PointerPressed="GumpBuilderResizeHandle_PointerPressed"
                                                                    PointerMoved="GumpBuilderResizeHandle_PointerMoved"
                                                                    PointerReleased="GumpBuilderResizeHandle_PointerReleased"/>
                                                        </Grid>
                                                    </Border>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Canvas>
                            </ScrollViewer>
                        </Border>

                        <!-- Right: Pickers + Export -->
                        <Border Grid.Column="2"
                                Background="#202733"
                                BorderBrush="#344052"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10">

                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="8">

                                    <TextBlock Text="Gump Picker"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2"/>

                                    <DockPanel>
                                        <TextBox DockPanel.Dock="Left"
                                                 Width="210"
                                                 Watermark="Gump ID / Hex"
                                                 Text="{Binding GumpBuilderPickerSearchText, Mode=TwoWay}"/>

                                        <Button Content="Search"
                                                Command="{Binding RefreshGumpBuilderPickerCommand}"
                                                Margin="6,0,0,0"/>
                                    </DockPanel>

                                    <ListBox ItemsSource="{Binding GumpBuilderPickerEntries}"
                                             SelectedItem="{Binding SelectedGumpBuilderPickerEntry}"
                                             Height="160">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Foreground="#E4EAF2"
                                                           Text="{Binding DisplayText}"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Border Background="#101318"
                                            BorderBrush="#344052"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="6"
                                            Height="140">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto">
                                            <Image Source="{Binding SelectedGumpBuilderGumpPickerPreview}"
                                                   Stretch="None"
                                                   RenderOptions.BitmapInterpolationMode="None"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        </ScrollViewer>
                                    </Border>

                                    <Button Content="Add Selected Gump"
                                            Command="{Binding AddSelectedPickerGumpToBuilderCommand}"/>

                                    <Separator/>

                                    <TextBlock Text="Art Picker"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2"/>

                                    <DockPanel>
                                        <TextBox DockPanel.Dock="Left"
                                                 Width="210"
                                                 Watermark="Art ID / Hex"
                                                 Text="{Binding GumpBuilderArtPickerSearchText, Mode=TwoWay}"/>

                                        <Button Content="Search"
                                                Command="{Binding RefreshGumpBuilderArtPickerCommand}"
                                                Margin="6,0,0,0"/>
                                    </DockPanel>

                                    <ListBox ItemsSource="{Binding GumpBuilderArtPickerEntries}"
                                             SelectedItem="{Binding SelectedGumpBuilderArtPickerEntry}"
                                             Height="160">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Foreground="#E4EAF2"
                                                           Text="{Binding DisplayText}"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Border Background="#101318"
                                            BorderBrush="#344052"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="6"
                                            Height="140">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto">
                                            <Image Source="{Binding SelectedGumpBuilderArtPickerPreview}"
                                                   Stretch="None"
                                                   RenderOptions.BitmapInterpolationMode="None"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        </ScrollViewer>
                                    </Border>

                                    <Button Content="Add Selected Art"
                                            Command="{Binding AddSelectedArtToGumpBuilderCommand}"/>

                                    <Separator/>

                                    <Border Background="#15191F"
                                            BorderBrush="#344052"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8"
                                            IsVisible="{Binding HasGumpBuilderActiveExport}">
                                        <StackPanel Spacing="8">

                                            <TextBlock Text="{Binding GumpBuilderActiveExportTitle}"
                                                       FontWeight="Bold"
                                                       Foreground="#E4EAF2"/>

                                            <!-- Sphere options only show for Sphere export -->
                                            <StackPanel Spacing="6"
                                                        IsVisible="{Binding IsGumpBuilderSphereExportVisible}">
                                                <TextBox Text="{Binding GumpBuilderSphereName, Mode=TwoWay}"
                                                         Watermark="Sphere gump name"/>

                                                <CheckBox Content="Sphere 0.56 / Revision"
                                                          IsChecked="{Binding GumpBuilderSphereRevision, Mode=TwoWay}"
                                                          Foreground="#E4EAF2"/>
                                            </StackPanel>

                                            <!-- POL options only show for POL export -->
                                            <StackPanel Spacing="6"
                                                        IsVisible="{Binding IsGumpBuilderPolExportVisible}">
                                                <TextBox Text="{Binding GumpBuilderPolName, Mode=TwoWay}"
                                                         Watermark="POL gump name"/>

                                                <CheckBox Content="POL Distro Gump Package"
                                                          IsChecked="{Binding GumpBuilderPolUseDistro, Mode=TwoWay}"
                                                          Foreground="#E4EAF2"/>
                                            </StackPanel>

                                            <TextBox Text="{Binding GumpBuilderActiveExportText, Mode=TwoWay}"
                                                     AcceptsReturn="True"
                                                     TextWrapping="NoWrap"
                                                     FontFamily="Consolas"
                                                     FontSize="12"
                                                     Height="220"/>

                                            <Button Content="{Binding GumpBuilderActiveCopyButtonText}"
                                                    Command="{Binding CopyGumpBuilderActiveExportCommand}"
                                                    HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Tiledata Tab -->
                <Grid Grid.Column="0"
                      Grid.ColumnSpan="2"
                      IsVisible="{Binding ShowTileDataPanel}"
                      Margin="-294,0,0,0"
                      RowDefinitions="Auto,*">

                    <Border Grid.Row="0"
                            Background="#1E232A"
                            BorderBrush="#343B46"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <CheckBox Content="Land"
                                      IsChecked="{Binding ShowLandTileData}" />

                            <CheckBox Content="Items"
                                      IsChecked="{Binding ShowItemTileData}" />

                            <TextBox Width="220"
                                     Watermark="Search ID / name..."
                                     Text="{Binding TileDataSearchText}" />


                            <Button Content="Save TileData Changes"
                                    Command="{Binding SaveTileDataChangesCommand}" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="360,*"
                          ColumnSpacing="10"
                          Margin="10">

                        <Border Grid.Column="0"
                                Background="#20262E"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ListBox ItemsSource="{Binding FilteredTileDataEntries}"
                                     SelectedItem="{Binding SelectedTileDataEntry}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}"
                                                   Foreground="#E4EAF2"
                                                   Margin="6"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <Border Grid.Column="1"
                                Background="#20262E"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12">
                            <Grid ColumnDefinitions="280,*"
                                  ColumnSpacing="12">

                                <StackPanel Grid.Column="0"
                                            Spacing="6">

                                    <TextBlock Text="{Binding SelectedTileDataEntry.DisplayText}"
                                               FontSize="18"
                                               FontWeight="Bold"/>

                                    <TextBlock Text="{Binding SelectedTileDataEntry.Flags, StringFormat='Flags: 0x{0:X16}'}"/>

                                    <TextBlock Text="Name"/>
                                    <TextBox Text="{Binding SelectedTileDataEntry.Name, Mode=TwoWay}"
                                             LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Animation/Gump"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Animation, Mode=TwoWay}"
                                                   Minimum="-32768"
                                                   Maximum="32767"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Weight"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Weight, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Quality/Layer/Light"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Quality, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Quantity"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Quantity, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Hue"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Hue, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Stack Offset"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.StackingOffset, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Value"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Value, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Height"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Height, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="MiscData"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.MiscData, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="65535"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Unk2"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Unknown2, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Unk3"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Unknown3, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Background="#151A20"
                                        BorderBrush="#343B46"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8">

                                    <Grid RowDefinitions="Auto,*"
                                          RowSpacing="8">

                                        <CheckBox Grid.Row="0"
                                                  Content="Apply flag changes to checked art tiles"
                                                  IsChecked="{Binding ApplyTileDataFlagsToCheckedArt}"
                                                  Foreground="#C7D1DB"/>

                                        <ScrollViewer Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding SelectedTileDataFlagOptions}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Width="150"
                                                                  Margin="2"
                                                                  Content="{Binding Name}"
                                                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                                  Command="{Binding $parent[ItemsControl].DataContext.ToggleSelectedTileDataFlagCommand}"
                                                                  CommandParameter="{Binding}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Art Tab -->
                <Grid Grid.Column="0"
                      Grid.ColumnSpan="2"
                      IsVisible="{Binding ShowArtPanel}"
                      Margin="-294,0,0,0"
                      RowDefinitions="Auto,*">

                    <Border Grid.Row="0"
                            Background="#1E232A"
                            BorderBrush="#343B46"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Button Content="Load Art"
                                    Command="{Binding LoadArtTabCommand}" />

                            <Button Content="Art Cutter"
                                    Command="{Binding OpenArtCutterCommand}" />

                            <Button Content="Import Selected"
                                    Command="{Binding ImportSelectedArtCommand}" />

                            <Button Content="Mass Import"
                                    Command="{Binding MassImportArtCommand}" />

                            <Button Content="Export Selected"
                                    Command="{Binding ExportSelectedArtCommand}" />

                            <Button Content="Mass Export"
                                    Command="{Binding MassExportArtCommand}" />

                            <Button Content="Remove Checked"
                                    Command="{Binding RemoveCheckedArtCommand}" />

                            <Button Content="Undo Art Change"
                                    Command="{Binding UndoArtChangeCommand}" />

                            <Button Content="Check All"
                                    Command="{Binding CheckAllArtCommand}" />

                            <Button Content="Uncheck All"
                                    Command="{Binding UncheckAllArtCommand}" />

                            <Button Content="Save Art Changes"
                                    Command="{Binding SaveArtChangesCommand}" />

                            <Button Content="Save TileData"
                                    Command="{Binding SaveTileDataChangesCommand}" />

                            <Button Content="Save AnimData"
                                    Command="{Binding SaveAnimDataCommand}" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="360,*,300"
                          ColumnSpacing="10"
                          Margin="10">

                        <!-- Left: Filters + Art List -->
                        <Grid Grid.Column="0"
                              RowDefinitions="Auto,*"
                              RowSpacing="8">

                            <Border Grid.Row="0"
                                    Background="#20262E"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <StackPanel Spacing="6">
                                    <TextBox Watermark="Search ID / hex..."
                                             Text="{Binding ArtSearchText}" />

                                    <ComboBox ItemsSource="{Binding ArtSlotFilterOptions}"
                                              SelectedItem="{Binding SelectedArtSlotFilter}"
                                              Width="180"/>

                                    <ComboBox ItemsSource="{Binding ArtEraFilters}"
                                              SelectedItem="{Binding SelectedArtEraFilter}"
                                              PlaceholderText="Art Filter"
                                              Width="220"/>

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="12">
                                        <CheckBox Content="Land"
                                                  IsChecked="{Binding ShowLandArt}" />

                                        <CheckBox Content="Statics"
                                                  IsChecked="{Binding ShowStaticArt}" />

                                        <CheckBox Content="ArtTiles"
                                                  IsChecked="{Binding ShowArtThumbnails}" />
                                        <CheckBox Content="Browser"
                                                  IsChecked="{Binding ShowArtBrowserMode}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Background="#20262E"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ListBox ItemsSource="{Binding ArtEntries}"
                                         SelectedItem="{Binding SelectedArtEntry}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="Auto,54,*"
                                                  ColumnSpacing="8"
                                                  Margin="6"
                                                  Classes.pendingArt="{Binding IsPendingChange}">
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsChecked}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,6,0"/>

                                                <Border Grid.Column="1"
                                                        Width="48"
                                                        Height="48"
                                                        Background="#151A20"
                                                        BorderBrush="#343B46"
                                                        BorderThickness="1">
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="Uniform"
                                                           RenderOptions.BitmapInterpolationMode="None"/>
                                                </Border>

                                                <StackPanel Grid.Column="2"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayText}"
                                                               FontWeight="SemiBold"
                                                               Foreground="#E4EAF2" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Grid>

                        <!-- Middle: Preview -->
                        <Grid Grid.Column="1"
                              RowDefinitions="*,Auto"
                              RowSpacing="10">

                            <Border Grid.Row="0"
                                    Background="#20262E"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">

                                <Grid>

                                    <!-- Normal single preview -->
                                    <ScrollViewer IsVisible="{Binding ShowArtSinglePreview}"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">

                                        <Grid HorizontalAlignment="Center"
                                              VerticalAlignment="Center">

                                            <Image Source="{Binding SelectedArtBitmap}"
                                                   Stretch="None"
                                                   RenderOptions.BitmapInterpolationMode="None"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />

                                            <!-- UO 44x44 tile base overlay -->
                                            <Path IsVisible="{Binding ShowArtTileBaseOverlay}"
                                                  Data="M 0,22 L 22,0 L 44,22 L 22,44 Z"
                                                  Stroke="#D14B4B"
                                                  StrokeThickness="1"
                                                  Fill="#22D14B4B"
                                                  Width="44"
                                                  Height="44"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Bottom"/>
                                        </Grid>
                                    </ScrollViewer>

                                    <!-- browser preview -->
                                    <ListBox IsVisible="{Binding ShowArtBrowserPreview}"
                                             ItemsSource="{Binding ArtEntries}"
                                             SelectedItem="{Binding SelectedArtEntry, Mode=TwoWay}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0">

                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>

                                        <ListBox.Styles>
                                            <Style Selector="ListBoxItem">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Style>

                                            <Style Selector="ListBoxItem:selected Border.browserTile">
                                                <Setter Property="BorderBrush" Value="#2D8CFF"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Background" Value="#163A5C"/>
                                            </Style>
                                        </ListBox.Styles>

                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="browserTile"
                                                        Classes.pendingArt="{Binding IsPendingChange}"
                                                        Width="54"
                                                        Height="54"
                                                        Margin="2"
                                                        Background="#151A20"
                                                        BorderBrush="#3A4350"
                                                        BorderThickness="1"
                                                        PointerPressed="ArtBrowserTile_PointerPressed"
                                                        PointerEntered="ArtBrowserTile_PointerEntered"
                                                        DoubleTapped="ArtBrowserTile_DoubleTapped">

                                                    <Grid>
                                                        <Image Source="{Binding BrowserThumbnail}"
                                                               Stretch="Uniform"
                                                               RenderOptions.BitmapInterpolationMode="None" />

                                                        <!-- Checked marker, not a checkbox -->
                                                        <Border IsVisible="{Binding IsChecked}"
                                                                BorderBrush="#2D8CFF"
                                                                BorderThickness="2"
                                                                Background="#22163A5C" />

                                                        <!-- Pending unsaved marker -->
                                                        <Border IsVisible="{Binding IsPendingChange}"
                                                                BorderBrush="#D14B4B"
                                                                BorderThickness="2"
                                                                Background="#22332020" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                </Grid>
                            </Border>

                            <Border Grid.Row="1"
                                    IsVisible="{Binding ShowSelectedArtAnimDataPreview}"
                                    Background="#151A20"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <StackPanel Spacing="6">

                                    <TextBlock Text="{Binding SelectedArtAnimDataEntry.SecondaryText}"
                                               HorizontalAlignment="Center"
                                               Foreground="#C7D1DB"
                                               FontWeight="SemiBold"/>

                                    <Button Content="{Binding ArtAnimDataPlayButtonText}"
                                            Command="{Binding ToggleArtAnimDataPlaybackCommand}"
                                            HorizontalAlignment="Center"
                                            MinWidth="80"/>

                                    <ItemsControl ItemsSource="{Binding SelectedArtAnimDataFrames}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center"
                                                            Spacing="8"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="58"
                                                        Height="70"
                                                        Background="#20262E"
                                                        BorderBrush="#343B46"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        Padding="4">
                                                    <StackPanel>
                                                        <Image Source="{Binding Bitmap}"
                                                               Stretch="None"
                                                               RenderOptions.BitmapInterpolationMode="None"
                                                               HorizontalAlignment="Left"
                                                               VerticalAlignment="Top"/>

                                                        <TextBlock Text="{Binding FrameIndex}"
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="#E4EAF2"
                                                                   FontSize="11"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Right: Art Info + TileData Info -->
                        <Border Grid.Column="2"
                                Background="#20262E"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="12">

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Art Info"
                                                   FontWeight="Bold"
                                                   Foreground="#E4EAF2" />

                                        <TextBlock Text="{Binding SelectedArtEntry.DisplayText}"
                                                   Foreground="#C7D1DB"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Text="{Binding SelectedArtEntry.SecondaryText}"
                                                   Foreground="#AAB4C0"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Text="{Binding SelectedArtVisibleBounds.FullSizeText, StringFormat='Full size: {0}'}"
                                                   Foreground="#AAB4C0"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Text="{Binding SelectedArtVisibleBounds.BoundsText, StringFormat='Visible bounds: {0}'}"
                                                   Foreground="#AAB4C0"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Text="{Binding SelectedArtVisibleBounds.VisibleSizeText, StringFormat='Visible size: {0}'}"
                                                   Foreground="#AAB4C0"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Text="{Binding SelectedArtVisibleBounds.PaddingText, StringFormat='Transparent padding: {0}'}"
                                                   Foreground="#AAB4C0"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Text="Radar Color"
                                                   Foreground="#E4EAF2"
                                                   FontWeight="SemiBold"
                                                   Margin="0,8,0,0"/>

                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8"
                                                    VerticalAlignment="Center">

                                            <Border Width="34"
                                                    Height="20"
                                                    Background="{Binding SelectedArtRadarBrush}"
                                                    BorderBrush="#566273"
                                                    BorderThickness="1"
                                                    CornerRadius="3"/>

                                            <TextBlock Text="{Binding SelectedArtRadarColorText}"
                                                       Foreground="#AAB4C0"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <TextBlock Text="Current radarcol.mul Color"
                                                   Foreground="#E4EAF2"
                                                   FontWeight="SemiBold"
                                                   Margin="0,8,0,0"/>

                                        <StackPanel Spacing="4">

                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8"
                                                        VerticalAlignment="Center">

                                                <Border Width="34"
                                                        Height="20"
                                                        Background="{Binding SelectedArtCurrentRadarBrush}"
                                                        BorderBrush="#566273"
                                                        BorderThickness="1"
                                                        CornerRadius="3"/>

                                                <TextBlock Text="{Binding SelectedArtCurrentRadarColorText}"
                                                           Foreground="#AAB4C0"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <TextBlock Text="{Binding SelectedArtRadarMatchText}"
                                                       Foreground="#E6C86E"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Margin="42,2,0,0"/>

                                        </StackPanel>

                                        <WrapPanel Orientation="Horizontal"
                                                   Margin="0,6,0,0">

                                            <Button Content="Apply Generated"
                                                    Command="{Binding ApplyGeneratedRadarColorToSelectedArtCommand}"
                                                    MinWidth="120"
                                                    Margin="0,0,6,6"/>

                                            <Button Content="Apply Checked"
                                                    Command="{Binding ApplyGeneratedRadarColorToCheckedArtCommand}"
                                                    MinWidth="110"
                                                    Margin="0,0,6,6"/>

                                            <Button Content="Revert"
                                                    Command="{Binding RevertSelectedRadarColorCommand}"
                                                    MinWidth="80"
                                                    Margin="0,0,6,6"/>

                                            <Button Content="Save RadarCol"
                                                    Command="{Binding SaveRadarColCommand}"
                                                    MinWidth="110"
                                                    Margin="0,0,6,6"/>
                                        </WrapPanel>
                                    </StackPanel>

                                    <Border Height="1"
                                            Background="#343B46"
                                            Margin="0,4"/>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="TileData Info"
                                                   FontWeight="Bold"
                                                   Foreground="#E4EAF2" />

                                        <TextBlock Text="{Binding SelectedArtTileDataEntry.DisplayText}"
                                                   Foreground="#C7D1DB"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Text="{Binding SelectedArtTileDataEntry.Flags, StringFormat='Flags: 0x{0:X16}'}"
                                                   Foreground="#AAB4C0"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Text="{Binding SelectedArtTileDataFlagNames, StringFormat='Flag Names: {0}'}"
                                                   Foreground="#AAB4C0"
                                                   TextWrapping="Wrap" />

                                        <Button Content="Edit Flags..."
                                                Command="{Binding OpenArtTileDataFlagsCommand}" />

                                        <Button Content="{Binding ArtAnimDataEditButtonText}"
                                                Command="{Binding OpenArtAnimDataEditorCommand}" />

                                        <CheckBox Content="Show TileData Editor"
                                                  IsChecked="{Binding ShowArtTileDataEditor}"
                                                  Foreground="#C7D1DB"/>

                                        <CheckBox Content="Apply field changes to checked art tiles"
                                                  IsChecked="{Binding ApplyTileDataFieldsToCheckedArt}"
                                                  Foreground="#C7D1DB"
                                                  Margin="0,6,0,8"/>

                                        <StackPanel IsVisible="{Binding ShowArtTileDataEditor}"
                                                    Spacing="4">

                                            <TextBlock Text="Name" Foreground="#AAB4C0"/>
                                            <TextBox Text="{Binding SelectedArtTileDataEntry.Name, Mode=TwoWay}"
                                                     LostFocus="ArtTileDataEditField_LostFocus"/>

                                            <TextBlock Text="Animation/Gump" Foreground="#AAB4C0"/>
                                            <NumericUpDown Value="{Binding SelectedArtTileDataEntry.Animation, Mode=TwoWay}"
                                                           Minimum="0"
                                                           Maximum="640000"
                                                           Increment="1"
                                                           FormatString="0"
                                                           LostFocus="ArtTileDataEditField_LostFocus"/>

                                            <TextBlock Text="Weight" Foreground="#AAB4C0"/>
                                            <NumericUpDown Value="{Binding SelectedArtTileDataEntry.Weight, Mode=TwoWay}"
                                                           Minimum="0"
                                                           Maximum="255"
                                                           Increment="1"
                                                           FormatString="0"
                                                           LostFocus="ArtTileDataEditField_LostFocus"/>

                                            <TextBlock Text="Quality/Layer/Light" Foreground="#AAB4C0"/>
                                            <NumericUpDown Value="{Binding SelectedArtTileDataEntry.Quality, Mode=TwoWay}"
                                                           Minimum="0"
                                                           Maximum="255"
                                                           Increment="1"
                                                           FormatString="0"
                                                           LostFocus="ArtTileDataEditField_LostFocus"/>

                                            <TextBlock Text="Quantity" Foreground="#AAB4C0"/>
                                            <NumericUpDown Value="{Binding SelectedArtTileDataEntry.Quantity, Mode=TwoWay}"
                                                           Minimum="0"
                                                           Maximum="255"
                                                           Increment="1"
                                                           FormatString="0"
                                                           LostFocus="ArtTileDataEditField_LostFocus"/>

                                            <TextBlock Text="Hue" Foreground="#AAB4C0"/>
                                            <NumericUpDown Value="{Binding SelectedArtTileDataEntry.Hue, Mode=TwoWay}"
                                                           Minimum="0"
                                                           Maximum="255"
                                                           Increment="1"
                                                           FormatString="0"
                                                           LostFocus="ArtTileDataEditField_LostFocus"/>

                                            <TextBlock Text="Stack Offset" Foreground="#AAB4C0"/>
                                            <NumericUpDown Value="{Binding SelectedArtTileDataEntry.StackingOffset, Mode=TwoWay}"
                                                           Minimum="0"
                                                           Maximum="255"
                                                           Increment="1"
                                                           FormatString="0"
                                                           LostFocus="ArtTileDataEditField_LostFocus"/>

                                            <TextBlock Text="Value" Foreground="#AAB4C0"/>
                                            <NumericUpDown Value="{Binding SelectedArtTileDataEntry.Value, Mode=TwoWay}"
                                                           Minimum="0"
                                                           Maximum="255"
                                                           Increment="1"
                                                           FormatString="0"
                                                           LostFocus="ArtTileDataEditField_LostFocus"/>

                                            <TextBlock Text="Height" Foreground="#AAB4C0"/>
                                            <NumericUpDown Value="{Binding SelectedArtTileDataEntry.Height, Mode=TwoWay}"
                                                           Minimum="0"
                                                           Maximum="255"
                                                           Increment="1"
                                                           FormatString="0"
                                                           LostFocus="ArtTileDataEditField_LostFocus"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Expander Header="Image Tools"
                                              IsExpanded="{Binding ShowArtImageTools}">
                                        <StackPanel Spacing="8"
                                                    Margin="0,8,0,0">

                                            <TextBlock Text="Enhance"
                                                       FontWeight="Bold"
                                                       Foreground="#E4EAF2"/>

                                            <TextBlock Text="{Binding ArtBrightness, StringFormat='Brightness: {0:0}'}"/>
                                            <Slider Minimum="-80"
                                                    Maximum="80"
                                                    Value="{Binding ArtBrightness}"/>

                                            <TextBlock Text="{Binding ArtContrast, StringFormat='Contrast: {0:0}'}"/>
                                            <Slider Minimum="-80"
                                                    Maximum="80"
                                                    Value="{Binding ArtContrast}"/>

                                            <TextBlock Text="{Binding ArtSharpness, StringFormat='Sharpness: {0:0}'}"/>
                                            <Slider Minimum="0"
                                                    Maximum="100"
                                                    Value="{Binding ArtSharpness}"/>

                                            <ComboBox Width="110"
                                                      ItemsSource="{Binding ArtSharpenModes}"
                                                      SelectedItem="{Binding SelectedArtSharpenMode}"/>

                                            <Button Content="Apply Enhancement"
                                                    Command="{Binding ApplyArtEnhancementCommand}"/>

                                            <Border Height="1"
                                                    Background="#343B46"
                                                    Margin="0,4"/>

                                            <TextBlock Text="Overlay"
                                                       FontWeight="Bold"
                                                       Foreground="#E4EAF2"/>

                                            <Button Content="Load Overlay Image"
                                                    Command="{Binding LoadArtOverlayImageCommand}"/>

                                            <TextBlock Text="{Binding ArtOverlayOpacity, StringFormat='Opacity: {0:0}%'}"/>
                                            <Slider Minimum="0"
                                                    Maximum="100"
                                                    Value="{Binding ArtOverlayOpacity}"/>

                                            <ComboBox ItemsSource="{Binding ArtOverlayBlendModes}"
                                                      SelectedItem="{Binding SelectedArtOverlayBlendMode}"/>

                                            <Button Content="Apply Overlay To Art"
                                                    Command="{Binding ApplyArtOverlayCommand}"/>

                                            <Border Height="1"
                                                    Background="#343B46"
                                                    Margin="0,4"/>

                                            <Button Content="Queue Art Edit"
                                                    Command="{Binding QueueSelectedArtEditCommand}"/>

                                            <Button Content="Reset Edit"
                                                    Command="{Binding ResetArtEditCommand}"/>
                                        </StackPanel>
                                    </Expander>

                                    <CheckBox Content="Show UO tile base"
                                              IsChecked="{Binding ShowArtTileBaseOverlay}"
                                              Foreground="#C7D1DB"
                                              Margin="0,6,0,0"/>

                                    <Border Height="1"
                                            Background="#343B46"
                                            Margin="0,8,0,4"/>

                                    <StackPanel Spacing="4"
                                                IsVisible="{Binding ShowSelectedArtEquipmentGump}">
                                        <TextBlock Text="Equipment Gump"
                                                   FontWeight="Bold"
                                                   Foreground="#E4EAF2" />

                                        <TextBlock Text="{Binding SelectedArtMaleEquipmentGumpText}"
                                                   Foreground="#AAB4C0"
                                                   TextWrapping="Wrap" />

                                        <Border Background="#151A20"
                                                BorderBrush="#343B46"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="8"
                                                HorizontalAlignment="Left">
                                            <Image Source="{Binding SelectedArtMaleEquipmentGumpBitmap}"
                                                   Stretch="None"
                                                   RenderOptions.BitmapInterpolationMode="None" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- RadarCol Tab -->
                <Grid IsVisible="{Binding ShowRadarColPanel}"
                      ColumnDefinitions="320,*,320"
                      ColumnSpacing="8"
                      Margin="8">

                    <!-- LEFT: list and filters -->
                    <Border Grid.Column="0"
                            Background="#20262E"
                            BorderBrush="#343B46"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8">

                        <Grid RowDefinitions="Auto,Auto,*"
                              RowSpacing="8">

                            <WrapPanel Grid.Row="0">
                                <Button Content="Load"
                                        Command="{Binding LoadRadarColCommand}"
                                        MinWidth="70"
                                        Margin="0,0,6,6"/>

                                <Button Content="Reload"
                                        Command="{Binding RebuildRadarColEntriesCommand}"
                                        MinWidth="70"
                                        Margin="0,0,6,6"/>

                                <Button Content="Save"
                                        Command="{Binding SaveRadarColCommand}"
                                        MinWidth="70"
                                        Margin="0,0,6,6"/>
                            </WrapPanel>

                            <StackPanel Grid.Row="1"
                                        Spacing="8">

                                <TextBox Watermark="Search ID..."
                                         Text="{Binding RadarColSearchText, Mode=TwoWay}"/>

                                <WrapPanel>
                                    <CheckBox Content="Land"
                                              IsChecked="{Binding ShowRadarColLand}"
                                              Margin="0,0,10,0"/>

                                    <CheckBox Content="Statics"
                                              IsChecked="{Binding ShowRadarColStatics}"
                                              Margin="0,0,10,0"/>

                                    <CheckBox Content="Different Only"
                                              IsChecked="{Binding ShowRadarColDifferentOnly}"/>
                                </WrapPanel>
                            </StackPanel>

                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding RadarColEntries}"
                                     SelectedItem="{Binding SelectedRadarColEntry, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0">

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="28,48,*"
                                              ColumnSpacing="8"
                                              Margin="2,4">

                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsChecked}"
                                                      VerticalAlignment="Center"/>

                                            <Border Grid.Column="1"
                                                    Width="42"
                                                    Height="42"
                                                    Background="#151A20"
                                                    BorderBrush="#343B46"
                                                    BorderThickness="1">
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapInterpolationMode="None"/>
                                            </Border>

                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding IdText}"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding TypeText}"
                                                           Foreground="#AAB4C0"
                                                           FontSize="12"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- MIDDLE: selected preview and color comparison -->
                    <Border Grid.Column="1"
                            Background="#20262E"
                            BorderBrush="#343B46"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">

                        <Grid RowDefinitions="Auto,*,Auto"
                              RowSpacing="12">

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="{Binding SelectedRadarColEntry.IdText}"
                                           Foreground="#E4EAF2"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>

                                <TextBlock Text="{Binding SelectedRadarColEntry.TypeText}"
                                           Foreground="#AAB4C0"/>
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Background="#151A20"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="20">

                                <Image Source="{Binding SelectedRadarColEntry.Thumbnail}"
                                       Stretch="None"
                                       RenderOptions.BitmapInterpolationMode="None"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>

                            <Grid Grid.Row="2"
                                  ColumnDefinitions="*,*,*"
                                  ColumnSpacing="10">

                                <Border Grid.Column="0"
                                        Background="#151A20"
                                        BorderBrush="#343B46"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Current"
                                                   FontWeight="SemiBold"/>
                                        <Border Height="34"
                                                Background="{Binding SelectedRadarColEntry.CurrentColorBrush}"
                                                BorderBrush="#566273"
                                                BorderThickness="1"/>
                                        <TextBlock Text="{Binding SelectedRadarColEntry.CurrentColorText}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Background="#151A20"
                                        BorderBrush="#343B46"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Generated"
                                                   FontWeight="SemiBold"/>
                                        <Border Height="34"
                                                Background="{Binding SelectedRadarColEntry.GeneratedColorBrush}"
                                                BorderBrush="#566273"
                                                BorderThickness="1"/>
                                        <TextBlock Text="{Binding SelectedRadarColEntry.GeneratedColorText}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Background="#151A20"
                                        BorderBrush="#343B46"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Match"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SelectedRadarColEntry.MatchText}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- RIGHT: tools -->
                    <Border Grid.Column="2"
                            Background="#20262E"
                            BorderBrush="#343B46"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10">

                        <StackPanel Spacing="12">

                            <TextBlock Text="RadarCol Tools"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>

                            <Border Background="#151A20"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Generated Color"
                                               FontWeight="SemiBold"/>

                                    <Border Background="#151A20"
                                            BorderBrush="#343B46"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Average Checked Tiles"
                                                       FontWeight="SemiBold"/>

                                            <Button Content="Average to Selected"
                                                    Command="{Binding ApplyCheckedAverageRadarColToSelectedCommand}"/>

                                            <Button Content="Average to Checked"
                                                    Command="{Binding ApplyCheckedAverageRadarColToCheckedCommand}"/>
                                        </StackPanel>
                                    </Border>

                                    <Button Content="Apply to Selected"
                                            Command="{Binding ApplyGeneratedRadarColToSelectedCommand}"/>

                                    <Button Content="Apply to Checked"
                                            Command="{Binding ApplyGeneratedRadarColToCheckedCommand}"/>

                                    <Button Content="Revert Selected"
                                            Command="{Binding RevertSelectedRadarColCommand}"/>

                                    <Button Content="Revert All"
                                            Command="{Binding RevertAllRadarColCommand}"/>
                                </StackPanel>

                            </Border>

                            <Border Background="#151A20"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Manual RGB"
                                               FontWeight="SemiBold"/>

                                    <Grid ColumnDefinitions="Auto,*"
                                          RowDefinitions="Auto,Auto,Auto"
                                          ColumnSpacing="8"
                                          RowSpacing="6">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="R" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="0" Grid.Column="1"
                                                       Minimum="0" Maximum="255"
                                                       Increment="1" FormatString="0"
                                                       Value="{Binding RadarColRed, Mode=TwoWay}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="G" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="1" Grid.Column="1"
                                                       Minimum="0" Maximum="255"
                                                       Increment="1" FormatString="0"
                                                       Value="{Binding RadarColGreen, Mode=TwoWay}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="B" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                                       Minimum="0" Maximum="255"
                                                       Increment="1" FormatString="0"
                                                       Value="{Binding RadarColBlue, Mode=TwoWay}"/>
                                    </Grid>

                                    <Button Content="Apply RGB to Selected"
                                            Command="{Binding ApplyManualRadarColToSelectedCommand}"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#151A20"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Range Apply"
                                               FontWeight="SemiBold"/>

                                    <Grid ColumnDefinitions="*,Auto,*"
                                          ColumnSpacing="6">
                                        <NumericUpDown Grid.Column="0"
                                                       Minimum="0"
                                                       Maximum="16383"
                                                       Increment="1"
                                                       FormatString="0"
                                                       Value="{Binding RadarColRangeFrom, Mode=TwoWay}"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="to"
                                                   VerticalAlignment="Center"/>

                                        <NumericUpDown Grid.Column="2"
                                                       Minimum="0"
                                                       Maximum="16383"
                                                       Increment="1"
                                                       FormatString="0"
                                                       Value="{Binding RadarColRangeTo, Mode=TwoWay}"/>
                                    </Grid>

                                    <Button Content="Apply Generated to Range"
                                            Command="{Binding ApplyGeneratedRadarColToRangeCommand}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Multis Tab -->
                <Grid Grid.Column="0"
                      Grid.ColumnSpan="2"
                      IsVisible="{Binding ShowMultisPanel}"
                      RowDefinitions="Auto,*"
                      Background="#151A20"
                      Margin="-260,0,0,0">

                    <!-- Main toolbar -->
                    <Border Grid.Row="0"
                            Background="#1B222B"
                            BorderBrush="#343B46"
                            BorderThickness="0,0,0,1"
                            Padding="8">

                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">

                            <Button Content="Load Multis"
                                    Command="{Binding LoadMultisCommand}"/>

                            <Button Content="Save Multis"
                                    Command="{Binding SaveMultisCommand}"/>

                            <Button Content="Open Editor"
                                    Command="{Binding OpenMultiEditorCommand}"/>

                            <Button Content="Free Slots"
                                    Command="{Binding ToggleMultiFreeSlotsCommand}"/>

                            <SplitButton Content="Export">
                                <SplitButton.Flyout>
                                    <MenuFlyout>
                                        <MenuItem Header="Export UOX3"
                                                  Command="{Binding ExportSelectedMultiUox3Command}"/>
                                        <MenuItem Header="Export PNG"
                                                  Command="{Binding ExportSelectedMultiPngCommand}"/>
                                        <MenuItem Header="Export TXT"
                                                  Command="{Binding ExportSelectedMultiTxtCommand}"/>
                                        <MenuItem Header="Export CSV"
                                                  Command="{Binding ExportSelectedMultiCsvCommand}"/>
                                    </MenuFlyout>
                                </SplitButton.Flyout>
                            </SplitButton>

                            <Button Content="Import"
                                    Command="{Binding ImportSelectedMultiCommand}"/>

                            <Separator Width="1"/>

                            <TextBlock Text="Source"
                                       VerticalAlignment="Center"
                                       Foreground="#C7D1DB"/>

                            <ComboBox Width="180"
                                      ItemsSource="{Binding MultiSourceOptions}"
                                      SelectedItem="{Binding SelectedMultiSource}"/>

                            <CheckBox Content="UOHSA 16-byte format"
                                      IsChecked="{Binding UseUohsaMultiFormat}"
                                      VerticalAlignment="Center"
                                      IsEnabled="{Binding SelectedMultiSource, Converter={StaticResource IsMulMultiSourceConverter}}"/>

                            <TextBlock Text="Height Cut"
                                       VerticalAlignment="Center"
                                       Foreground="#C7D1DB"/>

                            <Slider Width="240"
                                    Minimum="-128"
                                    Maximum="127"
                                    Value="{Binding MultiHeightCut, Mode=TwoWay}"/>

                            <TextBlock Text="{Binding MultiHeightCut}"
                                       Width="40"
                                       VerticalAlignment="Center"
                                       Foreground="#C7D1DB"/>

                            <ComboBox Width="160"
                                      ItemsSource="{Binding MultiPreviewModes}"
                                      SelectedItem="{Binding SelectedMultiPreviewMode}"/>

                            <TextBlock Text="{Binding MultiStatusText}"
                                       MinWidth="260"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="#AEB8C2"/>
                        </StackPanel>
                    </Border>

                    <!-- Full tab body -->
                    <Grid Grid.Row="1"
                          ColumnDefinitions="320,*,380"
                          Background="#0F141A">

                        <!-- Left list -->
                        <Border Grid.Column="0"
                                Background="#151A20"
                                BorderBrush="#2D3440"
                                BorderThickness="0,0,1,0"
                                Padding="8">

                            <Grid RowDefinitions="Auto,Auto,*"
                                  RowSpacing="8">

                                <Grid Grid.Row="0"
                                      ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8">

                                    <TextBlock Grid.Column="0"
                                               Text="Multis"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Foreground="#E8EDF2"/>

                                    <ComboBox Grid.Column="1"
                                              Width="115"
                                              HorizontalAlignment="Right"
                                              ItemsSource="{Binding MultiFilterOptions}"
                                              SelectedItem="{Binding SelectedMultiFilter}"/>
                                </Grid>

                                <TextBox Grid.Row="1"
                                         Watermark="Search ID / hex"
                                         Text="{Binding MultiSearchText, Mode=TwoWay}"/>

                                <ListBox Grid.Row="2"
                                         ItemsSource="{Binding MultiEntries}"
                                         SelectedItem="{Binding SelectedMulti}"
                                         Background="#1B222B">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayText}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="#E8EDF2"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- Center preview -->
                        <Border Grid.Column="1"
                                Background="#0B0F14"
                                Padding="8">

                            <Grid RowDefinitions="Auto,*"
                                  RowSpacing="8">

                                <TextBlock Text="Preview"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="#E8EDF2"/>

                                <Border Grid.Row="1"
                                        Background="#080B0F"
                                        BorderBrush="#2D3440"
                                        BorderThickness="1">

                                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">

                                        <Image Source="{Binding SelectedMultiPreview}"
                                               Stretch="None"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Right components -->
                        <Border Grid.Column="2"
                                Background="#151A20"
                                BorderBrush="#2D3440"
                                BorderThickness="1,0,0,0"
                                Padding="8">

                            <Grid RowDefinitions="Auto,*"
                                  RowSpacing="8">

                                <TextBlock Text="Components"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="#E8EDF2"/>

                                <TextBox Grid.Row="1"
                                         Text="{Binding SelectedMultiComponentsText}"
                                         AcceptsReturn="True"
                                         IsReadOnly="True"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         TextWrapping="NoWrap"
                                         Background="#0F141A"
                                         Foreground="#E8EDF2"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- AnimData Tab -->
                <Grid Grid.Column="0"
                      Grid.ColumnSpan="2"
                      IsVisible="{Binding ShowAnimDataPanel}"
                      Margin="-294,0,0,0"
                      RowDefinitions="Auto,*">

                    <Border Grid.Row="0"
                            Background="#1E232A"
                            BorderBrush="#343B46"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Button Content="Load AnimData"
                                    Command="{Binding LoadAnimDataTabCommand}" />

                            <Button Content="Save AnimData"
                                    Command="{Binding SaveAnimDataCommand}" />

                            <Button Content="Export"
                                    Command="{Binding ExportAnimDataCommand}" />

                            <Button Content="Import"
                                    Command="{Binding ImportAnimDataCommand}" />

                            <Button Content="Check All"
                                    Command="{Binding CheckAllAnimDataCommand}" />

                            <Button Content="Uncheck All"
                                    Command="{Binding UncheckAllAnimDataCommand}" />

                            <TextBlock Text="{Binding AnimDataStatusText}"
                                       VerticalAlignment="Center"
                                       Foreground="#C7D1DB" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="380,*,330"
                          ColumnSpacing="10"
                          Margin="10">

                        <!-- Left: Filters + AnimData List -->
                        <Grid Grid.Column="0"
                              RowDefinitions="Auto,*"
                              RowSpacing="8">

                            <Border Grid.Row="0"
                                    Background="#20262E"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <StackPanel Spacing="6">
                                    <TextBox Watermark="Search ID / hex / name..."
                                             Text="{Binding AnimDataSearchText}" />

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="12">
                                        <CheckBox Content="Missing Art"
                                                  IsChecked="{Binding ShowAnimDataMissingArt}" />

                                        <CheckBox Content="No Anim Flag"
                                                  IsChecked="{Binding ShowAnimDataWithoutAnimationFlag}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Background="#20262E"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ListBox ItemsSource="{Binding AnimDataEntries}"
                                         SelectedItem="{Binding SelectedAnimDataEntry}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="8"
                                                  Margin="6">
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsChecked}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,6,0" />

                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayText}"
                                                               FontWeight="SemiBold"
                                                               Foreground="#E4EAF2" />

                                                    <TextBlock Text="{Binding SecondaryText}"
                                                               FontSize="12"
                                                               Foreground="#AAB4C0"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Grid>

                        <!-- Middle: Base + selected frame preview -->
                        <Grid Grid.Column="1"
                              RowDefinitions="*,Auto,*"
                              RowSpacing="10">

                            <Border Grid.Row="0"
                                    Background="#20262E"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12">
                                <Grid RowDefinitions="Auto,*">
                                    <TextBlock Grid.Row="0"
                                               Text="Base Graphic"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2"
                                               Margin="0,0,0,8" />

                                    <ScrollViewer Grid.Row="1"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                        <Image Source="{Binding SelectedAnimDataBaseBitmap}"
                                               Stretch="None"
                                               RenderOptions.BitmapInterpolationMode="None"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1"
                                    Height="1"
                                    Background="#343B46" />

                            <Border Grid.Row="2"
                                    Background="#20262E"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12">
                                <Grid RowDefinitions="Auto,*">
                                    <TextBlock Grid.Row="0"
                                               Text="Selected Frame Graphic"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2"
                                               Margin="0,0,0,8" />

                                    <ScrollViewer Grid.Row="1"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                        <Image Source="{Binding SelectedAnimDataFrameBitmap}"
                                               Stretch="None"
                                               RenderOptions.BitmapInterpolationMode="None"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Right: frame list + info -->
                        <Border Grid.Column="2"
                                Background="#20262E"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10">
                            <Grid RowDefinitions="Auto,170,Auto,Auto,*"
                                  RowSpacing="8">

                                <StackPanel Grid.Row="0"
                                            Spacing="4">
                                    <TextBlock Text="AnimData Info"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2" />

                                    <TextBlock Text="{Binding SelectedAnimDataEntry.DisplayText}"
                                               Foreground="#C7D1DB"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="{Binding SelectedAnimDataEntry.SecondaryText}"
                                               Foreground="#AAB4C0"
                                               FontSize="12"
                                               TextWrapping="Wrap" />

                                    <Grid ColumnDefinitions="*,*"
                                          RowDefinitions="Auto,Auto,Auto,Auto"
                                          ColumnSpacing="8"
                                          RowSpacing="6"
                                          Margin="0,8,0,0">
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Unknown"
                                                   Foreground="#AAB4C0" />

                                        <NumericUpDown Grid.Row="0"
                                                       Grid.Column="1"
                                                       Minimum="0"
                                                       Maximum="255"
                                                       Value="{Binding SelectedAnimDataEntry.Unknown}" />

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="Frame Count"
                                                   Foreground="#AAB4C0" />

                                        <NumericUpDown Grid.Row="1"
                                                       Grid.Column="1"
                                                       Minimum="0"
                                                       Maximum="64"
                                                       Value="{Binding SelectedAnimDataEntry.FrameCount}" />

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Text="Frame Interval"
                                                   Foreground="#AAB4C0" />

                                        <NumericUpDown Grid.Row="2"
                                                       Grid.Column="1"
                                                       Minimum="0"
                                                       Maximum="255"
                                                       Value="{Binding SelectedAnimDataEntry.FrameInterval}" />

                                        <TextBlock Grid.Row="3"
                                                   Grid.Column="0"
                                                   Text="Frame Start"
                                                   Foreground="#AAB4C0" />

                                        <NumericUpDown Grid.Row="3"
                                                       Grid.Column="1"
                                                       Minimum="0"
                                                       Maximum="255"
                                                       Value="{Binding SelectedAnimDataEntry.FrameStart}" />
                                    </Grid>
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Background="#151A20"
                                        BorderBrush="#343B46"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <ListBox ItemsSource="{Binding SelectedAnimDataEntry.Frames}"
                                             SelectedItem="{Binding SelectedAnimDataFrame}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="6,4">
                                                    <TextBlock Text="{Binding DisplayText}"
                                                               Foreground="#E4EAF2" />
                                                    <TextBlock Text="{Binding StatusText}"
                                                               FontSize="11"
                                                               Foreground="#AAB4C0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>

                                <Grid Grid.Row="2"
                                      RowDefinitions="Auto,Auto"
                                      RowSpacing="5"
                                      Margin="0,2,0,4">

                                    <Grid Grid.Row="0"
                                          ColumnDefinitions="90,Auto,58,78"
                                          ColumnSpacing="6">
                                        <TextBox Grid.Column="0"
                                                 Watermark="0x091E"
                                                 Text="{Binding AnimDataAddFrameGraphicText}" />

                                        <CheckBox Grid.Column="1"
                                                  Content="Rel"
                                                  IsChecked="{Binding AnimDataAddFrameRelative}"
                                                  VerticalAlignment="Center" />

                                        <Button Grid.Column="2"
                                                Content="Add"
                                                Command="{Binding AddAnimDataFrameCommand}" />

                                        <Button Grid.Column="3"
                                                Content="Remove"
                                                Command="{Binding RemoveAnimDataFrameCommand}" />
                                    </Grid>

                                    <Grid Grid.Row="1"
                                          ColumnDefinitions="*,*,*"
                                          ColumnSpacing="6">
                                        <Button Grid.Column="0"
                                                Content="Move Up"
                                                Command="{Binding MoveAnimDataFrameUpCommand}" />

                                        <Button Grid.Column="1"
                                                Content="Move Down"
                                                Command="{Binding MoveAnimDataFrameDownCommand}" />

                                        <Button Grid.Column="2"
                                                Content="Play"
                                                Command="{Binding ToggleAnimDataAnimationCommand}" />
                                    </Grid>
                                </Grid>

                                <Border Grid.Row="3"
                                        Height="1"
                                        Background="#343B46"
                                        Margin="0,4" />

                                <ScrollViewer Grid.Row="4"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel Spacing="12">

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Base TileData"
                                                       FontWeight="Bold"
                                                       Foreground="#E4EAF2" />

                                            <TextBlock Text="{Binding SelectedAnimDataTileDataEntry.DisplayText}"
                                                       Foreground="#C7D1DB"
                                                       TextWrapping="Wrap" />

                                            <TextBlock Text="{Binding SelectedAnimDataTileDataEntry.Flags, StringFormat='Flags: 0x{0:X16}'}"
                                                       Foreground="#AAB4C0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Frame TileData"
                                                       FontWeight="Bold"
                                                       Foreground="#E4EAF2" />

                                            <TextBlock Text="{Binding SelectedAnimDataFrameTileDataEntry.DisplayText}"
                                                       Foreground="#C7D1DB"
                                                       TextWrapping="Wrap" />

                                            <TextBlock Text="{Binding SelectedAnimDataFrameTileDataEntry.Flags, StringFormat='Flags: 0x{0:X16}'}"
                                                       Foreground="#AAB4C0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Wearable Editor -->
                <Grid Grid.Column="0"
                      Grid.ColumnSpan="3"
                      IsVisible="{Binding ShowWearableWizardPanel}"
                      RowDefinitions="Auto,*"
                      Margin="-270,10,10,10"
                      RowSpacing="10"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">

                    <TextBlock Grid.Row="0"
                               Text="Wearable Creation Wizard"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#E4EAF2"/>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="410,*,520"
                          ColumnSpacing="12"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">

                        <!-- LEFT: Setup -->
                        <Border Grid.Column="0"
                                Background="#20242B"
                                BorderBrush="#303844"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">

                            <ScrollViewer>
                                <StackPanel Spacing="8">

                                    <TextBlock Text="Basic Info" FontWeight="Bold" Foreground="#E4EAF2"/>

                                    <TextBlock Text="Name" Foreground="#AAB4C0"/>
                                    <TextBox Text="{Binding WearableWizardName, Mode=TwoWay}"/>

                                    <TextBlock Text="Wearable Type" Foreground="#AAB4C0"/>
                                    <ComboBox ItemsSource="{Binding WearableWizardTypes}"
                                              SelectedItem="{Binding WearableWizardType, Mode=TwoWay}"/>

                                    <TextBlock Text="Layer" Foreground="#AAB4C0"/>
                                    <ComboBox ItemsSource="{Binding WearableWizardLayers}"
                                              SelectedItem="{Binding WearableWizardLayer, Mode=TwoWay}"/>

                                    <Separator Margin="0,8,0,8"/>

                                    <TextBlock Text="Images" FontWeight="Bold" Foreground="#E4EAF2"/>

                                    <Button Content="Load Male / Default Paperdoll Image"
                                            Command="{Binding BrowseWearablePaperdollImageCommand}"/>
                                    <TextBlock Text="{Binding WearableWizardPaperdollImagePath}"
                                               Foreground="#AAB4C0"
                                               TextWrapping="Wrap"
                                               MaxHeight="40"/>

                                    <CheckBox Content="Create female variant"
                                              IsChecked="{Binding WearableWizardCreateFemaleVariant, Mode=TwoWay}"/>

                                    <Button Content="Load Female Paperdoll Image"
                                            Command="{Binding BrowseWearableFemalePaperdollImageCommand}"/>
                                    <TextBlock Text="{Binding WearableWizardFemalePaperdollImagePath}"
                                               Foreground="#AAB4C0"
                                               TextWrapping="Wrap"
                                               MaxHeight="40"/>

                                    <Button Content="Load Inventory / World Art Image"
                                            Command="{Binding BrowseWearableArtImageCommand}"/>
                                    <TextBlock Text="{Binding WearableWizardArtImagePath}"
                                               Foreground="#AAB4C0"
                                               TextWrapping="Wrap"
                                               MaxHeight="40"/>

                                    <Separator Margin="0,8,0,8"/>

                                    <TextBlock Text="Slot Planning" FontWeight="Bold" Foreground="#E4EAF2"/>

                                    <Border Background="#3A2020"
                                            BorderBrush="#AA5555"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8"
                                            IsVisible="{Binding WearableWizardMaleGumpConflict}">
                                        <TextBlock Text="{Binding WearableWizardConflictText}"
                                                   Foreground="#FFB0B0"
                                                   TextWrapping="Wrap"/>
                                    </Border>

                                    <CheckBox Content="Use sitting-safe wearable range 50400-50999"
                                              IsChecked="{Binding WearableWizardUseSittingSafeRange, Mode=TwoWay}"/>

                                    <CheckBox Content="Partial hueable"
                                              IsChecked="{Binding WearableWizardPartialHue, Mode=TwoWay}"/>

                                    <Button Content="Auto Pick Free IDs"
                                            Command="{Binding AutoPickWearableWizardIdsCommand}"/>

                                    <Grid ColumnDefinitions="*,*"
                                          RowDefinitions="Auto,Auto,Auto,Auto"
                                          ColumnSpacing="8"
                                          RowSpacing="6">

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Male Gump ID" Foreground="#AAB4C0"/>
                                        <NumericUpDown Grid.Row="0" Grid.Column="1"
                                                       Value="{Binding WearableWizardMaleGumpId, Mode=TwoWay}"
                                                       Minimum="50000"
                                                       Maximum="50999"
                                                       Increment="1"
                                                       FormatString="0"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Female Gump ID" Foreground="#AAB4C0"/>
                                        <NumericUpDown Grid.Row="1" Grid.Column="1"
                                                       Value="{Binding WearableWizardFemaleGumpId, Mode=TwoWay}"
                                                       Minimum="60000"
                                                       Maximum="60999"
                                                       Increment="1"
                                                       FormatString="0"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Art ID" Foreground="#AAB4C0"/>
                                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                                       Value="{Binding WearableWizardArtId, Mode=TwoWay}"
                                                       Minimum="50000"
                                                       Maximum="50999"
                                                       Increment="1"
                                                       FormatString="0"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Animation ID" Foreground="#AAB4C0"/>
                                        <NumericUpDown Grid.Row="3" Grid.Column="1"
                                                       Value="{Binding WearableWizardAnimationId, Mode=TwoWay}"
                                                       Minimum="0"
                                                       Maximum="9999"
                                                       Increment="1"
                                                       FormatString="0"/>
                                    </Grid>

                                    <Separator Margin="0,8,0,8"/>

                                    <TextBlock Text="Animation Attachment" FontWeight="Bold" Foreground="#E4EAF2"/>

                                    <ComboBox ItemsSource="{Binding WearableWizardAnimationModes}"
                                              SelectedItem="{Binding WearableWizardAnimationMode, Mode=TwoWay}"/>

                                    <TextBlock Text="Existing Animation ID" Foreground="#AAB4C0"/>
                                    <NumericUpDown Value="{Binding WearableWizardExistingAnimationId, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="9999"
                                                   Increment="1"
                                                   FormatString="0"/>

                                    <TextBlock Text="Body.def Hue" Foreground="#AAB4C0"/>
                                    <TextBox Text="{Binding WearableWizardHue, Mode=TwoWay}"/>

                                    <Separator Margin="0,8,0,8"/>

                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                        <Button Grid.Column="0" Content="Rebuild" Command="{Binding RebuildWearableWizardPlanCommand}"/>
                                        <Button Grid.Column="1" Content="Reset" Command="{Binding ResetWearableWizardCommand}"/>
                                        <Button Grid.Column="2" Content="Apply" Command="{Binding ApplyWearableWizardCommand}"/>
                                    </Grid>

                                    <TextBlock Text="{Binding WearableWizardStatusText}"
                                               Foreground="#AAB4C0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- CENTER: Big Preview -->
                        <Border Grid.Column="1"
                                Background="#20242B"
                                BorderBrush="#303844"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">

                            <Grid RowDefinitions="150,*"
                                  RowSpacing="10">

                                <!-- Image previews -->
                                <Border Grid.Row="0"
                                        Background="#15191F"
                                        BorderBrush="#303844"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8">

                                    <Grid RowDefinitions="Auto,*" RowSpacing="6">
                                        <TextBlock Grid.Row="0"
                                                   Text="Image Previews"
                                                   FontWeight="Bold"
                                                   Foreground="#E4EAF2"/>

                                        <Grid Grid.Row="1"
                                              ColumnDefinitions="*,*,*"
                                              ColumnSpacing="8">

                                            <Border Grid.Column="0" Background="#101318" BorderBrush="#303844" BorderThickness="1" CornerRadius="4" Padding="6">
                                                <StackPanel>
                                                    <TextBlock Text="Male" HorizontalAlignment="Center" Foreground="#AAB4C0"/>
                                                    <Image Source="{Binding WearableWizardPaperdollPreview}" Stretch="Uniform" MaxHeight="95"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1" Background="#101318" BorderBrush="#303844" BorderThickness="1" CornerRadius="4" Padding="6">
                                                <StackPanel>
                                                    <TextBlock Text="Female" HorizontalAlignment="Center" Foreground="#AAB4C0"/>
                                                    <Image Source="{Binding WearableWizardFemalePaperdollPreview}" Stretch="Uniform" MaxHeight="95"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2" Background="#101318" BorderBrush="#303844" BorderThickness="1" CornerRadius="4" Padding="6">
                                                <StackPanel>
                                                    <TextBlock Text="Art" HorizontalAlignment="Center" Foreground="#AAB4C0"/>
                                                    <Image Source="{Binding WearableWizardArtPreview}" Stretch="Uniform" MaxHeight="95"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- Animation preview -->
                                <Border Grid.Row="1"
                                        Background="#15191F"
                                        BorderBrush="#303844"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8">

                                    <Grid RowDefinitions="Auto,Auto,*,Auto"
                                          RowSpacing="8">

                                        <Grid Grid.Row="0"
                                              ColumnDefinitions="*,Auto"
                                              ColumnSpacing="8">

                                            <TextBlock Grid.Column="0"
                                                       Text="Wearable Animation Overlay Preview"
                                                       FontWeight="Bold"
                                                       Foreground="#E4EAF2"/>

                                            <CheckBox Grid.Column="1"
                                                      Content="Enabled"
                                                      IsChecked="{Binding WearableWizardOverlayPreviewEnabled, Mode=TwoWay}"/>
                                        </Grid>

                                        <StackPanel Grid.Row="1"
                                                    Spacing="6">

                                            <Grid ColumnDefinitions="Auto,110,Auto,110,Auto,110"
                                                  ColumnSpacing="8">

                                                <TextBlock Grid.Column="0"
                                                           Text="Base"
                                                           VerticalAlignment="Center"
                                                           Foreground="#AAB4C0"/>
                                                <NumericUpDown Grid.Column="1"
                                                               Width="110"
                                                               Value="{Binding WearableWizardPreviewBaseBodyId, Mode=TwoWay}"
                                                               Minimum="0"
                                                               Maximum="9999"
                                                               Increment="1"
                                                               FormatString="0"/>

                                                <TextBlock Grid.Column="2"
                                                           Text="Action"
                                                           VerticalAlignment="Center"
                                                           Foreground="#AAB4C0"/>
                                                <NumericUpDown Grid.Column="3"
                                                               Width="110"
                                                               Value="{Binding WearableWizardPreviewAction, Mode=TwoWay}"
                                                               Minimum="0"
                                                               Maximum="34"
                                                               Increment="1"
                                                               FormatString="0"/>

                                                <TextBlock Grid.Column="4"
                                                           Text="Dir"
                                                           VerticalAlignment="Center"
                                                           Foreground="#AAB4C0"/>
                                                <NumericUpDown Grid.Column="5"
                                                               Width="110"
                                                               Value="{Binding WearableWizardPreviewDirection, Mode=TwoWay}"
                                                               Minimum="0"
                                                               Maximum="4"
                                                               Increment="1"
                                                               FormatString="0"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="Auto,110,Auto,110,Auto,110,Auto,110"
                                                  ColumnSpacing="8">

                                                <TextBlock Grid.Column="0"
                                                           Text="Frame"
                                                           VerticalAlignment="Center"
                                                           Foreground="#AAB4C0"/>
                                                <NumericUpDown Grid.Column="1"
                                                               Width="110"
                                                               Value="{Binding WearableWizardPreviewFrameIndex, Mode=TwoWay}"
                                                               Minimum="0"
                                                               Maximum="99"
                                                               Increment="1"
                                                               FormatString="0"/>

                                                <TextBlock Grid.Column="2"
                                                           Text="X"
                                                           VerticalAlignment="Center"
                                                           Foreground="#AAB4C0"/>
                                                <NumericUpDown Grid.Column="3"
                                                               Width="110"
                                                               Value="{Binding WearableWizardOverlayOffsetX, Mode=TwoWay}"
                                                               Minimum="-500"
                                                               Maximum="500"
                                                               Increment="1"
                                                               FormatString="0"/>

                                                <TextBlock Grid.Column="4"
                                                           Text="Y"
                                                           VerticalAlignment="Center"
                                                           Foreground="#AAB4C0"/>
                                                <NumericUpDown Grid.Column="5"
                                                               Width="110"
                                                               Value="{Binding WearableWizardOverlayOffsetY, Mode=TwoWay}"
                                                               Minimum="-500"
                                                               Maximum="500"
                                                               Increment="1"
                                                               FormatString="0"/>

                                                <TextBlock Grid.Column="6"
                                                           Text="Scale"
                                                           VerticalAlignment="Center"
                                                           Foreground="#AAB4C0"/>
                                                <NumericUpDown Grid.Column="7"
                                                               Width="110"
                                                               Value="{Binding WearableWizardOverlayScale, Mode=TwoWay}"
                                                               Minimum="0.1"
                                                               Maximum="5"
                                                               Increment="0.1"
                                                               FormatString="0.0"/>
                                            </Grid>
                                        </StackPanel>

                                        <Border Grid.Row="2"
                                                Background="#101318"
                                                BorderBrush="#303844"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="6">

                                            <Image Source="{Binding WearableWizardOverlayPreviewBitmap}"
                                                   Stretch="Uniform"/>
                                        </Border>

                                        <Grid Grid.Row="3"
                                              ColumnDefinitions="*,Auto"
                                              ColumnSpacing="8">

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding WearableWizardOverlayPreviewStatus}"
                                                       Foreground="#AAB4C0"
                                                       TextWrapping="Wrap"/>

                                            <Button Grid.Column="1"
                                                    Content="Refresh Preview"
                                                    Command="{Binding RefreshWearableWizardOverlayPreviewCommand}"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- RIGHT: Plan + Browsers -->
                        <Grid Grid.Column="2"
                              RowDefinitions="260,*"
                              RowSpacing="10">

                            <Border Grid.Row="0"
                                    Background="#15191F"
                                    BorderBrush="#303844"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12">

                                <Grid RowDefinitions="Auto,*"
                                      RowSpacing="8">

                                    <TextBlock Grid.Row="0"
                                               Text="Planned Changes"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2"/>

                                    <TextBox Grid.Row="1"
                                             Text="{Binding WearableWizardPlanText}"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             FontFamily="Consolas"
                                             Background="#101318"
                                             Foreground="#DDE6F0"/>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1"
                                  RowDefinitions="*,*"
                                  RowSpacing="10">

                                <Border Grid.Row="0"
                                        Background="#15191F"
                                        BorderBrush="#303844"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8">

                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto"
                                          RowSpacing="6">

                                        <TextBlock Grid.Row="0"
                                                   Text="Free Animation Slot Browser"
                                                   FontWeight="Bold"
                                                   Foreground="#E4EAF2"/>

                                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <ComboBox Grid.Column="0"
                                                      ItemsSource="{Binding WearableWizardSlotFileOptions}"
                                                      SelectedItem="{Binding WearableWizardSelectedSlotFile, Mode=TwoWay}"/>

                                            <Button Grid.Column="1"
                                                    Content="Refresh"
                                                    Command="{Binding RefreshWearableWizardFreeSlotsCommand}"/>
                                        </Grid>

                                        <TextBox Grid.Row="2"
                                                 Watermark="Search body/file/type..."
                                                 Text="{Binding WearableWizardSlotSearchText, Mode=TwoWay}"/>

                                        <WrapPanel Grid.Row="3">
                                            <CheckBox Content="H (Monster)" Margin="0,0,12,0" IsChecked="{Binding WearableWizardSlotShowHFilter, Mode=TwoWay}"/>
                                            <CheckBox Content="L (Animal)" Margin="0,0,12,0" IsChecked="{Binding WearableWizardSlotShowLFilter, Mode=TwoWay}"/>
                                            <CheckBox Content="P (Human/Equip)" IsChecked="{Binding WearableWizardSlotShowPFilter, Mode=TwoWay}"/>
                                        </WrapPanel>

                                        <ListBox Grid.Row="4"
                                                 ItemsSource="{Binding WearableWizardFreeSlots}"
                                                 SelectedItem="{Binding WearableWizardSelectedFreeSlot, Mode=TwoWay}">

                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid ColumnDefinitions="45,70,*,70" ColumnSpacing="8" Margin="2">
                                                        <TextBlock Grid.Column="0" Text="{Binding TypeLetter}" Foreground="#E4EAF2" FontWeight="Bold"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding BodyIndex}" Foreground="#DDE6F0"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding FileName}" Foreground="#AAB4C0"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding TrueBodyId}" Foreground="#8FD18F"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <Button Grid.Row="5"
                                                Content="Use Selected Slot"
                                                HorizontalAlignment="Left"
                                                Command="{Binding UseWearableWizardSelectedSlotCommand}"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1"
                                        Background="#15191F"
                                        BorderBrush="#303844"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8">

                                    <Grid RowDefinitions="Auto,Auto,*,Auto"
                                          RowSpacing="6">

                                        <TextBlock Grid.Row="0"
                                                   Text="Existing Animation Source Browser"
                                                   FontWeight="Bold"
                                                   Foreground="#E4EAF2"/>

                                        <TextBox Grid.Row="1"
                                                 Watermark="Search P-slot animations..."
                                                 Text="{Binding WearableWizardSourceAnimationSearchText, Mode=TwoWay}"/>

                                        <ListBox Grid.Row="2"
                                                 ItemsSource="{Binding WearableWizardSourceAnimations}"
                                                 SelectedItem="{Binding WearableWizardSelectedSourceAnimation, Mode=TwoWay}">

                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid ColumnDefinitions="70,*,120" ColumnSpacing="8" Margin="2">
                                                        <TextBlock Grid.Column="0" Text="{Binding BodyId}" Foreground="#8FD18F" FontWeight="Bold"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="#DDE6F0"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding SourceFile}" Foreground="#AAB4C0"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <Button Grid.Row="3"
                                                Content="Use Selected Source Animation"
                                                HorizontalAlignment="Left"
                                                Command="{Binding UseWearableWizardSourceAnimationCommand}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- Normal Editor Preview -->
                <Grid Grid.Column="0"
                      RowDefinitions="Auto,*"
                      IsVisible="{Binding ShowAnimationEditorPanel}">
                    <TextBlock Grid.Row="0"
                               Text="Preview"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10" />

                    <Border Grid.Row="1"
                            Background="Transparent"
                            BorderThickness="0">
                        <Grid RowDefinitions="*,Auto,Auto">

                            <Grid Grid.Row="0">

                                <!-- Single full-width preview -->
                                <Border x:Name="PreviewDropBorder"
                                        Background="{Binding PreviewBackgroundBrush}"
                                        BorderBrush="#343B46"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12"
                                        PointerPressed="PreviewDragSurface_PointerPressed"
                                        PointerMoved="PreviewDragSurface_PointerMoved"
                                        PointerReleased="PreviewDragSurface_PointerReleased"
                                        PointerCaptureLost="PreviewDragSurface_PointerCaptureLost"
                                        DragDrop.AllowDrop="True"
                                        IsVisible="{Binding ShowSinglePreviewOnly}">
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                        <Grid HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              MinHeight="420">
                                            <Image Source="{Binding PreviewBitmap}"
                                                   Width="{Binding PreviewImageWidth}"
                                                   Height="{Binding PreviewImageHeight}"
                                                   Stretch="Fill" />
                                        </Grid>
                                    </ScrollViewer>
                                </Border>

                                <!-- Split preview -->
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="12"
                                      IsVisible="{Binding ShowSplitPreview}">

                                    <Border Grid.Column="0"
                                            Background="{Binding PreviewBackgroundBrush}"
                                            BorderBrush="#343B46"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12"
                                            PointerPressed="PreviewDragSurface_PointerPressed"
                                            PointerMoved="PreviewDragSurface_PointerMoved"
                                            PointerReleased="PreviewDragSurface_PointerReleased"
                                            PointerCaptureLost="PreviewDragSurface_PointerCaptureLost"
                                            DragDrop.AllowDrop="True">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto">
                                            <Grid HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  MinHeight="420">
                                                <Image Source="{Binding PreviewBitmap}"
                                                       Width="{Binding PreviewImageWidth}"
                                                       Height="{Binding PreviewImageHeight}"
                                                       Stretch="Fill" />
                                            </Grid>
                                        </ScrollViewer>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Background="{Binding PreviewBackgroundBrush}"
                                            BorderBrush="#343B46"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto">
                                            <Grid HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  MinHeight="420">
                                                <Image Source="{Binding CompareSidePreviewBitmap}"
                                                       Width="{Binding ComparePreviewImageWidth}"
                                                       Height="{Binding ComparePreviewImageHeight}"
                                                       Stretch="Fill" />
                                            </Grid>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Grid>

                            <Border Grid.Row="1"
                                    Margin="0,10,0,8"
                                    Background="#171C22"
                                    BorderBrush="#2D3641"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,8">

                                <Grid>
                                    <!-- Single info -->
                                    <StackPanel Spacing="4"
                                                HorizontalAlignment="Center"
                                                IsVisible="{Binding ShowSinglePreviewOnly}">
                                        <TextBlock Text="{Binding CurrentFrameDisplayText}"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#E3E8EE"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding PreviewInfoText}"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#C7D1DB"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="780" />
                                    </StackPanel>

                                    <!-- Split info -->
                                    <Grid ColumnDefinitions="*,*"
                                          ColumnSpacing="12"
                                          IsVisible="{Binding ShowSplitPreview}">
                                        <StackPanel Grid.Column="0"
                                                    Spacing="4"
                                                    HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding CurrentFrameDisplayText}"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#E3E8EE"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding PreviewInfoText}"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#C7D1DB"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       MaxWidth="380" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Spacing="4"
                                                    HorizontalAlignment="Center">
                                            <TextBlock Text="Compare Preview"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#E3E8EE"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding CompareSidePreviewInfoText}"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#C7D1DB"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       MaxWidth="380" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <ListBox Grid.Row="2"
                                     x:Name="ThumbnailList"
                                     Classes="thumbnailList"
                                     ItemsSource="{Binding FrameThumbnails}"
                                     SelectedItem="{Binding SelectedFrameThumbnail, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Bottom"
                                     IsVisible="{Binding HasFrameThumbnails}"
                                     MaxHeight="110">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Classes="thumbCard"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Tag="{Binding $parent[ListBox].DataContext}">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Replace"
                                                              Click="ReplaceThumbnailMenuItem_Click"
                                                              Tag="{Binding}" />
                                                    <MenuItem Header="Remove"
                                                              Click="RemoveThumbnailMenuItem_Click"
                                                              Tag="{Binding}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>

                                            <StackPanel Spacing="4"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Top">
                                                <Border Classes="thumbImageHost">
                                                    <Image Source="{Binding Bitmap}"
                                                           Width="38"
                                                           Height="38"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                                </Border>

                                                <TextBlock Classes="thumbLabel"
                                                           Text="{Binding DisplayText}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            <!-- right -->
            <Border Grid.Column="2"
                    IsVisible="{Binding ShowAnimationEditorPanel}"
                    Background="#1E232A"
                    BorderBrush="#343B46"
                    BorderThickness="1,0,0,0"
                    Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">

                        <TextBlock Text="Details"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <Border Classes="card"
                                Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Playback"
                                           FontWeight="Bold" />

                                <WrapPanel Orientation="Horizontal"
                                           VerticalAlignment="Center">
                                    <Button Command="{Binding PlayCommand}"
                                            Width="40"
                                            Height="32"
                                            Margin="0,0,6,0"
                                            ToolTip.Tip="Play">
                                        <PathIcon Data="M 3 2 L 3 14 L 13 8 Z"
                                                  Width="14"
                                                  Height="14" />
                                    </Button>

                                    <Button Command="{Binding PauseCommand}"
                                            Width="40"
                                            Height="32"
                                            Margin="0,0,6,0"
                                            ToolTip.Tip="Pause">
                                        <PathIcon Data="M 3 2 H 6 V 14 H 3 Z M 10 2 H 13 V 14 H 10 Z"
                                                  Width="14"
                                                  Height="14" />
                                    </Button>

                                    <Button Command="{Binding PreviousFrameCommand}"
                                            Width="40"
                                            Height="32"
                                            Margin="0,0,6,0"
                                            ToolTip.Tip="Previous frame">
                                        <PathIcon Data="M 11 2 L 3 8 L 11 14 Z M 12 2 H 14 V 14 H 12 Z"
                                                  Width="14"
                                                  Height="14" />
                                    </Button>

                                    <Button Command="{Binding NextFrameCommand}"
                                            Width="40"
                                            Height="32"
                                            Margin="0,0,10,0"
                                            ToolTip.Tip="Next frame">
                                        <PathIcon Data="M 3 2 L 11 8 L 3 14 Z M 12 2 H 14 V 14 H 12 Z"
                                                  Width="14"
                                                  Height="14" />
                                    </Button>
                                </WrapPanel>

                                <Grid ColumnDefinitions="Auto,* ,Auto"
                                      ColumnSpacing="8">
                                    <TextBlock Grid.Column="0"
                                               Text="Speed"
                                               VerticalAlignment="Center" />

                                    <Slider Grid.Column="1"
                                            Minimum="1"
                                            Maximum="20"
                                            Value="{Binding PlaybackSpeed}"
                                            TickFrequency="1" />

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding PlaybackSpeedText}"
                                               Width="40"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="card"
                                Padding="10"
                                IsVisible="{Binding ShowAnimationView}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Animation Details"
                                           FontWeight="Bold" />
                                <Grid ColumnDefinitions="96,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedAnimationName}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Body ID:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedBodyId}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Action ID:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedActionId}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Frames:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedFrameCount}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Size:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedFrameSize}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Source:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedAnimationSource}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Index:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedIndexNumber}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Offset:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedOffset}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Length:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedLength}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Extra:" Margin="0,0,10,0" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding SelectedExtra}" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="card"
                                Padding="10"
                                IsVisible="{Binding ShowMulSlotList}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="MUL Slot Details"
                                           FontWeight="Bold" />
                                <Grid ColumnDefinitions="96,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="File:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedMulSlotFile}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Body Index:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedMulSlotIndex}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="True Body:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedMulSlotOffset}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Anim Length:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedMulSlotLength}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Type:" Margin="0,0,10,0" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedMulSlotExtra}" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="card"
                                Padding="10"
                                IsVisible="{Binding ShowUopSlotList}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="UOP Target Details"
                                           FontWeight="Bold" />
                                <Grid ColumnDefinitions="96,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="File:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedUopBodyFile}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Body ID:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedUopBodyId}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Body Type:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedUopBodyType}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Actions:" Margin="0,0,10,0" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedUopBodyActionCount}" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Expander Header="UOP Sequence / Remap"
                                  IsVisible="{Binding ShowUopSequenceDetails}">
                            <Border Classes="card"
                                    Padding="10"
                                    Margin="0,6,0,0">
                                <Grid ColumnDefinitions="96,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Req Action:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedSequenceRequestedAction}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Resolved:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedSequenceResolvedGroup}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Remap:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedSequenceRemap}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Seq Frames:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedSequenceFrameCount}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Body Map:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedSequenceBodyMapping}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="UOP Path:" Margin="0,0,10,0" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedUopVirtualPathDisplay}" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                        </Expander>

                        <Border Classes="detailCard"
                                Margin="0,0,0,10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Compare Overlay"
                                           FontWeight="SemiBold"
                                           Foreground="#D5DCE4" />

                                <Grid ColumnDefinitions="Auto,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                      ColumnSpacing="10"
                                      RowSpacing="4">

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Enabled:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding CompareOverlayEnabled}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="Target:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding CompareOverlayTargetText}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Action:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding CompareOverlayActionIndex}" />

                                    <TextBlock Grid.Row="3" Grid.Column="0"
                                               Text="Direction:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                               Text="{Binding CompareOverlayDirectionIndex}" />

                                    <TextBlock Grid.Row="4" Grid.Column="0"
                                               Text="Frame Mode:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="4" Grid.Column="1"
                                               Text="{Binding CompareOverlayFrameModeText}" />

                                    <TextBlock Grid.Row="5" Grid.Column="0"
                                               Text="Offset:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="5" Grid.Column="1"
                                               Text="{Binding CompareOverlayOffsetText}" />

                                    <TextBlock Grid.Row="6" Grid.Column="0"
                                               Text="Opacity:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="6" Grid.Column="1"
                                               Text="{Binding CompareOverlayOpacityText}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="File:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding CompareOverlayFileText}" />
                                    <TextBlock Grid.Row="7" Grid.Column="0"
                                               Text="Pose:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="7" Grid.Column="1"
                                               Text="{Binding CurrentComparePoseText}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="detailCard"
                                Margin="0,0,0,10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Prop Overlay"
                                           FontWeight="SemiBold"
                                           Foreground="#D5DCE4" />

                                <Grid ColumnDefinitions="Auto,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                      ColumnSpacing="10"
                                      RowSpacing="4">

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Enabled:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding PropOverlayEnabled}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="Source:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding PropOverlaySourceText}"
                                               TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Offset:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding PropOverlayOffsetText}" />

                                    <TextBlock Grid.Row="3" Grid.Column="0"
                                               Text="Scale:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                               Text="{Binding PropOverlayScaleText}" />

                                    <TextBlock Grid.Row="4" Grid.Column="0"
                                               Text="Rotation:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="4" Grid.Column="1"
                                               Text="{Binding PropOverlayRotationText}" />

                                    <TextBlock Grid.Row="5" Grid.Column="0"
                                               Text="Layer:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="5" Grid.Column="1"
                                               Text="{Binding PropOverlayLayerText}" />

                                    <TextBlock Grid.Row="6" Grid.Column="0"
                                               Text="Pivot:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="6" Grid.Column="1"
                                               Text="{Binding PropOverlayPivotText}" />

                                    <TextBlock Grid.Row="7" Grid.Column="0"
                                               Text="Pose:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="7" Grid.Column="1"
                                               Text="{Binding CurrentPropPoseText}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="card"
                                Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Debug"
                                           FontWeight="Bold" />

                                <WrapPanel Orientation="Horizontal">
                                    <Button Content="Open Debug Window"
                                            Command="{Binding PopOutDebugCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- loading overlay -->
        <Border IsVisible="{Binding IsLoading}"
                Grid.RowSpan="99"
                Background="#AA111317"
                ZIndex="9999">
            <Grid HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
                <Border Width="520"
                        MaxWidth="520"
                        Padding="22"
                        CornerRadius="12"
                        Background="#25282D"
                        BorderBrush="#3A3F46"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Loading Animation Data"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#F2F2F2" />

                        <TextBlock Text="{Binding LoadingText}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="#D8D8D8" />

                        <ProgressBar Minimum="0"
                                     Maximum="100"
                                     Value="{Binding LoadingProgress}"
                                     Height="18" />

                        <TextBlock Text="{Binding LoadingProgress, StringFormat={}{0:0}%}"
                                   HorizontalAlignment="Center"
                                   Foreground="#9BB7D3"
                                   FontWeight="SemiBold" />

                        <Border Background="#1C1F24"
                                BorderBrush="#35393F"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Tip"
                                           FontWeight="Bold"
                                           Foreground="#F2C14E" />

                                <TextBlock Text="{Binding LoadingTipText}"
                                           TextWrapping="Wrap"
                                           Foreground="#D8D8D8" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>