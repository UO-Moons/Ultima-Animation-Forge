<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:UltimaAnimationForge.ViewModels"
        x:Class="UltimaAnimationForge.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1500"
        Height="940"
        MinWidth="1180"
        MinHeight="760"
        Background="#1B1F25"
        Foreground="White"
        RequestedThemeVariant="Dark"
        Title="Ultima Animation Forge Alpha 19"
        DragDrop.AllowDrop="True"
        mc:Ignorable="d">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFolderCommand}" />
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveChangesCommand}" />
        <KeyBinding Gesture="Ctrl+E" Command="{Binding ExportFramesCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+E" Command="{Binding ExportVdCommand}" />
        <KeyBinding Gesture="Ctrl+I" Command="{Binding ImportVdCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+I" Command="{Binding ImportVdToUopCommand}" />
        <KeyBinding Gesture="Ctrl+P" Command="{Binding PlayCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+P" Command="{Binding PauseCommand}" />
        <KeyBinding Gesture="Ctrl+Left" Command="{Binding PreviousFrameCommand}" />
        <KeyBinding Gesture="Ctrl+Right" Command="{Binding NextFrameCommand}" />
        <KeyBinding Gesture="Ctrl+R" Command="{Binding ReplaceSelectedFrameCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+R" Command="{Binding ImportPngSequenceCommand}" />
        <KeyBinding Gesture="Ctrl+Delete" Command="{Binding DeleteAnimationCommand}" />
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoFrameEditCommand}" />

        <KeyBinding Gesture="Alt+1" Command="{Binding Direction0Command}" />
        <KeyBinding Gesture="Alt+2" Command="{Binding Direction1Command}" />
        <KeyBinding Gesture="Alt+3" Command="{Binding Direction2Command}" />
        <KeyBinding Gesture="Alt+4" Command="{Binding Direction3Command}" />
        <KeyBinding Gesture="Alt+5" Command="{Binding Direction4Command}" />

        <KeyBinding Gesture="Alt+C" Command="{Binding ToggleCheckerCommand}" />
        <KeyBinding Gesture="Alt+L" Command="{Binding ToggleLoopCommand}" />
    </Window.KeyBindings>

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#3A424D" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#56606D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="32" />
        </Style>

        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#46505D" />
        </Style>

        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#2E353F" />
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="#101419" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#505A66" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#101419" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#505A66" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="32" />
        </Style>

        <Style Selector="Slider">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="ContextMenu">
            <Setter Property="Background" Value="#232A32" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#56606D" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="ContextMenu MenuItem">
            <Setter Property="Background" Value="#232A32" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="ContextMenu MenuItem:pointerover">
            <Setter Property="Background" Value="#46505D" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="ContextMenu MenuItem:disabled">
            <Setter Property="Foreground" Value="#7F8790" />
        </Style>

        <Style Selector="MenuItem.topAction">
            <Setter Property="Background" Value="#334052" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderBrush" Value="#56606D" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="MenuItem.topAction:pointerover">
            <Setter Property="Background" Value="#46546A" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="Separator">
            <Setter Property="Background" Value="#56606D" />
        </Style>

        <Style Selector="ListBox">
            <Setter Property="Background" Value="#1F242B" />
            <Setter Property="BorderBrush" Value="#303844" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="#24303B" />
        </Style>

        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="#1B3E58" />
        </Style>

        <Style Selector="ListBoxItem:selected:pointerover">
            <Setter Property="Background" Value="#254F6F" />
        </Style>

        <Style Selector="ListBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="{TemplateBinding Background}" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="#232A32" />
            <Setter Property="BorderBrush" Value="#343D49" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="ListBoxItem:pointerover Border.card">
            <Setter Property="Background" Value="#283440" />
            <Setter Property="BorderBrush" Value="#66839C" />
        </Style>

        <Style Selector="ListBoxItem:selected Border.card">
            <Setter Property="Background" Value="#22455F" />
            <Setter Property="BorderBrush" Value="#73D0FF" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>

        <Style Selector="ListBoxItem:selected:pointerover Border.card">
            <Setter Property="Background" Value="#2C5372" />
            <Setter Property="BorderBrush" Value="#94DEFF" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>

        <Style Selector="Border.selectionBar">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBoxItem:pointerover Border.selectionBar">
            <Setter Property="Background" Value="#57718B" />
        </Style>

        <Style Selector="ListBoxItem:selected Border.selectionBar">
            <Setter Property="Background" Value="#73D0FF" />
        </Style>

        <Style Selector="ListBoxItem:selected:pointerover Border.selectionBar">
            <Setter Property="Background" Value="#94DEFF" />
        </Style>

        <Style Selector="TextBlock.subtleText">
            <Setter Property="Foreground" Value="#A9BED0" />
        </Style>

        <Style Selector="ListBoxItem:selected TextBlock.subtleText">
            <Setter Property="Foreground" Value="#DDF4FF" />
        </Style>

        <Style Selector="ListBox.thumbnailList">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="ListBox.thumbnailList ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.thumbnailList ListBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="{TemplateBinding Background}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style Selector="Border.thumbCard">
            <Setter Property="Background" Value="#182028" />
            <Setter Property="BorderBrush" Value="#37424D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Width" Value="58" />
            <Setter Property="Height" Value="78" />
        </Style>

        <Style Selector="ListBox.thumbnailList ListBoxItem:pointerover Border.thumbCard">
            <Setter Property="Background" Value="#22303B" />
            <Setter Property="BorderBrush" Value="#6D8AA2" />
        </Style>

        <Style Selector="ListBox.thumbnailList ListBoxItem:selected Border.thumbCard">
            <Setter Property="Background" Value="#1E3A4E" />
            <Setter Property="BorderBrush" Value="#7DD8FF" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>

        <Style Selector="ListBox.thumbnailList ListBoxItem:selected:pointerover Border.thumbCard">
            <Setter Property="Background" Value="#284A62" />
            <Setter Property="BorderBrush" Value="#9BE3FF" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>

        <Style Selector="Border.thumbImageHost">
            <Setter Property="Background" Value="#0F1419" />
            <Setter Property="BorderBrush" Value="#2D3741" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style Selector="TextBlock.thumbLabel">
            <Setter Property="Foreground" Value="#D6E2ED" />
        </Style>

        <Style Selector="ListBox.thumbnailList ListBoxItem:selected TextBlock.thumbLabel">
            <Setter Property="Foreground" Value="White" />
        </Style>


        <Style Selector="ListBox.animationBrowserList">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="ListBox.animationBrowserList ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.animationBrowserList ListBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="{TemplateBinding Background}" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="Border.animationBrowserTile">
            <Setter Property="Background" Value="#252A31" />
            <Setter Property="BorderBrush" Value="#3A404A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style Selector="ListBox.animationBrowserList ListBoxItem:pointerover Border.animationBrowserTile">
            <Setter Property="Background" Value="#2E3945" />
            <Setter Property="BorderBrush" Value="#66839C" />
        </Style>

        <Style Selector="ListBox.animationBrowserList ListBoxItem:selected Border.animationBrowserTile">
            <Setter Property="Background" Value="#22455F" />
            <Setter Property="BorderBrush" Value="#73D0FF" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>

        <Style Selector="Expander">
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="Expander /template/ ToggleButton">
            <Setter Property="Background" Value="#232A32" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*">

        <!-- profile/action bar -->
        <Border Grid.Row="0"
                Background="#23282F"
                BorderBrush="#343B46"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid ColumnDefinitions="Auto,190,Auto,Auto,Auto,*,360">
                <TextBlock Grid.Column="0"
                           Text="Profile"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#D5DCE4" />

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding ProfileOptions}"
                          SelectedIndex="{Binding SelectedProfileIndex, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0" />

                <Button Grid.Column="2"
                        Content="Manage Profiles"
                        Command="{Binding ManageProfilesCommand}"
                        Margin="0,0,8,0" />

                <Button Grid.Column="3"
                        Content="Open UO Folder"
                        Command="{Binding OpenFolderCommand}"
                        Margin="0,0,8,0" />

                <Button Grid.Column="4"
                        Content="?"
                        Command="{Binding HelpCommand}"
                        Width="36"
                        ToolTip.Tip="Show help and shortcuts" />

                <Border Grid.Column="6"
                        Background="#1A1F25"
                        BorderBrush="#39414D"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10,8"
                        Margin="12,0,0,0">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding HeaderStatusText}"
                                   Foreground="#EDF1F5"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="2" />
                        <TextBlock Text="{Binding UnsavedChangesText}"
                                   Foreground="#F2C14E"
                                   FontWeight="Bold"
                                   IsVisible="{Binding HasAnyUnsavedChanges}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- tool tabs -->
        <Border Grid.Row="1"
                Background="#1B2027"
                BorderBrush="#343B46"
                BorderThickness="0,0,0,1"
                Padding="8,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="2">
                    <Button Content="Animations"
                            Command="{Binding ShowAnimationEditorCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="Animation Browser"
                            Command="{Binding ShowAnimationBrowserCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="Gumps"
                            Command="{Binding ShowGumpEditorCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="TileData"
                            Command="{Binding ShowTileDataCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="Art"
                            Command="{Binding ShowArtCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="AnimData"
                            Command="{Binding ShowAnimDataCommand}"
                            CornerRadius="0"
                            Padding="14,6"
                            MinHeight="28" />

                    <Button Content="Wearables"
                            Command="{Binding ShowWearableWizardCommand}"/>
                </StackPanel>

                <WrapPanel Grid.Column="2"
                           Orientation="Horizontal"
                           VerticalAlignment="Center"
                           IsVisible="{Binding ShowAnimationEditorPanel}">
                    <Button Content="Save Changes"
                            Command="{Binding SaveChangesCommand}"
                            IsEnabled="{Binding CanSaveChanges}"
                            MinHeight="28"
                            Padding="10,5"
                            Margin="0,0,6,0" />

                    <Button Content="Preview Window"
                            Command="{Binding PopOutPreviewCommand}"
                            MinHeight="28"
                            Padding="10,5"
                            Margin="0,0,6,0" />

                    <Menu Background="Transparent"
                          Margin="0,0,6,0">
                        <MenuItem Header="Edit ▼"
                                  Classes="topAction">
                            <MenuItem Header="MUL Slot View"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding ShowMulSlotView, Mode=TwoWay}" />
                            <Separator />
                            <MenuItem Header="Replace Frame"
                                      Command="{Binding ReplaceSelectedFrameCommand}"
                                      IsVisible="{Binding ShowAnimationView}" />
                            <MenuItem Header="Remove Frame"
                                      Command="{Binding RemoveSelectedFrameCommand}"
                                      IsVisible="{Binding ShowAnimationView}" />
                            <MenuItem Header="Import PNG Sequence"
                                      Command="{Binding ImportPngSequenceCommand}"
                                      IsVisible="{Binding ShowAnimationView}" />
                            <Separator IsVisible="{Binding ShowAnimationView}" />
                            <MenuItem Header="Undo"
                                      Command="{Binding UndoFrameEditCommand}"
                                      IsEnabled="{Binding CanUndoFrameEdit}"
                                      IsVisible="{Binding ShowAnimationView}" />
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent"
                          Margin="0,0,6,0">
                        <MenuItem Header="Import / Export ▼"
                                  Classes="topAction">
                            <MenuItem Header="Open EC / KR Package Viewer"
                                      Command="{Binding OpenMythicPackageViewerCommand}" />
                            <Separator />
                            <MenuItem Header="Create Empty MUL/IDX"
                                      Command="{Binding CreateEmptyLegacyMulIdxCommand}" />
                            <Separator />
                            <MenuItem Header="Export Frames"
                                      Command="{Binding ExportFramesCommand}" />
                            <MenuItem Header="Export VD"
                                      Command="{Binding ExportVdCommand}"
                                      IsVisible="{Binding ShowAnimationView}" />
                            <Separator />
                            <MenuItem Header="Import VD"
                                      Command="{Binding ImportVdCommand}"
                                      IsVisible="{Binding ShowSlotView}" />
                            <MenuItem Header="Import UOP VD"
                                      Command="{Binding ImportVdToUopCommand}"
                                      IsVisible="{Binding ShowSlotView}" />
                            <MenuItem Header="Import Sprite Sheet"
                                      Command="{Binding ImportSpriteSheetCommand}" />
                            <Separator />
                            <MenuItem Header="Delete Animation"
                                      Command="{Binding DeleteAnimationCommand}"
                                      IsVisible="{Binding ShowAnimationView}" />
                        </MenuItem>
                    </Menu>

                    <Button Content="Uox3 - Discord"
                            Command="{Binding OpenDiscordCommand}"
                            MinHeight="28"
                            Padding="10,5" />
                </WrapPanel>
            </Grid>
        </Border>

        <!-- filters -->
        <Border Grid.Row="2"
                Background="#1E232A"
                BorderBrush="#343B46"
                BorderThickness="0,0,0,1"
                Padding="12,10"
                IsVisible="{Binding ShowAnimationEditorPanel}">
            <Grid ColumnDefinitions="Auto,144,12,Auto,98,12,Auto,100,118,12,Auto,128,18,Auto,8,Auto,132,8,Auto,176,8,Auto,124,8,Auto,108,*"
                  VerticalAlignment="Center">

                <!-- File -->
                <TextBlock Grid.Column="0"
                           Text="File"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#D5DCE4" />

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AnimationFileOptions}"
                          SelectedItem="{Binding SelectedAnimationFile}"
                          VerticalAlignment="Center" />

                <!-- Type -->
                <TextBlock Grid.Column="3"
                           Text="Type"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#D5DCE4"
                           IsVisible="{Binding ShowAnimationOnlyControls}" />

                <ComboBox Grid.Column="4"
                          ItemsSource="{Binding BodyTypeOptions}"
                          SelectedItem="{Binding SelectedBodyType}"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowAnimationOnlyControls}" />

                <!-- Direction -->
                <TextBlock Grid.Column="6"
                           Text="Dir"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#D5DCE4"
                           IsVisible="{Binding ShowActionDirectionControls}" />

                <Slider Grid.Column="7"
                        Minimum="0"
                        Maximum="4"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Value="{Binding SelectedDirectionSliderValue}"
                        VerticalAlignment="Center"
                        IsVisible="{Binding ShowActionDirectionControls}" />

                <ComboBox Grid.Column="8"
                          ItemsSource="{Binding DirectionOptions}"
                          SelectedItem="{Binding SelectedDirection}"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowActionDirectionControls}" />

                <!-- Action -->
                <TextBlock Grid.Column="10"
                           Text="Action"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#D5DCE4"
                           IsVisible="{Binding ShowActionDirectionControls}" />

                <ComboBox Grid.Column="11"
                          ItemsSource="{Binding ActionOptions}"
                          SelectedItem="{Binding SelectedAction}"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowActionDirectionControls}" />

                <!-- Compare target -->
                <TextBlock Grid.Column="13"
                           Text="{Binding CompareTargetHeaderText}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"
                           Foreground="#9FB2C8"
                           FontWeight="SemiBold"
                           IsVisible="{Binding ShowCompareSelectorBar}" />

                <TextBlock Grid.Column="15"
                           Text="File"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           Foreground="#D5DCE4"
                           IsVisible="{Binding ShowCompareSelectorBar}" />

                <ComboBox Grid.Column="16"
                          Width="132"
                          ItemsSource="{Binding CompareAnimationFileOptions}"
                          SelectedItem="{Binding CompareSelectedAnimationFile}"
                          Margin="0,0,6,0"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowCompareSelectorBar}" />

                <TextBlock Grid.Column="18"
                           Text="Body"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           Foreground="#D5DCE4"
                           IsVisible="{Binding ShowCompareSelectorBar}" />

                <ComboBox Grid.Column="19"
                          Width="176"
                          ItemsSource="{Binding CompareAnimationEntries}"
                          SelectedItem="{Binding CompareSelectedAnimation}"
                          Margin="0,0,6,0"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowCompareSelectorBar}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="0">
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Column="21"
                           Text="Action"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           Foreground="#D5DCE4"
                           IsVisible="{Binding ShowCompareSelectorBar}" />

                <ComboBox Grid.Column="22"
                          Width="124"
                          ItemsSource="{Binding CompareActionOptions}"
                          SelectedItem="{Binding CompareSelectedAction}"
                          Margin="0,0,6,0"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowCompareSelectorBar}" />

                <TextBlock Grid.Column="24"
                           Text="Dir"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           Foreground="#D5DCE4"
                           IsVisible="{Binding ShowCompareSelectorBar}" />

                <ComboBox Grid.Column="25"
                          Width="108"
                          ItemsSource="{Binding CompareDirectionOptions}"
                          SelectedItem="{Binding CompareSelectedDirection}"
                          Margin="0,0,6,0"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowCompareSelectorBar}" />
            </Grid>
        </Border>

        <!-- live preview row -->
        <Border Grid.Row="4"
                Background="#1E232A"
                BorderBrush="#343B46"
                BorderThickness="0,0,0,1"
                Padding="12,8"
                IsVisible="{Binding ShowAnimationEditorPanel}">
            <StackPanel Spacing="8">
                <TextBlock Text="Live Preview"
                           FontWeight="Bold"
                           Foreground="#D5DCE4" />

                <WrapPanel Orientation="Horizontal"
                           VerticalAlignment="Center">
                    <CheckBox Content="Sharpen"
                              IsChecked="{Binding LivePreviewSharpenEnabled}"
                              VerticalAlignment="Center"
                              Margin="0,0,6,0" />

                    <NumericUpDown Width="70"
                                   Minimum="0"
                                   Maximum="5"
                                   Increment="0.1"
                                   FormatString="0.0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding LivePreviewSharpenAmountValue, Mode=TwoWay}"
                                   Margin="0,0,8,0" />

                    <ComboBox Width="100"
                              SelectedIndex="{Binding LivePreviewSharpenModeIndex}"
                              Margin="0,0,12,0">
                        <ComboBoxItem Content="Gaussian" />
                        <ComboBoxItem Content="Pixel" />
                    </ComboBox>

                    <CheckBox Content="Contrast"
                              IsChecked="{Binding LivePreviewContrastEnabled}"
                              VerticalAlignment="Center"
                              Margin="0,0,6,0" />

                    <NumericUpDown Width="70"
                                   Minimum="0"
                                   Maximum="2"
                                   Increment="0.05"
                                   FormatString="0.00"
                                   ShowButtonSpinner="False"
                                   Value="{Binding LivePreviewContrastAmountValue, Mode=TwoWay}"
                                   Margin="0,0,12,0" />

                    <CheckBox Content="Outline"
                              IsChecked="{Binding LivePreviewOutlineEnabled}"
                              VerticalAlignment="Center"
                              Margin="0,0,6,0" />

                    <NumericUpDown Width="70"
                                   Minimum="0"
                                   Maximum="1"
                                   Increment="0.05"
                                   FormatString="0.00"
                                   ShowButtonSpinner="False"
                                   Value="{Binding LivePreviewOutlineStrengthValue, Mode=TwoWay}"
                                   Margin="0,0,18,0" />

                    <TextBlock Text="Mode"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <ComboBox Width="150"
                              ItemsSource="{Binding CompareOverlaySyncModeOptions}"
                              SelectedItem="{Binding CompareOverlaySyncMode}"
                              Margin="0,0,6,0" />

                    <TextBlock Text="F"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4"
                               IsVisible="{Binding IsCompareOverlayManualFrameMode}" />

                    <NumericUpDown Width="70"
                                   Minimum="0"
                                   Maximum="999"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding CompareOverlayFrameIndex, Mode=TwoWay}"
                                   Margin="0,0,6,0"
                                   IsVisible="{Binding IsCompareOverlayManualFrameMode}" />

                    <TextBlock Text="X"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <NumericUpDown Width="70"
                                   Minimum="-500"
                                   Maximum="500"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding CompareOverlayOffsetXText, Mode=TwoWay}"
                                   Margin="0,0,6,0" />

                    <TextBlock Text="Y"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <NumericUpDown Width="70"
                                   Minimum="-500"
                                   Maximum="500"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding CompareOverlayOffsetYText, Mode=TwoWay}"
                                   Margin="0,0,6,0" />

                    <TextBlock Text="Opacity"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <NumericUpDown Width="78"
                                   Minimum="0"
                                   Maximum="100"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding CompareOverlayOpacityPercentText, Mode=TwoWay}"
                                   Margin="0,0,8,0" />

                    <Menu Background="Transparent">
                        <MenuItem Header="Compare ▼"
                                  Classes="topAction">
                            <MenuItem Header="Mount Rider Align"
                                      Command="{Binding SetupMountRiderAlignmentCommand}" />
                            <MenuItem Header="Apply Current Rider Offset To All Frames"
                                      Command="{Binding ApplyCurrentComparePoseToAllFramesCommand}" />
                            <Separator />
                            <MenuItem Header="Compare On"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding CompareOverlayEnabled, Mode=TwoWay}" />
                            <MenuItem Header="Side-by-Side Preview"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding CompareSideBySideEnabled, Mode=TwoWay}" />
                            <MenuItem Header="Clear Compare"
                                      Command="{Binding ClearCompareOverlayCommand}" />
                            <MenuItem Header="Apply Compare To Frame"
                                      Command="{Binding ApplyCompareOverlayToCurrentFrameCommand}" />
                            <MenuItem Header="Apply Compare To Direction"
                                      Command="{Binding ApplyCompareOverlayToCurrentDirectionCommand}" />
                            <Separator />
                            <MenuItem Header="Save Compare Pose For Frame"
                                      Command="{Binding SaveComparePoseForCurrentFrameCommand}" />
                            <MenuItem Header="Copy Compare Pose From Previous"
                                      Command="{Binding CopyComparePoseFromPreviousFrameCommand}" />
                            <MenuItem Header="Clear Compare Pose For Frame"
                                      Command="{Binding ClearComparePoseForCurrentFrameCommand}" />
                            <Separator />
                            <MenuItem Header="{Binding CompareOverlayDragModeButtonText}"
                                      Command="{Binding ToggleCompareOverlayDragModeCommand}" />
                        </MenuItem>
                    </Menu>

                    <TextBlock Text="X"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <NumericUpDown Width="70"
                                   Minimum="-500"
                                   Maximum="500"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding PropOverlayOffsetXValue, Mode=TwoWay}"
                                   Margin="0,0,6,0" />

                    <TextBlock Text="Y"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <NumericUpDown Width="70"
                                   Minimum="-500"
                                   Maximum="500"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding PropOverlayOffsetYValue, Mode=TwoWay}"
                                   Margin="0,0,6,0" />

                    <TextBlock Text="Scale"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <NumericUpDown Width="78"
                                   Minimum="1"
                                   Maximum="800"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding PropOverlayScalePercentValue, Mode=TwoWay}"
                                   Margin="0,0,6,0" />

                    <TextBlock Text="Rot"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <NumericUpDown Width="78"
                                   Minimum="-180"
                                   Maximum="180"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding PropOverlayRotationDegreesValue, Mode=TwoWay}"
                                   Margin="0,0,6,0" />

                    <TextBlock Text="Pivot X"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <NumericUpDown Width="78"
                                   Minimum="-500"
                                   Maximum="500"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding PropOverlayPivotXValue, Mode=TwoWay}"
                                   Margin="0,0,6,0" />

                    <TextBlock Text="Pivot Y"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Foreground="#D5DCE4" />

                    <NumericUpDown Width="78"
                                   Minimum="-500"
                                   Maximum="500"
                                   Increment="1"
                                   FormatString="0"
                                   ShowButtonSpinner="False"
                                   Value="{Binding PropOverlayPivotYValue, Mode=TwoWay}"
                                   Margin="0,0,8,0" />

                    <CheckBox Content="Flip H"
                              IsChecked="{Binding PropOverlayFlipHorizontal}"
                              VerticalAlignment="Center"
                              Margin="0,0,6,0" />

                    <CheckBox Content="Flip V"
                              IsChecked="{Binding PropOverlayFlipVertical}"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0" />

                    <ComboBox Width="88"
                              SelectedIndex="{Binding PropOverlayDrawOrderIndex}"
                              Margin="0,0,8,0">
                        <ComboBoxItem Content="Behind" />
                        <ComboBoxItem Content="Front" />
                    </ComboBox>

                    <Menu Background="Transparent">
                        <MenuItem Header="Preview ▼"
                                  Classes="topAction">
                            <MenuItem Header="Apply To Direction"
                                      Command="{Binding ApplyLivePreviewToCurrentDirectionCommand}" />
                            <MenuItem Header="Apply To Full Animation"
                                      Command="{Binding ApplyLivePreviewToFullAnimationCommand}" />
                            <Separator />
                            <MenuItem Header="Reset Preview Effects"
                                      Command="{Binding ResetLivePreviewCommand}" />
                        </MenuItem>
                    </Menu>

                    <Button Content="Hue..."
                            Command="{Binding ConfigureLivePreviewHueCommand}"
                            Margin="0,0,6,0" />

                    <TextBlock Text="{Binding LivePreviewHueText}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Foreground="#D5DCE4" />

                    <Button Content="Scale..."
                            Command="{Binding ConfigureLivePreviewScaleCommand}"
                            Margin="0,0,6,0" />

                    <TextBlock Text="{Binding LivePreviewScaleText}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Foreground="#D5DCE4" />

                    <Menu Background="Transparent">
                        <MenuItem Header="Props ▼"
                                  Classes="topAction">
                            <MenuItem Header="Prop On"
                                      ToggleType="CheckBox"
                                      IsChecked="{Binding PropOverlayEnabled, Mode=TwoWay}" />
                            <MenuItem Header="Load Prop..."
                                      Command="{Binding LoadPropOverlayCommand}" />
                            <MenuItem Header="Clear Prop"
                                      Command="{Binding ClearPropOverlayCommand}" />
                            <Separator />
                            <MenuItem Header="Apply Prop"
                                      Command="{Binding ApplyPropOverlayToCurrentFrameCommand}" />
                            <MenuItem Header="Apply Prop To Direction"
                                      Command="{Binding ApplyPropOverlayToCurrentDirectionCommand}" />
                            <Separator />
                            <MenuItem Header="{Binding PreviewDragModeButtonText}"
                                      Command="{Binding ToggleCompareOverlayDragModeCommand}" />
                            <Separator />
                            <MenuItem Header="Set Pose"
                                      Command="{Binding SavePropPoseForCurrentFrameCommand}" />
                            <MenuItem Header="Copy Previous Pose"
                                      Command="{Binding CopyPropPoseFromPreviousFrameCommand}" />
                            <MenuItem Header="Clear Pose"
                                      Command="{Binding ClearPropPoseForCurrentFrameCommand}" />
                        </MenuItem>
                    </Menu>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- main content -->
        <Grid Grid.Row="5"
              ColumnDefinitions="280,*,310">

            <!-- left -->
            <Border Grid.Column="0"
                    Background="#1E232A"
                    BorderBrush="#343B46"
                    BorderThickness="0,0,1,0"
                    Padding="10"
                    IsVisible="{Binding ShowAnimationEditorPanel}">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                    <TextBlock Grid.Row="0"
                               Text="Animations"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"
                               IsVisible="{Binding ShowAnimationView}" />

                    <TextBlock Grid.Row="0"
                               Text="{Binding SlotPaneTitle}"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"
                               IsVisible="{Binding ShowSlotView}" />

                    <TextBox Grid.Row="1"
                             Watermark="Search animations or MUL slots..."
                             Text="{Binding SearchText}"
                             Margin="0,0,0,10" />

                    <WrapPanel Grid.Row="2"
                               Margin="0,0,0,10"
                               IsVisible="{Binding ShowMulSlotList}"
                               VerticalAlignment="Center">
                        <TextBlock Text="Show:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Foreground="#D5DCE4" />

                        <CheckBox Content="H"
                                  IsChecked="{Binding MulSlotShowHFilter}"
                                  Margin="0,0,10,0" />

                        <CheckBox Content="L"
                                  IsChecked="{Binding MulSlotShowLFilter}"
                                  Margin="0,0,10,0" />

                        <CheckBox Content="P"
                                  IsChecked="{Binding MulSlotShowPFilter}" />
                        <Button Content="Clear Selected"
                                Command="{Binding ClearSelectedMulSlotCommand}"
                                IsVisible="{Binding ShowMulSlotView}" />
                    </WrapPanel>

                    <Grid Grid.Row="3">
                        <ListBox ItemsSource="{Binding AnimationEntries}"
                                 SelectedItem="{Binding SelectedAnimation}"
                                 IsVisible="{Binding ShowAnimationView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="card">
                                        <Grid ColumnDefinitions="6,*">
                                            <Border Classes="selectionBar"
                                                    Grid.Column="0"
                                                    CornerRadius="8,0,0,8" />

                                            <StackPanel Grid.Column="1"
                                                        Spacing="2"
                                                        Margin="10,8,10,8">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="White" />
                                                <TextBlock Classes="subtleText"
                                                           Text="{Binding SecondaryText}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox Name="MulSlotListBox"
                                 ItemsSource="{Binding MulSlotEntries}"
                                 SelectedItem="{Binding SelectedMulSlot}"
                                 IsVisible="{Binding ShowMulSlotList}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="card">
                                        <Grid ColumnDefinitions="6,*">
                                            <Border Classes="selectionBar"
                                                    Grid.Column="0"
                                                    CornerRadius="8,0,0,8" />

                                            <StackPanel Grid.Column="1"
                                                        Spacing="2"
                                                        Margin="10,8,10,8">
                                                <TextBlock Text="{Binding DisplayText}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="White" />
                                                <TextBlock Classes="subtleText"
                                                           Text="{Binding FileName}"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox ItemsSource="{Binding UopBodyEntries}"
                                 SelectedItem="{Binding SelectedUopBodySlot}"
                                 IsVisible="{Binding ShowUopSlotList}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="card">
                                        <Grid ColumnDefinitions="6,*">
                                            <Border Classes="selectionBar"
                                                    Grid.Column="0"
                                                    CornerRadius="8,0,0,8" />

                                            <StackPanel Grid.Column="1"
                                                        Spacing="2"
                                                        Margin="10,8,10,8">
                                                <TextBlock Text="{Binding DisplayText}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="White" />
                                                <TextBlock Classes="subtleText"
                                                           Text="{Binding SecondaryText}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <!-- center -->
            <Grid Grid.Column="1"
                  Grid.ColumnSpan="2"
                  ColumnDefinitions="*,310"
                  Margin="14">

                <!-- Animation Browser -->
                <Grid Grid.Column="0"
                      Grid.ColumnSpan="2"
                      RowDefinitions="Auto,*"
                      Margin="-294,0,0,0"
                      IsVisible="{Binding ShowAnimationBrowserPanel}">

                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="Auto,220,12,Auto,150,12,Auto,150,*,Auto"
                              VerticalAlignment="Center">

                            <TextBlock Grid.Column="0"
                                       Text="Animation Browser"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0" />

                            <TextBox Grid.Column="1"
                                     Watermark="Search body, name, source..."
                                     Text="{Binding AnimationBrowserSearchText}"
                                     VerticalAlignment="Center" />

                            <TextBlock Grid.Column="3"
                                       Text="Source"
                                       Foreground="#D5DCE4"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />

                            <ComboBox Grid.Column="4"
                                      ItemsSource="{Binding AnimationBrowserSourceFilters}"
                                      SelectedItem="{Binding AnimationBrowserSourceFilter}"
                                      VerticalAlignment="Center" />

                            <TextBlock Grid.Column="6"
                                       Text="Type"
                                       Foreground="#D5DCE4"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />

                            <ComboBox Grid.Column="7"
                                      ItemsSource="{Binding AnimationBrowserTypeFilters}"
                                      SelectedItem="{Binding AnimationBrowserTypeFilter}"
                                      VerticalAlignment="Center" />

                            <TextBlock Grid.Column="9"
                                       Text="{Binding AnimationBrowserCountText}"
                                       Foreground="#A9BED0"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,130,20,Auto,20,Auto,100,20,Auto,Auto,12,115,92,12,Auto,*"
                              VerticalAlignment="Center">

                            <TextBlock Grid.Column="0"
                                       Text="Sort"
                                       Foreground="#D5DCE4"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AnimationBrowserSortModeOptions}"
                                      SelectedItem="{Binding AnimationBrowserSortMode}"
                                      VerticalAlignment="Center" />

                            <CheckBox Grid.Column="3"
                                      Content="Show Missing"
                                      IsChecked="{Binding AnimationBrowserShowMissingSlots}"
                                      VerticalAlignment="Center" />

                            <TextBlock Grid.Column="5"
                                       Text="Size"
                                       Foreground="#D5DCE4"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />

                            <ComboBox Grid.Column="6"
                                      ItemsSource="{Binding AnimationBrowserTileSizeOptions}"
                                      SelectedItem="{Binding AnimationBrowserTileSize}"
                                      VerticalAlignment="Center" />

                            <Button Grid.Column="8"
                                    Content="Refresh Thumbnails"
                                    Command="{Binding RefreshAnimationBrowserThumbnailsCommand}"
                                    Padding="10,6"
                                    VerticalAlignment="Center" />

                            <CheckBox Grid.Column="11"
                                      Content="Hover Preview"
                                      IsChecked="{Binding AnimationBrowserHoverPreviewEnabled}"
                                      VerticalAlignment="Center" />

                            <ComboBox Grid.Column="12"
                                      Width="90"
                                      ItemsSource="{Binding AnimationBrowserHoverSpeedOptions}"
                                      SelectedItem="{Binding AnimationBrowserHoverSpeed}"
                                      VerticalAlignment="Center" />

                            <CheckBox Grid.Column="14"
                                      Content="Names"
                                      IsChecked="{Binding AnimationBrowserShowNames}"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="#1E232A"
                            BorderBrush="#343B46"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">

                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">

                            <ListBox ItemsSource="{Binding AnimationBrowserTiles}"
                                     SelectedItem="{Binding SelectedAnimationBrowserTile}"
                                     Classes="animationBrowserList">

                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Classes="animationBrowserTile"
                                                Width="{Binding $parent[Window].DataContext.AnimationBrowserTileWidth}"
                                                Height="{Binding $parent[Window].DataContext.AnimationBrowserTileHeight}"
                                                Tag="{Binding $parent[Window].DataContext}"
                                                PointerEntered="AnimationBrowserTile_PointerEntered"
                                                PointerExited="AnimationBrowserTile_PointerExited">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Open in Editor"
                                                              Command="{Binding $parent[Window].DataContext.OpenAnimationBrowserTileCommand}"
                                                              CommandParameter="{Binding}" />

                                                    <MenuItem Header="Open Detached Preview"
                                                              Command="{Binding $parent[Window].DataContext.OpenAnimationBrowserTileDetachedPreviewCommand}"
                                                              CommandParameter="{Binding}" />

                                                    <MenuItem Header="Edit Name"
                                                              Click="EditAnimationBrowserNameMenuItem_Click"
                                                              Tag="{Binding}" />

                                                    <MenuItem Header="Refresh This Thumbnail"
                                                              Command="{Binding $parent[Window].DataContext.RefreshAnimationBrowserTileThumbnailCommand}"
                                                              CommandParameter="{Binding}" />

                                                    <Separator />

                                                    <MenuItem Header="Export Frames"
                                                              Command="{Binding $parent[Window].DataContext.ExportAnimationBrowserTileFramesCommand}"
                                                              CommandParameter="{Binding}" />

                                                    <MenuItem Header="Export VD"
                                                              Command="{Binding $parent[Window].DataContext.ExportAnimationBrowserTileVdCommand}"
                                                              CommandParameter="{Binding}" />

                                                    <Separator />

                                                    <MenuItem Header="Delete Animation"
                                                              Command="{Binding $parent[Window].DataContext.DeleteAnimationBrowserTileCommand}"
                                                              CommandParameter="{Binding}" />

                                                    <MenuItem Header="Copy Body ID"
                                                              Click="CopyAnimationBrowserBodyIdMenuItem_Click"
                                                              Tag="{Binding}" />

                                                    <MenuItem Header="Copy Source File"
                                                              Click="CopyAnimationBrowserSourceFileMenuItem_Click"
                                                              Tag="{Binding}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid RowDefinitions="*,Auto">
                                                <Border Grid.Row="0"
                                                        Background="#101419"
                                                        BorderBrush="#343B46"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Padding="2">
                                                    <Grid Width="{Binding $parent[Window].DataContext.AnimationBrowserImageHostSize}"
                                                          Height="{Binding $parent[Window].DataContext.AnimationBrowserImageHostSize}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center">
                                                        <Image Source="{Binding Thumbnail}"
                                                               Width="{Binding $parent[Window].DataContext.AnimationBrowserImageBoxSize}"
                                                               Height="{Binding $parent[Window].DataContext.AnimationBrowserImageBoxSize}"
                                                               Stretch="Uniform"
                                                               RenderOptions.BitmapInterpolationMode="None"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding !IsMissingSlot}" />

                                                        <TextBlock Text="MISSING"
                                                                   IsVisible="{Binding IsMissingSlot}"
                                                                   Foreground="#7F8790"
                                                                   FontSize="9"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>

                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding DisplayName}"
                                                           Foreground="White"
                                                           FontSize="10"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,1,0,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Grid Grid.Column="0"
                      Grid.ColumnSpan="2"
                      IsVisible="{Binding ShowGumpEditorPanel}"
                      Margin="-294,0,0,0"
                      RowDefinitions="Auto,*">

                    <Border Grid.Row="0"
                            Background="#1E232A"
                            BorderBrush="#343B46"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">

                            <ComboBox Width="145"
                                      ItemsSource="{Binding GumpSharpenModes}"
                                      SelectedItem="{Binding SelectedGumpSharpenMode}"/>

                            <Button Content="Sharpen"
                                    Command="{Binding SharpenSelectedGumpCommand}"/>

                            <Button Content="Contrast +"
                                    Command="{Binding IncreaseGumpContrastCommand}"/>

                            <Button Content="Contrast -"
                                    Command="{Binding DecreaseGumpContrastCommand}"/>

                            <Button Content="Brighten"
                                    Command="{Binding BrightenGumpCommand}"/>

                            <Button Content="Darken"
                                    Command="{Binding DarkenGumpCommand}"/>

                            <Button Content="Sat +"
                                    Command="{Binding IncreaseGumpSaturationCommand}"/>

                            <Button Content="Sat -"
                                    Command="{Binding DecreaseGumpSaturationCommand}"/>

                            <Button Content="Outline"
                                    Command="{Binding OutlineGumpCommand}"/>

                            <Button Content="Load Overlay Image"
                                    Command="{Binding LoadGumpOverlayImageCommand}"/>

                            <TextBlock Text="Overlay Opacity %"
                                       Foreground="#AAB4C0"
                                       VerticalAlignment="Center"/>

                            <NumericUpDown Minimum="0"
                                           Maximum="100"
                                           Increment="5"
                                           Width="125"
                                           Value="{Binding GumpOverlayOpacityPercent}"/>

                            <ComboBox Width="120"
                                      ItemsSource="{Binding GumpOverlayBlendModes}"
                                      SelectedItem="{Binding SelectedGumpOverlayBlendMode}"/>

                            <Button Content="Apply Overlay To Gump"
                                    Command="{Binding ApplyOverlayToGumpCommand}"/>

                            <Button Content="Save Edit"
                                    Command="{Binding SaveGumpEditCommand}"/>

                            <Button Content="Reset Edit"
                                    Command="{Binding ResetGumpEditPreviewCommand}"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="300,*,260"
                          Background="#111317">

                        <Border Grid.Column="0"
                                BorderBrush="#343B46"
                                BorderThickness="0,0,1,0"
                                Background="#161A20"
                                Padding="8">
                            <Grid RowDefinitions="Auto,*">

                                <StackPanel Grid.Row="0"
                                            Spacing="6"
                                            Margin="0,0,0,8">
                                    <TextBlock Text="Search"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2"/>

                                    <TextBox Watermark="Gump ID..."
                                             Text="{Binding GumpSearchText}"/>
                                </StackPanel>

                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding GumpEntries}"
                                         SelectedItem="{Binding SelectedGump}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="Auto,*"
                                                  Margin="6">
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsSelectedForExport}"
                                                          IsVisible="{Binding IsValid}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,8,0"/>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DisplayText}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#E4EAF2"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="1">

                            <!-- normal centered single preview -->
                            <ScrollViewer IsVisible="{Binding !ShowGumpParallelView}"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <Grid HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="16">

                                    <Border Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            Padding="20">
                                        <Canvas Width="300"
                                                Height="400">

                                            <Image Source="{Binding PaperdollTemplateBitmap}"
                                                   IsVisible="{Binding ShowPaperdollTemplate}"
                                                   Opacity="{Binding PaperdollTemplateOpacity}"
                                                   Canvas.Left="{Binding PaperdollTemplateOffsetX}"
                                                   Canvas.Top="{Binding PaperdollTemplateOffsetY}"
                                                   Stretch="None"/>

                                            <Image Source="{Binding SelectedGumpBitmap}"
                                                   Canvas.Left="{Binding GumpWearableOffsetX}"
                                                   Canvas.Top="{Binding GumpWearableOffsetY}"
                                                   Stretch="None"/>
                                        </Canvas>
                                    </Border>
                                </Grid>
                            </ScrollViewer>

                            <!-- parallel preview -->
                            <Grid IsVisible="{Binding ShowGumpParallelView}"
                                  ColumnDefinitions="*,*">

                                <ScrollViewer Grid.Column="0"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Spacing="8">
                                        <TextBlock Text="Selected"
                                                   HorizontalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="#E4EAF2"/>
                                        <Border Margin="16"
                                                Background="#20242B"
                                                BorderBrush="#343B46"
                                                BorderThickness="1"
                                                Padding="20">
                                            <Image Source="{Binding SelectedGumpBitmap}"
                                                   Stretch="None"/>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>

                                <ScrollViewer Grid.Column="1"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Spacing="8">
                                        <TextBlock Text="{Binding GumpParallelPairText}"
                                                   HorizontalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="#E4EAF2"/>
                                        <Border Margin="16"
                                                Background="#20242B"
                                                BorderBrush="#343B46"
                                                BorderThickness="1"
                                                Padding="20">
                                            <Image Source="{Binding PairedGumpBitmap}"
                                                   Stretch="None"/>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>

                            </Grid>
                        </Grid>

                        <Border Grid.Column="2"
                                Background="#1A1F26"
                                BorderBrush="#343B46"
                                BorderThickness="1,0,0,0"
                                Padding="12">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Spacing="8">

                                    <TextBlock Text="Gump Info"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2"/>

                                    <Border Background="#202733"
                                            BorderBrush="#343B46"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10">
                                        <StackPanel Spacing="8">
                                            <CheckBox Content="Show free slots"
                                                      IsChecked="{Binding ShowFreeGumpSlots}"/>

                                            <ComboBox Width="180"
                                                      SelectedIndex="{Binding SelectedGumpFreeSlotMode}"
                                                      IsVisible="{Binding ShowFreeGumpSlots}">
                                                <ComboBoxItem Content="All Free"/>
                                                <ComboBoxItem Content="Male Wearables"/>
                                                <ComboBoxItem Content="Female Wearables"/>
                                            </ComboBox>

                                            <CheckBox Content="Parallel wearable view"
                                                      IsChecked="{Binding ShowGumpParallelView}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#202733"
                                            BorderBrush="#343B46"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10">
                                        <StackPanel Spacing="8">

                                            <TextBlock Text="Paperdoll Template"
                                                       FontWeight="Bold"
                                                       Foreground="#AAB4C0"/>

                                            <CheckBox Content="Show paperdoll template"
                                                      IsChecked="{Binding ShowPaperdollTemplate}"/>

                                            <StackPanel Spacing="8"
                                                        IsVisible="{Binding ShowPaperdollTemplate}">

                                                <TextBlock Text="Template Gump ID"
                                                           FontWeight="Bold"
                                                           Foreground="#AAB4C0"/>

                                                <NumericUpDown Minimum="0"
                                                               Maximum="65535"
                                                               Value="{Binding PaperdollTemplateGumpId}"
                                                               Width="180"/>

                                                <TextBlock Text="Template Opacity"
                                                           FontWeight="Bold"
                                                           Foreground="#AAB4C0"/>

                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding PaperdollTemplateOpacity}"
                                                        Width="180"/>

                                                <TextBlock Text="Template Offset"
                                                           FontWeight="Bold"
                                                           Foreground="#AAB4C0"/>

                                                <TextBlock Text="{Binding PaperdollTemplateOffsetX, StringFormat='Template X: {0}'}"
                                                           Foreground="#E4EAF2"/>

                                                <TextBlock Text="{Binding PaperdollTemplateOffsetY, StringFormat='Template Y: {0}'}"
                                                           Foreground="#E4EAF2"/>

                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="6">
                                                    <Button Content="←"
                                                            Command="{Binding NudgePaperdollTemplateLeftCommand}"/>
                                                    <Button Content="→"
                                                            Command="{Binding NudgePaperdollTemplateRightCommand}"/>
                                                    <Button Content="↑"
                                                            Command="{Binding NudgePaperdollTemplateUpCommand}"/>
                                                    <Button Content="↓"
                                                            Command="{Binding NudgePaperdollTemplateDownCommand}"/>
                                                </StackPanel>

                                                <Button Content="Reset Template Offset"
                                                        Command="{Binding ResetPaperdollTemplateOffsetCommand}"/>

                                                <TextBlock Text="Wearable Offset"
                                                           FontWeight="Bold"
                                                           Foreground="#AAB4C0"/>

                                                <TextBlock Text="{Binding GumpWearableOffsetX, StringFormat='X: {0}'}"
                                                           Foreground="#E4EAF2"/>

                                                <TextBlock Text="{Binding GumpWearableOffsetY, StringFormat='Y: {0}'}"
                                                           Foreground="#E4EAF2"/>

                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="6">
                                                    <Button Content="←"
                                                            Command="{Binding NudgeGumpLeftCommand}"/>
                                                    <Button Content="→"
                                                            Command="{Binding NudgeGumpRightCommand}"/>
                                                    <Button Content="↑"
                                                            Command="{Binding NudgeGumpUpCommand}"/>
                                                    <Button Content="↓"
                                                            Command="{Binding NudgeGumpDownCommand}"/>
                                                </StackPanel>

                                                <Button Content="Reset Offset"
                                                        Command="{Binding ResetGumpWearableOffsetCommand}"/>

                                                <TextBlock Text="Wearable Scale"
                                                           FontWeight="Bold"
                                                           Foreground="#AAB4C0"/>

                                                <NumericUpDown Minimum="10"
                                                               Maximum="400"
                                                               Increment="5"
                                                               Value="{Binding GumpWearableScalePercent}"
                                                               Width="180"/>

                                                <Button Content="Apply Scale"
                                                        Command="{Binding ApplyGumpPreviewScaleCommand}"/>

                                                <Button Content="Save Offset To Gump"
                                                        Command="{Binding SaveGumpOffsetCommand}"/>

                                                <Button Content="Load Source Image"
                                                        Command="{Binding LoadSourceImageForGumpCommand}"/>

                                                <Button Content="Remove White BG"
                                                        Command="{Binding RemoveWhiteBackgroundFromGumpCommand}"/>

                                                <Button Content="Auto Trim"
                                                        Command="{Binding AutoTrimGumpPreviewCommand}"/>

                                                <Button Content="Save Preview To Gump"
                                                        Command="{Binding SaveGumpEditCommand}"/>

                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="Slots"
                                               FontWeight="Bold"
                                               Foreground="#AAB4C0"/>
                                    <TextBlock Text="{Binding GumpSlotSummaryText}"
                                               Foreground="#E4EAF2"/>

                                    <TextBlock Text="Wearable Free Slots"
                                               FontWeight="Bold"
                                               Foreground="#AAB4C0"/>

                                    <TextBlock Text="{Binding GumpWearableSlotSummaryText}"
                                               Foreground="#E4EAF2"/>

                                    <Border Background="#202733"
                                            BorderBrush="#343B46"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10">
                                        <StackPanel Spacing="6">

                                            <TextBlock Text="ID"
                                                       FontWeight="Bold"
                                                       Foreground="#AAB4C0"/>
                                            <TextBlock Text="{Binding SelectedGump.GumpId}"
                                                       Foreground="#E4EAF2"/>

                                            <TextBlock Text="Hex"
                                                       FontWeight="Bold"
                                                       Foreground="#AAB4C0"/>
                                            <TextBlock Text="{Binding SelectedGump.HexId}"
                                                       Foreground="#E4EAF2"/>

                                            <TextBlock Text="Size"
                                                       FontWeight="Bold"
                                                       Foreground="#AAB4C0"/>
                                            <TextBlock Text="{Binding SelectedGump.SizeText}"
                                                       Foreground="#E4EAF2"/>

                                            <TextBlock Text="Bytes"
                                                       FontWeight="Bold"
                                                       Foreground="#AAB4C0"/>
                                            <TextBlock Text="{Binding SelectedGump.LengthText}"
                                                       Foreground="#E4EAF2"/>

                                            <TextBlock Text="Source File"
                                                       FontWeight="Bold"
                                                       Foreground="#AAB4C0"/>

                                            <TextBlock Text="{Binding SelectedGump.SourceFile}"
                                                       TextWrapping="Wrap"
                                                       Foreground="#E4EAF2"/>

                                            <Button Command="{Binding ExportSelectedGumpCommand}"
                                                    Margin="0,10,0,0">
                                                <TextBlock Text="Export PNG"/>
                                            </Button>

                                            <Button Command="{Binding ExportCheckedGumpsCommand}"
                                                    Margin="0,6,0,0">
                                                <TextBlock Text="Export Checked"/>
                                            </Button>

                                            <Button Command="{Binding ImportCheckedGumpsCommand}"
                                                    Margin="0,6,0,0">
                                                <TextBlock Text="Mass Import Checked"/>
                                            </Button>

                                            <Button Command="{Binding ImportPngToGumpCommand}"
                                                    Margin="0,6,0,0">
                                                <TextBlock Text="Import / Replace Image"/>
                                            </Button>

                                            <Button Command="{Binding RemoveSelectedGumpCommand}"
                                                    Margin="0,6,0,0">
                                                <TextBlock Text="Remove / Free Slot"/>
                                            </Button>

                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Tiledata Tab -->
                <Grid Grid.Column="0"
                      Grid.ColumnSpan="2"
                      IsVisible="{Binding ShowTileDataPanel}"
                      Margin="-294,0,0,0"
                      RowDefinitions="Auto,*">

                    <Border Grid.Row="0"
                            Background="#1E232A"
                            BorderBrush="#343B46"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <CheckBox Content="Land"
                                      IsChecked="{Binding ShowLandTileData}" />

                            <CheckBox Content="Items"
                                      IsChecked="{Binding ShowItemTileData}" />

                            <TextBox Width="220"
                                     Watermark="Search ID / name..."
                                     Text="{Binding TileDataSearchText}" />


                            <Button Content="Save TileData Changes"
                                    Command="{Binding SaveTileDataChangesCommand}" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="360,*"
                          ColumnSpacing="10"
                          Margin="10">

                        <Border Grid.Column="0"
                                Background="#20262E"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ListBox ItemsSource="{Binding FilteredTileDataEntries}"
                                     SelectedItem="{Binding SelectedTileDataEntry}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}"
                                                   Foreground="#E4EAF2"
                                                   Margin="6"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <Border Grid.Column="1"
                                Background="#20262E"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12">
                            <Grid ColumnDefinitions="280,*"
                                  ColumnSpacing="12">

                                <StackPanel Grid.Column="0"
                                            Spacing="6">

                                    <TextBlock Text="{Binding SelectedTileDataEntry.DisplayText}"
                                               FontSize="18"
                                               FontWeight="Bold"/>

                                    <TextBlock Text="{Binding SelectedTileDataEntry.Flags, StringFormat='Flags: 0x{0:X16}'}"/>

                                    <TextBlock Text="Name"/>
                                    <TextBox Text="{Binding SelectedTileDataEntry.Name, Mode=TwoWay}"
                                             LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Animation/Gump"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Animation, Mode=TwoWay}"
                                                   Minimum="-32768"
                                                   Maximum="32767"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Weight"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Weight, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Quality/Layer/Light"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Quality, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Quantity"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Quantity, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Hue"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Hue, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Stack Offset"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.StackingOffset, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Value"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Value, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Height"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Height, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="MiscData"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.MiscData, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="65535"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Unk2"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Unknown2, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>

                                    <TextBlock Text="Unk3"/>
                                    <NumericUpDown Value="{Binding SelectedTileDataEntry.Unknown3, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="255"
                                                   LostFocus="TileDataEditField_LostFocus"/>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Background="#151A20"
                                        BorderBrush="#343B46"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding SelectedTileDataFlagOptions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Width="150"
                                                              Margin="2"
                                                              Content="{Binding Name}"
                                                              IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                              Command="{Binding $parent[ItemsControl].DataContext.ToggleSelectedTileDataFlagCommand}"
                                                              CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Art Tab -->
                <Grid Grid.Column="0"
                      Grid.ColumnSpan="2"
                      IsVisible="{Binding ShowArtPanel}"
                      Margin="-294,0,0,0"
                      RowDefinitions="Auto,*">

                    <Border Grid.Row="0"
                            Background="#1E232A"
                            BorderBrush="#343B46"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Button Content="Load Art"
                                    Command="{Binding LoadArtTabCommand}" />

                            <Button Content="Import Selected"
                                    Command="{Binding ImportSelectedArtCommand}" />

                            <Button Content="Mass Import"
                                    Command="{Binding MassImportArtCommand}" />

                            <Button Content="Export Selected"
                                    Command="{Binding ExportSelectedArtCommand}" />

                            <Button Content="Mass Export"
                                    Command="{Binding MassExportArtCommand}" />

                            <Button Content="Remove Checked"
                                    Command="{Binding RemoveCheckedArtCommand}" />

                            <Button Content="Undo Art Change"
                                    Command="{Binding UndoArtChangeCommand}" />

                            <Button Content="Check All"
                                    Command="{Binding CheckAllArtCommand}" />

                            <Button Content="Uncheck All"
                                    Command="{Binding UncheckAllArtCommand}" />

                            <Button Content="Save Art Changes"
                                    Command="{Binding SaveArtChangesCommand}" />

                            <Button Content="Save TileData"
                                    Command="{Binding SaveTileDataChangesCommand}" />

                            <Button Content="Save AnimData"
                                    Command="{Binding SaveAnimDataCommand}" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="360,*,300"
                          ColumnSpacing="10"
                          Margin="10">

                        <!-- Left: Filters + Art List -->
                        <Grid Grid.Column="0"
                              RowDefinitions="Auto,*"
                              RowSpacing="8">

                            <Border Grid.Row="0"
                                    Background="#20262E"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <StackPanel Spacing="6">
                                    <TextBox Watermark="Search ID / hex..."
                                             Text="{Binding ArtSearchText}" />

                                    <ComboBox ItemsSource="{Binding ArtSlotFilterOptions}"
                                              SelectedItem="{Binding SelectedArtSlotFilter}"
                                              Width="180"/>

                                    <ComboBox ItemsSource="{Binding ArtEraFilters}"
                                              SelectedItem="{Binding SelectedArtEraFilter}"
                                              PlaceholderText="UO Era Filter"
                                              Width="220"/>

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="12">
                                        <CheckBox Content="Land"
                                                  IsChecked="{Binding ShowLandArt}" />

                                        <CheckBox Content="Statics"
                                                  IsChecked="{Binding ShowStaticArt}" />

                                        <CheckBox Content="ArtTiles"
                                                  IsChecked="{Binding ShowArtThumbnails}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Background="#20262E"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ListBox ItemsSource="{Binding ArtEntries}"
                                         SelectedItem="{Binding SelectedArtEntry}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="Auto,54,*"
                                                  ColumnSpacing="8"
                                                  Margin="6">
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsChecked}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,6,0"/>

                                                <Border Grid.Column="1"
                                                        Width="48"
                                                        Height="48"
                                                        Background="#151A20"
                                                        BorderBrush="#343B46"
                                                        BorderThickness="1">
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="Uniform"
                                                           RenderOptions.BitmapInterpolationMode="None"/>
                                                </Border>

                                                <StackPanel Grid.Column="2"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayText}"
                                                               FontWeight="SemiBold"
                                                               Foreground="#E4EAF2" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Grid>

                        <!-- Middle: Preview -->
                        <Grid Grid.Column="1"
                              RowDefinitions="*,Auto"
                              RowSpacing="10">

                            <Border Grid.Row="0"
                                    Background="#20262E"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                    <Image Source="{Binding SelectedArtBitmap}"
                                           Stretch="None"
                                           RenderOptions.BitmapInterpolationMode="None"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                </ScrollViewer>
                            </Border>

                            <Border Grid.Row="1"
                                    IsVisible="{Binding ShowSelectedArtAnimDataPreview}"
                                    Background="#151A20"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <StackPanel Spacing="6">

                                    <TextBlock Text="{Binding SelectedArtAnimDataEntry.SecondaryText}"
                                               HorizontalAlignment="Center"
                                               Foreground="#C7D1DB"
                                               FontWeight="SemiBold"/>

                                    <Button Content="{Binding ArtAnimDataPlayButtonText}"
                                            Command="{Binding ToggleArtAnimDataPlaybackCommand}"
                                            HorizontalAlignment="Center"
                                            MinWidth="80"/>

                                    <ItemsControl ItemsSource="{Binding SelectedArtAnimDataFrames}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center"
                                                            Spacing="8"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="58"
                                                        Height="70"
                                                        Background="#20262E"
                                                        BorderBrush="#343B46"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        Padding="4">
                                                    <StackPanel>
                                                        <Image Source="{Binding Bitmap}"
                                                               Width="42"
                                                               Height="42"
                                                               Stretch="Uniform"
                                                               RenderOptions.BitmapInterpolationMode="None"/>

                                                        <TextBlock Text="{Binding FrameIndex}"
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="#E4EAF2"
                                                                   FontSize="11"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Right: Art Info + TileData Info -->
                        <Border Grid.Column="2"
                                Background="#20262E"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="12">

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Art Info"
                                                   FontWeight="Bold"
                                                   Foreground="#E4EAF2" />

                                        <TextBlock Text="{Binding SelectedArtEntry.DisplayText}"
                                                   Foreground="#C7D1DB"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Text="{Binding SelectedArtEntry.SecondaryText}"
                                                   Foreground="#AAB4C0"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Border Height="1"
                                            Background="#343B46"
                                            Margin="0,4"/>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="TileData Info"
                                                   FontWeight="Bold"
                                                   Foreground="#E4EAF2" />

                                        <TextBlock Text="{Binding SelectedArtTileDataEntry.DisplayText}"
                                                   Foreground="#C7D1DB"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Text="{Binding SelectedArtTileDataEntry.Flags, StringFormat='Flags: 0x{0:X16}'}"
                                                   Foreground="#AAB4C0"
                                                   TextWrapping="Wrap" />

                                        <TextBlock Text="{Binding SelectedArtTileDataFlagNames, StringFormat='Flag Names: {0}'}"
                                                   Foreground="#AAB4C0"
                                                   TextWrapping="Wrap" />

                                        <Button Content="Edit Flags..."
                                                Command="{Binding OpenArtTileDataFlagsCommand}" />

                                        <Button Content="{Binding ArtAnimDataEditButtonText}"
                                                Command="{Binding OpenArtAnimDataEditorCommand}" />

                                        <CheckBox Content="Show TileData Editor"
                                                  IsChecked="{Binding ShowArtTileDataEditor}"
                                                  Foreground="#C7D1DB"/>

                                        <StackPanel IsVisible="{Binding ShowArtTileDataEditor}"
                                                    Spacing="4">

                                            <TextBlock Text="Name" Foreground="#AAB4C0"/>
                                            <TextBox Text="{Binding SelectedArtTileDataEntry.Name, Mode=TwoWay}"
                                                     LostFocus="ArtTileDataEditField_LostFocus"/>

                                            <TextBlock Text="Animation/Gump" Foreground="#AAB4C0"/>
                                            <NumericUpDown Value="{Binding SelectedArtTileDataEntry.Animation, Mode=TwoWay}"
                                                           Minimum="0"
                                                           Maximum="640000"
                                                           Increment="1"
                                                           FormatString="0"
                                                           LostFocus="ArtTileDataEditField_LostFocus"/>

                                            <TextBlock Text="Weight" Foreground="#AAB4C0"/>
                                            <NumericUpDown Value="{Binding SelectedArtTileDataEntry.Weight, Mode=TwoWay}"
                                                           Minimum="0"
                                                           Maximum="255"
                                                           Increment="1"
                                                           FormatString="0"
                                                           LostFocus="ArtTileDataEditField_LostFocus"/>

                                            <TextBlock Text="Quality/Layer/Light" Foreground="#AAB4C0"/>
                                            <NumericUpDown Value="{Binding SelectedArtTileDataEntry.Quality, Mode=TwoWay}"
                                                           Minimum="0"
                                                           Maximum="255"
                                                           Increment="1"
                                                           FormatString="0"
                                                           LostFocus="ArtTileDataEditField_LostFocus"/>

                                            <TextBlock Text="Quantity" Foreground="#AAB4C0"/>
                                            <NumericUpDown Value="{Binding SelectedArtTileDataEntry.Quantity, Mode=TwoWay}"
                                                           Minimum="0"
                                                           Maximum="255"
                                                           Increment="1"
                                                           FormatString="0"
                                                           LostFocus="ArtTileDataEditField_LostFocus"/>

                                            <TextBlock Text="Hue" Foreground="#AAB4C0"/>
                                            <NumericUpDown Value="{Binding SelectedArtTileDataEntry.Hue, Mode=TwoWay}"
                                                           Minimum="0"
                                                           Maximum="255"
                                                           Increment="1"
                                                           FormatString="0"
                                                           LostFocus="ArtTileDataEditField_LostFocus"/>

                                            <TextBlock Text="Stack Offset" Foreground="#AAB4C0"/>
                                            <NumericUpDown Value="{Binding SelectedArtTileDataEntry.StackingOffset, Mode=TwoWay}"
                                                           Minimum="0"
                                                           Maximum="255"
                                                           Increment="1"
                                                           FormatString="0"
                                                           LostFocus="ArtTileDataEditField_LostFocus"/>

                                            <TextBlock Text="Value" Foreground="#AAB4C0"/>
                                            <NumericUpDown Value="{Binding SelectedArtTileDataEntry.Value, Mode=TwoWay}"
                                                           Minimum="0"
                                                           Maximum="255"
                                                           Increment="1"
                                                           FormatString="0"
                                                           LostFocus="ArtTileDataEditField_LostFocus"/>

                                            <TextBlock Text="Height" Foreground="#AAB4C0"/>
                                            <NumericUpDown Value="{Binding SelectedArtTileDataEntry.Height, Mode=TwoWay}"
                                                           Minimum="0"
                                                           Maximum="255"
                                                           Increment="1"
                                                           FormatString="0"
                                                           LostFocus="ArtTileDataEditField_LostFocus"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Expander Header="Image Tools"
                                              IsExpanded="{Binding ShowArtImageTools}">
                                        <StackPanel Spacing="8"
                                                    Margin="0,8,0,0">

                                            <TextBlock Text="Enhance"
                                                       FontWeight="Bold"
                                                       Foreground="#E4EAF2"/>

                                            <TextBlock Text="{Binding ArtBrightness, StringFormat='Brightness: {0:0}'}"/>
                                            <Slider Minimum="-80"
                                                    Maximum="80"
                                                    Value="{Binding ArtBrightness}"/>

                                            <TextBlock Text="{Binding ArtContrast, StringFormat='Contrast: {0:0}'}"/>
                                            <Slider Minimum="-80"
                                                    Maximum="80"
                                                    Value="{Binding ArtContrast}"/>

                                            <TextBlock Text="{Binding ArtSharpness, StringFormat='Sharpness: {0:0}'}"/>
                                            <Slider Minimum="0"
                                                    Maximum="100"
                                                    Value="{Binding ArtSharpness}"/>

                                            <ComboBox Width="110"
                                                      ItemsSource="{Binding ArtSharpenModes}"
                                                      SelectedItem="{Binding SelectedArtSharpenMode}"/>

                                            <Button Content="Apply Enhancement"
                                                    Command="{Binding ApplyArtEnhancementCommand}"/>

                                            <Border Height="1"
                                                    Background="#343B46"
                                                    Margin="0,4"/>

                                            <TextBlock Text="Overlay"
                                                       FontWeight="Bold"
                                                       Foreground="#E4EAF2"/>

                                            <Button Content="Load Overlay Image"
                                                    Command="{Binding LoadArtOverlayImageCommand}"/>

                                            <TextBlock Text="{Binding ArtOverlayOpacity, StringFormat='Opacity: {0:0}%'}"/>
                                            <Slider Minimum="0"
                                                    Maximum="100"
                                                    Value="{Binding ArtOverlayOpacity}"/>

                                            <ComboBox ItemsSource="{Binding ArtOverlayBlendModes}"
                                                      SelectedItem="{Binding SelectedArtOverlayBlendMode}"/>

                                            <Button Content="Apply Overlay To Art"
                                                    Command="{Binding ApplyArtOverlayCommand}"/>

                                            <Border Height="1"
                                                    Background="#343B46"
                                                    Margin="0,4"/>

                                            <Button Content="Queue Art Edit"
                                                    Command="{Binding QueueSelectedArtEditCommand}"/>

                                            <Button Content="Reset Edit"
                                                    Command="{Binding ResetArtEditCommand}"/>
                                        </StackPanel>
                                    </Expander>

                                    <Border Height="1"
                                            Background="#343B46"
                                            Margin="0,8,0,4"/>

                                    <StackPanel Spacing="4"
                                                IsVisible="{Binding ShowSelectedArtEquipmentGump}">
                                        <TextBlock Text="Equipment Gump"
                                                   FontWeight="Bold"
                                                   Foreground="#E4EAF2" />

                                        <TextBlock Text="{Binding SelectedArtMaleEquipmentGumpText}"
                                                   Foreground="#AAB4C0"
                                                   TextWrapping="Wrap" />

                                        <Border Background="#151A20"
                                                BorderBrush="#343B46"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="8"
                                                HorizontalAlignment="Left">
                                            <Image Source="{Binding SelectedArtMaleEquipmentGumpBitmap}"
                                                   Stretch="None"
                                                   RenderOptions.BitmapInterpolationMode="None" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- AnimData Tab -->
                <Grid Grid.Column="0"
                      Grid.ColumnSpan="2"
                      IsVisible="{Binding ShowAnimDataPanel}"
                      Margin="-294,0,0,0"
                      RowDefinitions="Auto,*">

                    <Border Grid.Row="0"
                            Background="#1E232A"
                            BorderBrush="#343B46"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Button Content="Load AnimData"
                                    Command="{Binding LoadAnimDataTabCommand}" />

                            <Button Content="Save AnimData"
                                    Command="{Binding SaveAnimDataCommand}" />

                            <Button Content="Export"
                                    Command="{Binding ExportAnimDataCommand}" />

                            <Button Content="Import"
                                    Command="{Binding ImportAnimDataCommand}" />

                            <Button Content="Check All"
                                    Command="{Binding CheckAllAnimDataCommand}" />

                            <Button Content="Uncheck All"
                                    Command="{Binding UncheckAllAnimDataCommand}" />

                            <TextBlock Text="{Binding AnimDataStatusText}"
                                       VerticalAlignment="Center"
                                       Foreground="#C7D1DB" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="380,*,330"
                          ColumnSpacing="10"
                          Margin="10">

                        <!-- Left: Filters + AnimData List -->
                        <Grid Grid.Column="0"
                              RowDefinitions="Auto,*"
                              RowSpacing="8">

                            <Border Grid.Row="0"
                                    Background="#20262E"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <StackPanel Spacing="6">
                                    <TextBox Watermark="Search ID / hex / name..."
                                             Text="{Binding AnimDataSearchText}" />

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="12">
                                        <CheckBox Content="Missing Art"
                                                  IsChecked="{Binding ShowAnimDataMissingArt}" />

                                        <CheckBox Content="No Anim Flag"
                                                  IsChecked="{Binding ShowAnimDataWithoutAnimationFlag}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Background="#20262E"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ListBox ItemsSource="{Binding AnimDataEntries}"
                                         SelectedItem="{Binding SelectedAnimDataEntry}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="8"
                                                  Margin="6">
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsChecked}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,6,0" />

                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayText}"
                                                               FontWeight="SemiBold"
                                                               Foreground="#E4EAF2" />

                                                    <TextBlock Text="{Binding SecondaryText}"
                                                               FontSize="12"
                                                               Foreground="#AAB4C0"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Grid>

                        <!-- Middle: Base + selected frame preview -->
                        <Grid Grid.Column="1"
                              RowDefinitions="*,Auto,*"
                              RowSpacing="10">

                            <Border Grid.Row="0"
                                    Background="#20262E"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12">
                                <Grid RowDefinitions="Auto,*">
                                    <TextBlock Grid.Row="0"
                                               Text="Base Graphic"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2"
                                               Margin="0,0,0,8" />

                                    <ScrollViewer Grid.Row="1"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                        <Image Source="{Binding SelectedAnimDataBaseBitmap}"
                                               Stretch="None"
                                               RenderOptions.BitmapInterpolationMode="None"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1"
                                    Height="1"
                                    Background="#343B46" />

                            <Border Grid.Row="2"
                                    Background="#20262E"
                                    BorderBrush="#343B46"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12">
                                <Grid RowDefinitions="Auto,*">
                                    <TextBlock Grid.Row="0"
                                               Text="Selected Frame Graphic"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2"
                                               Margin="0,0,0,8" />

                                    <ScrollViewer Grid.Row="1"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                        <Image Source="{Binding SelectedAnimDataFrameBitmap}"
                                               Stretch="None"
                                               RenderOptions.BitmapInterpolationMode="None"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Right: frame list + info -->
                        <Border Grid.Column="2"
                                Background="#20262E"
                                BorderBrush="#343B46"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10">
                            <Grid RowDefinitions="Auto,170,Auto,Auto,*"
                                  RowSpacing="8">

                                <StackPanel Grid.Row="0"
                                            Spacing="4">
                                    <TextBlock Text="AnimData Info"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2" />

                                    <TextBlock Text="{Binding SelectedAnimDataEntry.DisplayText}"
                                               Foreground="#C7D1DB"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="{Binding SelectedAnimDataEntry.SecondaryText}"
                                               Foreground="#AAB4C0"
                                               FontSize="12"
                                               TextWrapping="Wrap" />

                                    <Grid ColumnDefinitions="*,*"
                                          RowDefinitions="Auto,Auto,Auto,Auto"
                                          ColumnSpacing="8"
                                          RowSpacing="6"
                                          Margin="0,8,0,0">
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Unknown"
                                                   Foreground="#AAB4C0" />

                                        <NumericUpDown Grid.Row="0"
                                                       Grid.Column="1"
                                                       Minimum="0"
                                                       Maximum="255"
                                                       Value="{Binding SelectedAnimDataEntry.Unknown}" />

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="Frame Count"
                                                   Foreground="#AAB4C0" />

                                        <NumericUpDown Grid.Row="1"
                                                       Grid.Column="1"
                                                       Minimum="0"
                                                       Maximum="64"
                                                       Value="{Binding SelectedAnimDataEntry.FrameCount}" />

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Text="Frame Interval"
                                                   Foreground="#AAB4C0" />

                                        <NumericUpDown Grid.Row="2"
                                                       Grid.Column="1"
                                                       Minimum="0"
                                                       Maximum="255"
                                                       Value="{Binding SelectedAnimDataEntry.FrameInterval}" />

                                        <TextBlock Grid.Row="3"
                                                   Grid.Column="0"
                                                   Text="Frame Start"
                                                   Foreground="#AAB4C0" />

                                        <NumericUpDown Grid.Row="3"
                                                       Grid.Column="1"
                                                       Minimum="0"
                                                       Maximum="255"
                                                       Value="{Binding SelectedAnimDataEntry.FrameStart}" />
                                    </Grid>
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Background="#151A20"
                                        BorderBrush="#343B46"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <ListBox ItemsSource="{Binding SelectedAnimDataEntry.Frames}"
                                             SelectedItem="{Binding SelectedAnimDataFrame}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="6,4">
                                                    <TextBlock Text="{Binding DisplayText}"
                                                               Foreground="#E4EAF2" />
                                                    <TextBlock Text="{Binding StatusText}"
                                                               FontSize="11"
                                                               Foreground="#AAB4C0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>

                                <Grid Grid.Row="2"
                                      RowDefinitions="Auto,Auto"
                                      RowSpacing="5"
                                      Margin="0,2,0,4">

                                    <Grid Grid.Row="0"
                                          ColumnDefinitions="90,Auto,58,78"
                                          ColumnSpacing="6">
                                        <TextBox Grid.Column="0"
                                                 Watermark="0x091E"
                                                 Text="{Binding AnimDataAddFrameGraphicText}" />

                                        <CheckBox Grid.Column="1"
                                                  Content="Rel"
                                                  IsChecked="{Binding AnimDataAddFrameRelative}"
                                                  VerticalAlignment="Center" />

                                        <Button Grid.Column="2"
                                                Content="Add"
                                                Command="{Binding AddAnimDataFrameCommand}" />

                                        <Button Grid.Column="3"
                                                Content="Remove"
                                                Command="{Binding RemoveAnimDataFrameCommand}" />
                                    </Grid>

                                    <Grid Grid.Row="1"
                                          ColumnDefinitions="*,*,*"
                                          ColumnSpacing="6">
                                        <Button Grid.Column="0"
                                                Content="Move Up"
                                                Command="{Binding MoveAnimDataFrameUpCommand}" />

                                        <Button Grid.Column="1"
                                                Content="Move Down"
                                                Command="{Binding MoveAnimDataFrameDownCommand}" />

                                        <Button Grid.Column="2"
                                                Content="Play"
                                                Command="{Binding ToggleAnimDataAnimationCommand}" />
                                    </Grid>
                                </Grid>

                                <Border Grid.Row="3"
                                        Height="1"
                                        Background="#343B46"
                                        Margin="0,4" />

                                <ScrollViewer Grid.Row="4"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel Spacing="12">

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Base TileData"
                                                       FontWeight="Bold"
                                                       Foreground="#E4EAF2" />

                                            <TextBlock Text="{Binding SelectedAnimDataTileDataEntry.DisplayText}"
                                                       Foreground="#C7D1DB"
                                                       TextWrapping="Wrap" />

                                            <TextBlock Text="{Binding SelectedAnimDataTileDataEntry.Flags, StringFormat='Flags: 0x{0:X16}'}"
                                                       Foreground="#AAB4C0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Frame TileData"
                                                       FontWeight="Bold"
                                                       Foreground="#E4EAF2" />

                                            <TextBlock Text="{Binding SelectedAnimDataFrameTileDataEntry.DisplayText}"
                                                       Foreground="#C7D1DB"
                                                       TextWrapping="Wrap" />

                                            <TextBlock Text="{Binding SelectedAnimDataFrameTileDataEntry.Flags, StringFormat='Flags: 0x{0:X16}'}"
                                                       Foreground="#AAB4C0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Wearable Editor -->
                <Grid Grid.Column="0"
                      Grid.ColumnSpan="3"
                      IsVisible="{Binding ShowWearableWizardPanel}"
                      RowDefinitions="Auto,*"
                      Margin="-270,10,10,10"
                      RowSpacing="10"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">

                    <TextBlock Grid.Row="0"
                               Text="Wearable Creation Wizard"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#E4EAF2"/>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="410,*,520"
                          ColumnSpacing="12"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">

                        <!-- LEFT: Setup -->
                        <Border Grid.Column="0"
                                Background="#20242B"
                                BorderBrush="#303844"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">

                            <ScrollViewer>
                                <StackPanel Spacing="8">

                                    <TextBlock Text="Basic Info" FontWeight="Bold" Foreground="#E4EAF2"/>

                                    <TextBlock Text="Name" Foreground="#AAB4C0"/>
                                    <TextBox Text="{Binding WearableWizardName, Mode=TwoWay}"/>

                                    <TextBlock Text="Wearable Type" Foreground="#AAB4C0"/>
                                    <ComboBox ItemsSource="{Binding WearableWizardTypes}"
                                              SelectedItem="{Binding WearableWizardType, Mode=TwoWay}"/>

                                    <TextBlock Text="Layer" Foreground="#AAB4C0"/>
                                    <ComboBox ItemsSource="{Binding WearableWizardLayers}"
                                              SelectedItem="{Binding WearableWizardLayer, Mode=TwoWay}"/>

                                    <Separator Margin="0,8,0,8"/>

                                    <TextBlock Text="Images" FontWeight="Bold" Foreground="#E4EAF2"/>

                                    <Button Content="Load Male / Default Paperdoll Image"
                                            Command="{Binding BrowseWearablePaperdollImageCommand}"/>
                                    <TextBlock Text="{Binding WearableWizardPaperdollImagePath}"
                                               Foreground="#AAB4C0"
                                               TextWrapping="Wrap"
                                               MaxHeight="40"/>

                                    <CheckBox Content="Create female variant"
                                              IsChecked="{Binding WearableWizardCreateFemaleVariant, Mode=TwoWay}"/>

                                    <Button Content="Load Female Paperdoll Image"
                                            Command="{Binding BrowseWearableFemalePaperdollImageCommand}"/>
                                    <TextBlock Text="{Binding WearableWizardFemalePaperdollImagePath}"
                                               Foreground="#AAB4C0"
                                               TextWrapping="Wrap"
                                               MaxHeight="40"/>

                                    <Button Content="Load Inventory / World Art Image"
                                            Command="{Binding BrowseWearableArtImageCommand}"/>
                                    <TextBlock Text="{Binding WearableWizardArtImagePath}"
                                               Foreground="#AAB4C0"
                                               TextWrapping="Wrap"
                                               MaxHeight="40"/>

                                    <Separator Margin="0,8,0,8"/>

                                    <TextBlock Text="Slot Planning" FontWeight="Bold" Foreground="#E4EAF2"/>

                                    <Border Background="#3A2020"
                                            BorderBrush="#AA5555"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8"
                                            IsVisible="{Binding WearableWizardMaleGumpConflict}">
                                        <TextBlock Text="{Binding WearableWizardConflictText}"
                                                   Foreground="#FFB0B0"
                                                   TextWrapping="Wrap"/>
                                    </Border>

                                    <CheckBox Content="Use sitting-safe wearable range 50400-50999"
                                              IsChecked="{Binding WearableWizardUseSittingSafeRange, Mode=TwoWay}"/>

                                    <CheckBox Content="Partial hueable"
                                              IsChecked="{Binding WearableWizardPartialHue, Mode=TwoWay}"/>

                                    <Button Content="Auto Pick Free IDs"
                                            Command="{Binding AutoPickWearableWizardIdsCommand}"/>

                                    <Grid ColumnDefinitions="*,*"
                                          RowDefinitions="Auto,Auto,Auto,Auto"
                                          ColumnSpacing="8"
                                          RowSpacing="6">

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Male Gump ID" Foreground="#AAB4C0"/>
                                        <NumericUpDown Grid.Row="0" Grid.Column="1"
                                                       Value="{Binding WearableWizardMaleGumpId, Mode=TwoWay}"
                                                       Minimum="50000"
                                                       Maximum="50999"
                                                       Increment="1"
                                                       FormatString="0"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Female Gump ID" Foreground="#AAB4C0"/>
                                        <NumericUpDown Grid.Row="1" Grid.Column="1"
                                                       Value="{Binding WearableWizardFemaleGumpId, Mode=TwoWay}"
                                                       Minimum="60000"
                                                       Maximum="60999"
                                                       Increment="1"
                                                       FormatString="0"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Art ID" Foreground="#AAB4C0"/>
                                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                                       Value="{Binding WearableWizardArtId, Mode=TwoWay}"
                                                       Minimum="50000"
                                                       Maximum="50999"
                                                       Increment="1"
                                                       FormatString="0"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Animation ID" Foreground="#AAB4C0"/>
                                        <NumericUpDown Grid.Row="3" Grid.Column="1"
                                                       Value="{Binding WearableWizardAnimationId, Mode=TwoWay}"
                                                       Minimum="0"
                                                       Maximum="9999"
                                                       Increment="1"
                                                       FormatString="0"/>
                                    </Grid>

                                    <Separator Margin="0,8,0,8"/>

                                    <TextBlock Text="Animation Attachment" FontWeight="Bold" Foreground="#E4EAF2"/>

                                    <ComboBox ItemsSource="{Binding WearableWizardAnimationModes}"
                                              SelectedItem="{Binding WearableWizardAnimationMode, Mode=TwoWay}"/>

                                    <TextBlock Text="Existing Animation ID" Foreground="#AAB4C0"/>
                                    <NumericUpDown Value="{Binding WearableWizardExistingAnimationId, Mode=TwoWay}"
                                                   Minimum="0"
                                                   Maximum="9999"
                                                   Increment="1"
                                                   FormatString="0"/>

                                    <TextBlock Text="Body.def Hue" Foreground="#AAB4C0"/>
                                    <TextBox Text="{Binding WearableWizardHue, Mode=TwoWay}"/>

                                    <Separator Margin="0,8,0,8"/>

                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                        <Button Grid.Column="0" Content="Rebuild" Command="{Binding RebuildWearableWizardPlanCommand}"/>
                                        <Button Grid.Column="1" Content="Reset" Command="{Binding ResetWearableWizardCommand}"/>
                                        <Button Grid.Column="2" Content="Apply" Command="{Binding ApplyWearableWizardCommand}"/>
                                    </Grid>

                                    <TextBlock Text="{Binding WearableWizardStatusText}"
                                               Foreground="#AAB4C0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- CENTER: Big Preview -->
                        <Border Grid.Column="1"
                                Background="#20242B"
                                BorderBrush="#303844"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">

                            <Grid RowDefinitions="150,*"
                                  RowSpacing="10">

                                <!-- Image previews -->
                                <Border Grid.Row="0"
                                        Background="#15191F"
                                        BorderBrush="#303844"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8">

                                    <Grid RowDefinitions="Auto,*" RowSpacing="6">
                                        <TextBlock Grid.Row="0"
                                                   Text="Image Previews"
                                                   FontWeight="Bold"
                                                   Foreground="#E4EAF2"/>

                                        <Grid Grid.Row="1"
                                              ColumnDefinitions="*,*,*"
                                              ColumnSpacing="8">

                                            <Border Grid.Column="0" Background="#101318" BorderBrush="#303844" BorderThickness="1" CornerRadius="4" Padding="6">
                                                <StackPanel>
                                                    <TextBlock Text="Male" HorizontalAlignment="Center" Foreground="#AAB4C0"/>
                                                    <Image Source="{Binding WearableWizardPaperdollPreview}" Stretch="Uniform" MaxHeight="95"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1" Background="#101318" BorderBrush="#303844" BorderThickness="1" CornerRadius="4" Padding="6">
                                                <StackPanel>
                                                    <TextBlock Text="Female" HorizontalAlignment="Center" Foreground="#AAB4C0"/>
                                                    <Image Source="{Binding WearableWizardFemalePaperdollPreview}" Stretch="Uniform" MaxHeight="95"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2" Background="#101318" BorderBrush="#303844" BorderThickness="1" CornerRadius="4" Padding="6">
                                                <StackPanel>
                                                    <TextBlock Text="Art" HorizontalAlignment="Center" Foreground="#AAB4C0"/>
                                                    <Image Source="{Binding WearableWizardArtPreview}" Stretch="Uniform" MaxHeight="95"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- Animation preview -->
                                <Border Grid.Row="1"
                                        Background="#15191F"
                                        BorderBrush="#303844"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8">

                                    <Grid RowDefinitions="Auto,Auto,*,Auto"
                                          RowSpacing="8">

                                        <Grid Grid.Row="0"
                                              ColumnDefinitions="*,Auto"
                                              ColumnSpacing="8">

                                            <TextBlock Grid.Column="0"
                                                       Text="Wearable Animation Overlay Preview"
                                                       FontWeight="Bold"
                                                       Foreground="#E4EAF2"/>

                                            <CheckBox Grid.Column="1"
                                                      Content="Enabled"
                                                      IsChecked="{Binding WearableWizardOverlayPreviewEnabled, Mode=TwoWay}"/>
                                        </Grid>

                                        <StackPanel Grid.Row="1"
                                                    Spacing="6">

                                            <Grid ColumnDefinitions="Auto,110,Auto,110,Auto,110"
                                                  ColumnSpacing="8">

                                                <TextBlock Grid.Column="0"
                                                           Text="Base"
                                                           VerticalAlignment="Center"
                                                           Foreground="#AAB4C0"/>
                                                <NumericUpDown Grid.Column="1"
                                                               Width="110"
                                                               Value="{Binding WearableWizardPreviewBaseBodyId, Mode=TwoWay}"
                                                               Minimum="0"
                                                               Maximum="9999"
                                                               Increment="1"
                                                               FormatString="0"/>

                                                <TextBlock Grid.Column="2"
                                                           Text="Action"
                                                           VerticalAlignment="Center"
                                                           Foreground="#AAB4C0"/>
                                                <NumericUpDown Grid.Column="3"
                                                               Width="110"
                                                               Value="{Binding WearableWizardPreviewAction, Mode=TwoWay}"
                                                               Minimum="0"
                                                               Maximum="34"
                                                               Increment="1"
                                                               FormatString="0"/>

                                                <TextBlock Grid.Column="4"
                                                           Text="Dir"
                                                           VerticalAlignment="Center"
                                                           Foreground="#AAB4C0"/>
                                                <NumericUpDown Grid.Column="5"
                                                               Width="110"
                                                               Value="{Binding WearableWizardPreviewDirection, Mode=TwoWay}"
                                                               Minimum="0"
                                                               Maximum="4"
                                                               Increment="1"
                                                               FormatString="0"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="Auto,110,Auto,110,Auto,110,Auto,110"
                                                  ColumnSpacing="8">

                                                <TextBlock Grid.Column="0"
                                                           Text="Frame"
                                                           VerticalAlignment="Center"
                                                           Foreground="#AAB4C0"/>
                                                <NumericUpDown Grid.Column="1"
                                                               Width="110"
                                                               Value="{Binding WearableWizardPreviewFrameIndex, Mode=TwoWay}"
                                                               Minimum="0"
                                                               Maximum="99"
                                                               Increment="1"
                                                               FormatString="0"/>

                                                <TextBlock Grid.Column="2"
                                                           Text="X"
                                                           VerticalAlignment="Center"
                                                           Foreground="#AAB4C0"/>
                                                <NumericUpDown Grid.Column="3"
                                                               Width="110"
                                                               Value="{Binding WearableWizardOverlayOffsetX, Mode=TwoWay}"
                                                               Minimum="-500"
                                                               Maximum="500"
                                                               Increment="1"
                                                               FormatString="0"/>

                                                <TextBlock Grid.Column="4"
                                                           Text="Y"
                                                           VerticalAlignment="Center"
                                                           Foreground="#AAB4C0"/>
                                                <NumericUpDown Grid.Column="5"
                                                               Width="110"
                                                               Value="{Binding WearableWizardOverlayOffsetY, Mode=TwoWay}"
                                                               Minimum="-500"
                                                               Maximum="500"
                                                               Increment="1"
                                                               FormatString="0"/>

                                                <TextBlock Grid.Column="6"
                                                           Text="Scale"
                                                           VerticalAlignment="Center"
                                                           Foreground="#AAB4C0"/>
                                                <NumericUpDown Grid.Column="7"
                                                               Width="110"
                                                               Value="{Binding WearableWizardOverlayScale, Mode=TwoWay}"
                                                               Minimum="0.1"
                                                               Maximum="5"
                                                               Increment="0.1"
                                                               FormatString="0.0"/>
                                            </Grid>
                                        </StackPanel>

                                        <Border Grid.Row="2"
                                                Background="#101318"
                                                BorderBrush="#303844"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="6">

                                            <Image Source="{Binding WearableWizardOverlayPreviewBitmap}"
                                                   Stretch="Uniform"/>
                                        </Border>

                                        <Grid Grid.Row="3"
                                              ColumnDefinitions="*,Auto"
                                              ColumnSpacing="8">

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding WearableWizardOverlayPreviewStatus}"
                                                       Foreground="#AAB4C0"
                                                       TextWrapping="Wrap"/>

                                            <Button Grid.Column="1"
                                                    Content="Refresh Preview"
                                                    Command="{Binding RefreshWearableWizardOverlayPreviewCommand}"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- RIGHT: Plan + Browsers -->
                        <Grid Grid.Column="2"
                              RowDefinitions="260,*"
                              RowSpacing="10">

                            <Border Grid.Row="0"
                                    Background="#15191F"
                                    BorderBrush="#303844"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12">

                                <Grid RowDefinitions="Auto,*"
                                      RowSpacing="8">

                                    <TextBlock Grid.Row="0"
                                               Text="Planned Changes"
                                               FontWeight="Bold"
                                               Foreground="#E4EAF2"/>

                                    <TextBox Grid.Row="1"
                                             Text="{Binding WearableWizardPlanText}"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             FontFamily="Consolas"
                                             Background="#101318"
                                             Foreground="#DDE6F0"/>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1"
                                  RowDefinitions="*,*"
                                  RowSpacing="10">

                                <Border Grid.Row="0"
                                        Background="#15191F"
                                        BorderBrush="#303844"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8">

                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto"
                                          RowSpacing="6">

                                        <TextBlock Grid.Row="0"
                                                   Text="Free Animation Slot Browser"
                                                   FontWeight="Bold"
                                                   Foreground="#E4EAF2"/>

                                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <ComboBox Grid.Column="0"
                                                      ItemsSource="{Binding WearableWizardSlotFileOptions}"
                                                      SelectedItem="{Binding WearableWizardSelectedSlotFile, Mode=TwoWay}"/>

                                            <Button Grid.Column="1"
                                                    Content="Refresh"
                                                    Command="{Binding RefreshWearableWizardFreeSlotsCommand}"/>
                                        </Grid>

                                        <TextBox Grid.Row="2"
                                                 Watermark="Search body/file/type..."
                                                 Text="{Binding WearableWizardSlotSearchText, Mode=TwoWay}"/>

                                        <WrapPanel Grid.Row="3">
                                            <CheckBox Content="H (Monster)" Margin="0,0,12,0" IsChecked="{Binding WearableWizardSlotShowHFilter, Mode=TwoWay}"/>
                                            <CheckBox Content="L (Animal)" Margin="0,0,12,0" IsChecked="{Binding WearableWizardSlotShowLFilter, Mode=TwoWay}"/>
                                            <CheckBox Content="P (Human/Equip)" IsChecked="{Binding WearableWizardSlotShowPFilter, Mode=TwoWay}"/>
                                        </WrapPanel>

                                        <ListBox Grid.Row="4"
                                                 ItemsSource="{Binding WearableWizardFreeSlots}"
                                                 SelectedItem="{Binding WearableWizardSelectedFreeSlot, Mode=TwoWay}">

                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid ColumnDefinitions="45,70,*,70" ColumnSpacing="8" Margin="2">
                                                        <TextBlock Grid.Column="0" Text="{Binding TypeLetter}" Foreground="#E4EAF2" FontWeight="Bold"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding BodyIndex}" Foreground="#DDE6F0"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding FileName}" Foreground="#AAB4C0"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding TrueBodyId}" Foreground="#8FD18F"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <Button Grid.Row="5"
                                                Content="Use Selected Slot"
                                                HorizontalAlignment="Left"
                                                Command="{Binding UseWearableWizardSelectedSlotCommand}"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1"
                                        Background="#15191F"
                                        BorderBrush="#303844"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8">

                                    <Grid RowDefinitions="Auto,Auto,*,Auto"
                                          RowSpacing="6">

                                        <TextBlock Grid.Row="0"
                                                   Text="Existing Animation Source Browser"
                                                   FontWeight="Bold"
                                                   Foreground="#E4EAF2"/>

                                        <TextBox Grid.Row="1"
                                                 Watermark="Search P-slot animations..."
                                                 Text="{Binding WearableWizardSourceAnimationSearchText, Mode=TwoWay}"/>

                                        <ListBox Grid.Row="2"
                                                 ItemsSource="{Binding WearableWizardSourceAnimations}"
                                                 SelectedItem="{Binding WearableWizardSelectedSourceAnimation, Mode=TwoWay}">

                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid ColumnDefinitions="70,*,120" ColumnSpacing="8" Margin="2">
                                                        <TextBlock Grid.Column="0" Text="{Binding BodyId}" Foreground="#8FD18F" FontWeight="Bold"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="#DDE6F0"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding SourceFile}" Foreground="#AAB4C0"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <Button Grid.Row="3"
                                                Content="Use Selected Source Animation"
                                                HorizontalAlignment="Left"
                                                Command="{Binding UseWearableWizardSourceAnimationCommand}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
                <!-- Normal Editor Preview -->
                <Grid Grid.Column="0"
                      RowDefinitions="Auto,*"
                      IsVisible="{Binding ShowAnimationEditorPanel}">
                    <TextBlock Grid.Row="0"
                               Text="Preview"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10" />

                    <Border Grid.Row="1"
                            Background="Transparent"
                            BorderThickness="0">
                        <Grid RowDefinitions="*,Auto,Auto">

                            <Grid Grid.Row="0">

                                <!-- Single full-width preview -->
                                <Border x:Name="PreviewDropBorder"
                                        Background="{Binding PreviewBackgroundBrush}"
                                        BorderBrush="#343B46"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12"
                                        PointerPressed="PreviewDragSurface_PointerPressed"
                                        PointerMoved="PreviewDragSurface_PointerMoved"
                                        PointerReleased="PreviewDragSurface_PointerReleased"
                                        PointerCaptureLost="PreviewDragSurface_PointerCaptureLost"
                                        DragDrop.AllowDrop="True"
                                        IsVisible="{Binding ShowSinglePreviewOnly}">
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                        <Grid HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              MinHeight="420">
                                            <Image Source="{Binding PreviewBitmap}"
                                                   Width="{Binding PreviewImageWidth}"
                                                   Height="{Binding PreviewImageHeight}"
                                                   Stretch="Fill" />
                                        </Grid>
                                    </ScrollViewer>
                                </Border>

                                <!-- Split preview -->
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="12"
                                      IsVisible="{Binding ShowSplitPreview}">

                                    <Border Grid.Column="0"
                                            Background="{Binding PreviewBackgroundBrush}"
                                            BorderBrush="#343B46"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12"
                                            PointerPressed="PreviewDragSurface_PointerPressed"
                                            PointerMoved="PreviewDragSurface_PointerMoved"
                                            PointerReleased="PreviewDragSurface_PointerReleased"
                                            PointerCaptureLost="PreviewDragSurface_PointerCaptureLost"
                                            DragDrop.AllowDrop="True">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto">
                                            <Grid HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  MinHeight="420">
                                                <Image Source="{Binding PreviewBitmap}"
                                                       Width="{Binding PreviewImageWidth}"
                                                       Height="{Binding PreviewImageHeight}"
                                                       Stretch="Fill" />
                                            </Grid>
                                        </ScrollViewer>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Background="{Binding PreviewBackgroundBrush}"
                                            BorderBrush="#343B46"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto">
                                            <Grid HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  MinHeight="420">
                                                <Image Source="{Binding CompareSidePreviewBitmap}"
                                                       Width="{Binding ComparePreviewImageWidth}"
                                                       Height="{Binding ComparePreviewImageHeight}"
                                                       Stretch="Fill" />
                                            </Grid>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Grid>

                            <Border Grid.Row="1"
                                    Margin="0,10,0,8"
                                    Background="#171C22"
                                    BorderBrush="#2D3641"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,8">

                                <Grid>
                                    <!-- Single info -->
                                    <StackPanel Spacing="4"
                                                HorizontalAlignment="Center"
                                                IsVisible="{Binding ShowSinglePreviewOnly}">
                                        <TextBlock Text="{Binding CurrentFrameDisplayText}"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#E3E8EE"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding PreviewInfoText}"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#C7D1DB"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="780" />
                                    </StackPanel>

                                    <!-- Split info -->
                                    <Grid ColumnDefinitions="*,*"
                                          ColumnSpacing="12"
                                          IsVisible="{Binding ShowSplitPreview}">
                                        <StackPanel Grid.Column="0"
                                                    Spacing="4"
                                                    HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding CurrentFrameDisplayText}"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#E3E8EE"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding PreviewInfoText}"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#C7D1DB"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       MaxWidth="380" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Spacing="4"
                                                    HorizontalAlignment="Center">
                                            <TextBlock Text="Compare Preview"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#E3E8EE"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding CompareSidePreviewInfoText}"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#C7D1DB"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       MaxWidth="380" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <ListBox Grid.Row="2"
                                     x:Name="ThumbnailList"
                                     Classes="thumbnailList"
                                     ItemsSource="{Binding FrameThumbnails}"
                                     SelectedItem="{Binding SelectedFrameThumbnail, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Bottom"
                                     IsVisible="{Binding HasFrameThumbnails}"
                                     MaxHeight="110">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Classes="thumbCard"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Tag="{Binding $parent[ListBox].DataContext}">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Replace"
                                                              Click="ReplaceThumbnailMenuItem_Click"
                                                              Tag="{Binding}" />
                                                    <MenuItem Header="Remove"
                                                              Click="RemoveThumbnailMenuItem_Click"
                                                              Tag="{Binding}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>

                                            <StackPanel Spacing="4"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Top">
                                                <Border Classes="thumbImageHost">
                                                    <Image Source="{Binding Bitmap}"
                                                           Width="38"
                                                           Height="38"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                                </Border>

                                                <TextBlock Classes="thumbLabel"
                                                           Text="{Binding DisplayText}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            <!-- right -->
            <Border Grid.Column="2"
                    IsVisible="{Binding ShowAnimationEditorPanel}"
                    Background="#1E232A"
                    BorderBrush="#343B46"
                    BorderThickness="1,0,0,0"
                    Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">

                        <TextBlock Text="Details"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <Border Classes="card"
                                Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Playback"
                                           FontWeight="Bold" />

                                <WrapPanel Orientation="Horizontal"
                                           VerticalAlignment="Center">
                                    <Button Command="{Binding PlayCommand}"
                                            Width="40"
                                            Height="32"
                                            Margin="0,0,6,0"
                                            ToolTip.Tip="Play">
                                        <PathIcon Data="M 3 2 L 3 14 L 13 8 Z"
                                                  Width="14"
                                                  Height="14" />
                                    </Button>

                                    <Button Command="{Binding PauseCommand}"
                                            Width="40"
                                            Height="32"
                                            Margin="0,0,6,0"
                                            ToolTip.Tip="Pause">
                                        <PathIcon Data="M 3 2 H 6 V 14 H 3 Z M 10 2 H 13 V 14 H 10 Z"
                                                  Width="14"
                                                  Height="14" />
                                    </Button>

                                    <Button Command="{Binding PreviousFrameCommand}"
                                            Width="40"
                                            Height="32"
                                            Margin="0,0,6,0"
                                            ToolTip.Tip="Previous frame">
                                        <PathIcon Data="M 11 2 L 3 8 L 11 14 Z M 12 2 H 14 V 14 H 12 Z"
                                                  Width="14"
                                                  Height="14" />
                                    </Button>

                                    <Button Command="{Binding NextFrameCommand}"
                                            Width="40"
                                            Height="32"
                                            Margin="0,0,10,0"
                                            ToolTip.Tip="Next frame">
                                        <PathIcon Data="M 3 2 L 11 8 L 3 14 Z M 12 2 H 14 V 14 H 12 Z"
                                                  Width="14"
                                                  Height="14" />
                                    </Button>
                                </WrapPanel>

                                <Grid ColumnDefinitions="Auto,* ,Auto"
                                      ColumnSpacing="8">
                                    <TextBlock Grid.Column="0"
                                               Text="Speed"
                                               VerticalAlignment="Center" />

                                    <Slider Grid.Column="1"
                                            Minimum="1"
                                            Maximum="20"
                                            Value="{Binding PlaybackSpeed}"
                                            TickFrequency="1" />

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding PlaybackSpeedText}"
                                               Width="40"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="card"
                                Padding="10"
                                IsVisible="{Binding ShowAnimationView}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Animation Details"
                                           FontWeight="Bold" />
                                <Grid ColumnDefinitions="96,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedAnimationName}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Body ID:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedBodyId}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Action ID:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedActionId}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Frames:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedFrameCount}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Size:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedFrameSize}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Source:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedAnimationSource}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Index:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedIndexNumber}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Offset:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedOffset}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Length:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedLength}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Extra:" Margin="0,0,10,0" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding SelectedExtra}" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="card"
                                Padding="10"
                                IsVisible="{Binding ShowMulSlotList}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="MUL Slot Details"
                                           FontWeight="Bold" />
                                <Grid ColumnDefinitions="96,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="File:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedMulSlotFile}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Body Index:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedMulSlotIndex}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="True Body:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedMulSlotOffset}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Anim Length:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedMulSlotLength}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Type:" Margin="0,0,10,0" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedMulSlotExtra}" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="card"
                                Padding="10"
                                IsVisible="{Binding ShowUopSlotList}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="UOP Target Details"
                                           FontWeight="Bold" />
                                <Grid ColumnDefinitions="96,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="File:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedUopBodyFile}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Body ID:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedUopBodyId}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Body Type:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedUopBodyType}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Actions:" Margin="0,0,10,0" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedUopBodyActionCount}" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Expander Header="UOP Sequence / Remap"
                                  IsVisible="{Binding ShowUopSequenceDetails}">
                            <Border Classes="card"
                                    Padding="10"
                                    Margin="0,6,0,0">
                                <Grid ColumnDefinitions="96,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Req Action:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedSequenceRequestedAction}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Resolved:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedSequenceResolvedGroup}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Remap:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedSequenceRemap}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Seq Frames:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedSequenceFrameCount}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Body Map:" Margin="0,0,10,6" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedSequenceBodyMapping}" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="UOP Path:" Margin="0,0,10,0" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedUopVirtualPathDisplay}" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                        </Expander>

                        <Border Classes="detailCard"
                                Margin="0,0,0,10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Compare Overlay"
                                           FontWeight="SemiBold"
                                           Foreground="#D5DCE4" />

                                <Grid ColumnDefinitions="Auto,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                      ColumnSpacing="10"
                                      RowSpacing="4">

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Enabled:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding CompareOverlayEnabled}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="Target:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding CompareOverlayTargetText}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Action:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding CompareOverlayActionIndex}" />

                                    <TextBlock Grid.Row="3" Grid.Column="0"
                                               Text="Direction:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                               Text="{Binding CompareOverlayDirectionIndex}" />

                                    <TextBlock Grid.Row="4" Grid.Column="0"
                                               Text="Frame Mode:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="4" Grid.Column="1"
                                               Text="{Binding CompareOverlayFrameModeText}" />

                                    <TextBlock Grid.Row="5" Grid.Column="0"
                                               Text="Offset:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="5" Grid.Column="1"
                                               Text="{Binding CompareOverlayOffsetText}" />

                                    <TextBlock Grid.Row="6" Grid.Column="0"
                                               Text="Opacity:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="6" Grid.Column="1"
                                               Text="{Binding CompareOverlayOpacityText}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="File:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding CompareOverlayFileText}" />
                                    <TextBlock Grid.Row="7" Grid.Column="0"
                                               Text="Pose:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="7" Grid.Column="1"
                                               Text="{Binding CurrentComparePoseText}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="detailCard"
                                Margin="0,0,0,10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Prop Overlay"
                                           FontWeight="SemiBold"
                                           Foreground="#D5DCE4" />

                                <Grid ColumnDefinitions="Auto,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                      ColumnSpacing="10"
                                      RowSpacing="4">

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Enabled:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding PropOverlayEnabled}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="Source:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding PropOverlaySourceText}"
                                               TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Offset:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding PropOverlayOffsetText}" />

                                    <TextBlock Grid.Row="3" Grid.Column="0"
                                               Text="Scale:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                               Text="{Binding PropOverlayScaleText}" />

                                    <TextBlock Grid.Row="4" Grid.Column="0"
                                               Text="Rotation:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="4" Grid.Column="1"
                                               Text="{Binding PropOverlayRotationText}" />

                                    <TextBlock Grid.Row="5" Grid.Column="0"
                                               Text="Layer:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="5" Grid.Column="1"
                                               Text="{Binding PropOverlayLayerText}" />

                                    <TextBlock Grid.Row="6" Grid.Column="0"
                                               Text="Pivot:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="6" Grid.Column="1"
                                               Text="{Binding PropOverlayPivotText}" />

                                    <TextBlock Grid.Row="7" Grid.Column="0"
                                               Text="Pose:"
                                               Foreground="#9FB2C8" />
                                    <TextBlock Grid.Row="7" Grid.Column="1"
                                               Text="{Binding CurrentPropPoseText}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="card"
                                Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Debug"
                                           FontWeight="Bold" />

                                <WrapPanel Orientation="Horizontal">
                                    <Button Content="Open Debug Window"
                                            Command="{Binding PopOutDebugCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- loading overlay -->
        <Border IsVisible="{Binding IsLoading}"
                Grid.RowSpan="99"
                Background="#AA111317"
                ZIndex="9999">
            <Grid HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
                <Border Width="520"
                        MaxWidth="520"
                        Padding="22"
                        CornerRadius="12"
                        Background="#25282D"
                        BorderBrush="#3A3F46"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Loading Animation Data"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#F2F2F2" />

                        <TextBlock Text="{Binding LoadingText}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="#D8D8D8" />

                        <ProgressBar Minimum="0"
                                     Maximum="100"
                                     Value="{Binding LoadingProgress}"
                                     Height="18" />

                        <TextBlock Text="{Binding LoadingProgress, StringFormat={}{0:0}%}"
                                   HorizontalAlignment="Center"
                                   Foreground="#9BB7D3"
                                   FontWeight="SemiBold" />

                        <Border Background="#1C1F24"
                                BorderBrush="#35393F"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Tip"
                                           FontWeight="Bold"
                                           Foreground="#F2C14E" />

                                <TextBlock Text="{Binding LoadingTipText}"
                                           TextWrapping="Wrap"
                                           Foreground="#D8D8D8" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>