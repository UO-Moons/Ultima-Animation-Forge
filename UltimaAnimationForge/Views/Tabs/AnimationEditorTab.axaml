<UserControl
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:vm="clr-namespace:UltimaAnimationForge.ViewModels"
xmlns:converters="clr-namespace:UltimaAnimationForge.Converters"
x:Class="UltimaAnimationForge.Views.Tabs.AnimationEditorTab"
x:DataType="vm:MainWindowViewModel">

    <UserControl.Resources>
        <converters:BoolToSelectionBrushConverter x:Key="BoolToSelectionBrushConverter"/>
        <converters:IsMulMultiSourceConverter x:Key="IsMulMultiSourceConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#E7ECF2"/>
        </Style>

        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#95A3B3"/>
        </Style>

        <Style Selector="TextBlock.panelTitle">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#F2F6FA"/>
        </Style>

        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#CFE0F4"/>
        </Style>

        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#151A20"/>
            <Setter Property="BorderBrush" Value="#2C3440"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="#1B222B"/>
            <Setter Property="BorderBrush" Value="#303A46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style Selector="Border.selectionBar">
            <Setter Property="Background" Value="#3AA675"/>
        </Style>

        <Style Selector="TextBlock.subtleText">
            <Setter Property="Foreground" Value="#93A1B2"/>
        </Style>

        <Style Selector="Button.iconButton">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style Selector="Border.thumbCard">
            <Setter Property="Background" Value="#202832"/>
            <Setter Property="BorderBrush" Value="#384555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style Selector="Border.thumbImageHost">
            <Setter Property="Background" Value="#101419"/>
            <Setter Property="BorderBrush" Value="#2B3541"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Width" Value="54"/>
            <Setter Property="Height" Value="54"/>
        </Style>

        <Style Selector="TextBlock.thumbLabel">
            <Setter Property="Foreground" Value="#C8D4E0"/>
        </Style>

        <Style Selector="ListBox.thumbnailList ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="ListBox.thumbnailList ListBoxItem:selected Border.thumbCard">
            <Setter Property="BorderBrush" Value="#1E90FF"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="#263446"/>
        </Style>

        <Style Selector="ListBox.thumbnailList ListBoxItem:pointerover Border.thumbCard">
            <Setter Property="BorderBrush" Value="#5A6C82"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Background="#0D1117">

        <!-- TOP COMMAND BAR -->
        <Border Grid.Row="0"
                Background="#161B22"
                BorderBrush="#2D3642"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid ColumnDefinitions="Auto,140,14,Auto,110,14,Auto,170,14,Auto,130,*,Auto"
                  ColumnSpacing="6"
                  VerticalAlignment="Center">

                <TextBlock Grid.Column="0" Text="File" VerticalAlignment="Center" Classes="muted"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AnimationFileOptions}"
                          SelectedItem="{Binding SelectedAnimationFile}"/>

                <TextBlock Grid.Column="3"
                           Text="Type"
                           VerticalAlignment="Center"
                           Classes="muted"
                           IsVisible="{Binding ShowAnimationOnlyControls}"/>
                <ComboBox Grid.Column="4"
                          ItemsSource="{Binding BodyTypeOptions}"
                          SelectedItem="{Binding SelectedBodyType}"
                          IsVisible="{Binding ShowAnimationOnlyControls}"/>

                <TextBlock Grid.Column="6"
                           Text="Action"
                           VerticalAlignment="Center"
                           Classes="muted"
                           IsVisible="{Binding ShowActionDirectionControls}"/>
                <ComboBox Grid.Column="7"
                          ItemsSource="{Binding ActionOptions}"
                          SelectedItem="{Binding SelectedAction}"
                          IsVisible="{Binding ShowActionDirectionControls}"/>

                <TextBlock Grid.Column="9"
                           Text="Direction"
                           VerticalAlignment="Center"
                           Classes="muted"
                           IsVisible="{Binding ShowActionDirectionControls}"/>
                <ComboBox Grid.Column="10"
                          ItemsSource="{Binding DirectionOptions}"
                          SelectedItem="{Binding SelectedDirection}"
                          IsVisible="{Binding ShowActionDirectionControls}"/>

                <StackPanel Grid.Column="12" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <CheckBox Content="Compare"
                              IsChecked="{Binding CompareOverlayEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center"/>
                    <CheckBox Content="Split"
                              IsChecked="{Binding CompareSideBySideEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center"/>
                    <CheckBox Content="Prop"
                              IsChecked="{Binding PropOverlayEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN EDITOR -->
        <Grid Grid.Row="1" ColumnDefinitions="300,*,340" ColumnSpacing="10" Margin="10">

            <!-- LEFT BROWSER -->
            <Border Grid.Column="0" Classes="panel" Padding="10">
                <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10">
                    <TextBlock Grid.Row="0"
                               Text="Animations"
                               Classes="panelTitle"
                               IsVisible="{Binding ShowAnimationView}"/>
                    <TextBlock Grid.Row="0"
                               Text="{Binding SlotPaneTitle}"
                               Classes="panelTitle"
                               IsVisible="{Binding ShowSlotView}"/>

                    <TextBox Grid.Row="1"
                             Watermark="Search body, slot, file..."
                             Text="{Binding SearchText}"/>

                    <Border Grid.Row="2" Classes="card" Padding="10" IsVisible="{Binding ShowMulSlotList}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Slot Filter" Classes="sectionTitle"/>
                            <WrapPanel>
                                <CheckBox Content="H Monster" IsChecked="{Binding MulSlotShowHFilter}" Margin="0,0,10,0"/>
                                <CheckBox Content="L Animal" IsChecked="{Binding MulSlotShowLFilter}" Margin="0,0,10,0"/>
                                <CheckBox Content="P Human" IsChecked="{Binding MulSlotShowPFilter}"/>
                            </WrapPanel>
                            <Button Content="Clear Selected Slot" Command="{Binding ClearSelectedMulSlotCommand}"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="3">
                        <ListBox ItemsSource="{Binding AnimationEntries}"
                                 SelectedItem="{Binding SelectedAnimation}"
                                 IsVisible="{Binding ShowAnimationView}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="card" Padding="0">
                                        <Grid ColumnDefinitions="5,*">
                                            <Border Grid.Column="0" Classes="selectionBar" CornerRadius="8,0,0,8"/>
                                            <StackPanel Grid.Column="1" Spacing="3" Margin="10,8">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding SecondaryText}" Classes="subtleText" FontSize="12" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox Name="MulSlotListBox"
                                 ItemsSource="{Binding MulSlotEntries}"
                                 SelectedItem="{Binding SelectedMulSlot}"
                                 IsVisible="{Binding ShowMulSlotList}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="card" Padding="0">
                                        <Grid ColumnDefinitions="5,*">
                                            <Border Grid.Column="0" Classes="selectionBar" CornerRadius="8,0,0,8"/>
                                            <StackPanel Grid.Column="1" Spacing="3" Margin="10,8">
                                                <TextBlock Text="{Binding DisplayText}" FontSize="15" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding FileName}" Classes="subtleText" FontSize="12"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox ItemsSource="{Binding UopBodyEntries}"
                                 SelectedItem="{Binding SelectedUopBodySlot}"
                                 IsVisible="{Binding ShowUopSlotList}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="card" Padding="0">
                                        <Grid ColumnDefinitions="5,*">
                                            <Border Grid.Column="0" Classes="selectionBar" CornerRadius="8,0,0,8"/>
                                            <StackPanel Grid.Column="1" Spacing="3" Margin="10,8">
                                                <TextBlock Text="{Binding DisplayText}" FontSize="15" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding SecondaryText}" Classes="subtleText" FontSize="12" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <!-- CENTER PREVIEW -->
            <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="10">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Viewport" Classes="panelTitle"/>
                        <TextBlock Text="{Binding CurrentFrameDisplayText}" Classes="muted" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <Button Command="{Binding PlayCommand}" Classes="iconButton" ToolTip.Tip="Play">
                            <PathIcon Data="M 3 2 L 3 14 L 13 8 Z" Width="14" Height="14"/>
                        </Button>
                        <Button Command="{Binding PauseCommand}" Classes="iconButton" ToolTip.Tip="Pause">
                            <PathIcon Data="M 3 2 H 6 V 14 H 3 Z M 10 2 H 13 V 14 H 10 Z" Width="14" Height="14"/>
                        </Button>
                        <Button Command="{Binding PreviousFrameCommand}" Classes="iconButton" ToolTip.Tip="Previous frame">
                            <PathIcon Data="M 11 2 L 3 8 L 11 14 Z M 12 2 H 14 V 14 H 12 Z" Width="14" Height="14"/>
                        </Button>
                        <Button Command="{Binding NextFrameCommand}" Classes="iconButton" ToolTip.Tip="Next frame">
                            <PathIcon Data="M 3 2 L 11 8 L 3 14 Z M 12 2 H 14 V 14 H 12 Z" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Border x:Name="PreviewDropBorder"
                            Classes="panel"
                            Background="{Binding PreviewBackgroundBrush}"
                            Padding="14"
                            PointerPressed="PreviewDragSurface_PointerPressed"
                            PointerMoved="PreviewDragSurface_PointerMoved"
                            PointerReleased="PreviewDragSurface_PointerReleased"
                            PointerCaptureLost="PreviewDragSurface_PointerCaptureLost"
                            DragDrop.AllowDrop="True"
                            IsVisible="{Binding ShowSinglePreviewOnly}">
                        <Grid RowDefinitions="*,Auto" RowSpacing="10">
                            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" MinHeight="520">
                                    <Image Source="{Binding PreviewBitmap}"
                                           Width="{Binding PreviewImageWidth}"
                                           Height="{Binding PreviewImageHeight}"
                                           Stretch="Fill"/>
                                </Grid>
                            </ScrollViewer>

                            <Border Grid.Row="1" Background="#111820" BorderBrush="#283241" BorderThickness="1" CornerRadius="8" Padding="10">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding PreviewInfoText}" Classes="muted" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="820"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" IsVisible="{Binding ShowSplitPreview}">
                        <Border Grid.Column="0"
                                Classes="panel"
                                Background="{Binding PreviewBackgroundBrush}"
                                Padding="14"
                                PointerPressed="PreviewDragSurface_PointerPressed"
                                PointerMoved="PreviewDragSurface_PointerMoved"
                                PointerReleased="PreviewDragSurface_PointerReleased"
                                PointerCaptureLost="PreviewDragSurface_PointerCaptureLost"
                                DragDrop.AllowDrop="True">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" MinHeight="520">
                                    <Image Source="{Binding PreviewBitmap}"
                                           Width="{Binding PreviewImageWidth}"
                                           Height="{Binding PreviewImageHeight}"
                                           Stretch="Fill"/>
                                </Grid>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="1" Classes="panel" Background="{Binding PreviewBackgroundBrush}" Padding="14">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" MinHeight="520">
                                    <Image Source="{Binding CompareSidePreviewBitmap}"
                                           Width="{Binding ComparePreviewImageWidth}"
                                           Height="{Binding ComparePreviewImageHeight}"
                                           Stretch="Fill"/>
                                </Grid>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- RIGHT INSPECTOR -->
            <Border Grid.Column="2" Classes="panel" Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Inspector" Classes="panelTitle"/>

                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Playback" Classes="sectionTitle"/>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="Speed" VerticalAlignment="Center" Classes="muted"/>
                                    <Slider Grid.Column="1" Minimum="1" Maximum="20" Value="{Binding PlaybackSpeed}" TickFrequency="1"/>
                                    <TextBlock Grid.Column="2" Text="{Binding PlaybackSpeedText}" Width="42" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="card" IsVisible="{Binding ShowAnimationView}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Animation Details" Classes="sectionTitle"/>
                                <Grid ColumnDefinitions="92,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="5">                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedAnimationName}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Body" Classes="muted"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedBodyId}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Action" Classes="muted"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedActionId}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Frames" Classes="muted"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedFrameCount}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Size" Classes="muted"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedFrameSize}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Source" Classes="muted"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedAnimationSource}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Index" Classes="muted"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedIndexNumber}"/>
                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Frame X" Classes="muted"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding CurrentFrameCenterX}"/>

                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Frame Y" Classes="muted"/>
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding CurrentFrameCenterY}"/>

                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Bounds" Classes="muted"/>
                                    <TextBlock Grid.Row="9" Grid.Column="1"
                                               Text="{Binding CurrentFrameBoundsText}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Selected Frame Offset" Classes="sectionTitle"/>
                                <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="X" VerticalAlignment="Center" Classes="muted"/>
                                    <NumericUpDown Grid.Column="1" Minimum="-500" Maximum="500" Increment="1" FormatString="0" ShowButtonSpinner="False" Value="{Binding SelectedAnimationOffsetXText, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="2" Text="Y" VerticalAlignment="Center" Classes="muted"/>
                                    <NumericUpDown Grid.Column="3" Minimum="-500" Maximum="500" Increment="1" FormatString="0" ShowButtonSpinner="False" Value="{Binding SelectedAnimationOffsetYText, Mode=TwoWay}"/>
                                </Grid>
                                <WrapPanel>
                                    <Button Content="Compare Original"
                                            Command="{Binding ToggleOriginalFrameCompareCommand}"
                                            ToolTip.Tip="Shows the original frame as a ghost behind the moved frame so you can compare the offset."
                                            Margin="0,0,6,0"/>

                                    <Button Content="Apply Frame"
                                            Command="{Binding ApplySelectedAnimationOffsetToCurrentFrameCommand}"
                                            ToolTip.Tip="Applies the X/Y offset only to the currently selected frame."
                                            Margin="0,0,6,0"/>

                                    <Button Content="Apply Direction"
                                            Command="{Binding ApplySelectedAnimationOffsetToCurrentDirectionCommand}"
                                            ToolTip.Tip="Applies the X/Y offset to every frame in the currently loaded direction."
                                            Margin="0,0,6,0"/>

                                    <Button Content="Clear"
                                            Command="{Binding ClearSelectedAnimationOffsetCommand}"
                                            ToolTip.Tip="Clears the current X/Y offset preview."/>
                                    <Border Classes="card" Padding="8" Margin="0,4,0,0">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Align Tools" Classes="sectionTitle"/>

                                            <TextBlock Text="{Binding AnimationAlignReferenceText}"
                                                       Classes="muted"
                                                       TextWrapping="Wrap"/>

                                            <WrapPanel>
                                                <Button Content="Set Ref"
                                                        Command="{Binding SetAnimationAlignReferenceCommand}"
                                                        ToolTip.Tip="Uses the current frame as the alignment reference."
                                                        Margin="0,0,6,0"/>

                                                <Button Content="Match Frame"
                                                        Command="{Binding MatchCurrentFrameToAlignReferenceCommand}"
                                                        ToolTip.Tip="Calculates the X/Y offset needed to match the reference frame."
                                                        Margin="0,0,6,0"/>

                                                <Button Content="Align Direction"
                                                        Command="{Binding AlignCurrentDirectionToReferenceCommand}"
                                                        ToolTip.Tip="Applies the same offset to all loaded frames."
                                                        Margin="0,0,6,0"/>

                                                <Button Content="Auto Align Frames"
                                                        Command="{Binding AutoAlignCurrentDirectionFramesCommand}"
                                                        ToolTip.Tip="Calculates and applies alignment separately for each frame."/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Compare / Mount Align" Classes="sectionTitle"/>
                                <StackPanel Spacing="6" IsVisible="{Binding ShowCompareSelectorBar}">
                                    <TextBlock Text="{Binding CompareTargetHeaderText}" Classes="sectionTitle"/>

                                    <ComboBox ItemsSource="{Binding CompareAnimationFileOptions}"
                                              SelectedItem="{Binding CompareSelectedAnimationFile}"/>

                                    <ComboBox ItemsSource="{Binding CompareAnimationEntries}"
                                              SelectedItem="{Binding CompareSelectedAnimation}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <ComboBox Grid.Column="0"
                                                  ItemsSource="{Binding CompareActionOptions}"
                                                  SelectedItem="{Binding CompareSelectedAction}"/>

                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding CompareDirectionOptions}"
                                                  SelectedItem="{Binding CompareSelectedDirection}"/>
                                    </Grid>
                                </StackPanel>
                                <ComboBox ItemsSource="{Binding CompareOverlaySyncModeOptions}" SelectedItem="{Binding CompareOverlaySyncMode}"/>
                                <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="X" VerticalAlignment="Center" Classes="muted"/>
                                    <NumericUpDown Grid.Column="1" Minimum="-500" Maximum="500" Increment="1" FormatString="0" ShowButtonSpinner="False" Value="{Binding CompareOverlayOffsetXText, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="2" Text="Y" VerticalAlignment="Center" Classes="muted"/>
                                    <NumericUpDown Grid.Column="3" Minimum="-500" Maximum="500" Increment="1" FormatString="0" ShowButtonSpinner="False" Value="{Binding CompareOverlayOffsetYText, Mode=TwoWay}"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="Opacity" VerticalAlignment="Center" Classes="muted"/>
                                    <NumericUpDown Grid.Column="1" Minimum="0" Maximum="100" Increment="1" FormatString="0" ShowButtonSpinner="False" Value="{Binding CompareOverlayOpacityPercentText, Mode=TwoWay}"/>
                                </Grid>
                                <WrapPanel>
                                    <Button Content="Mount Rider Align"
                                            Command="{Binding SetupMountRiderAlignmentCommand}"
                                            ToolTip.Tip="Sets up compare mode for aligning a rider animation on top of a mount animation."
                                            Margin="0,0,6,0"/>

                                    <Button Content="Save Pose"
                                            Command="{Binding SaveComparePoseForCurrentFrameCommand}"
                                            ToolTip.Tip="Saves the current compare X/Y pose for this frame."
                                            Margin="0,0,6,0"/>

                                    <Button Content="Copy Prev"
                                            Command="{Binding CopyComparePoseFromPreviousFrameCommand}"
                                            ToolTip.Tip="Copies the compare pose from the previous frame to the current frame."
                                            Margin="0,0,6,0"/>

                                    <Button Content="Clear"
                                            Command="{Binding ClearCompareOverlayCommand}"
                                            ToolTip.Tip="Turns off and clears the compare overlay."/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Prop Overlay" Classes="sectionTitle"/>
                                <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X" VerticalAlignment="Center" Classes="muted"/>
                                    <NumericUpDown Grid.Row="0" Grid.Column="1" Minimum="-500" Maximum="500" Increment="1" FormatString="0" ShowButtonSpinner="False" Value="{Binding PropOverlayOffsetXValue, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Y" VerticalAlignment="Center" Classes="muted"/>
                                    <NumericUpDown Grid.Row="0" Grid.Column="3" Minimum="-500" Maximum="500" Increment="1" FormatString="0" ShowButtonSpinner="False" Value="{Binding PropOverlayOffsetYValue, Mode=TwoWay}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Scale" VerticalAlignment="Center" Classes="muted"/>
                                    <NumericUpDown Grid.Row="1" Grid.Column="1" Minimum="1" Maximum="800" Increment="1" FormatString="0" ShowButtonSpinner="False" Value="{Binding PropOverlayScalePercentValue, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Rot" VerticalAlignment="Center" Classes="muted"/>
                                    <NumericUpDown Grid.Row="1" Grid.Column="3" Minimum="-180" Maximum="180" Increment="1" FormatString="0" ShowButtonSpinner="False" Value="{Binding PropOverlayRotationDegreesValue, Mode=TwoWay}"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Pivot X" VerticalAlignment="Center" Classes="muted"/>
                                    <NumericUpDown Grid.Row="2" Grid.Column="1" Minimum="-500" Maximum="500" Increment="1" FormatString="0" ShowButtonSpinner="False" Value="{Binding PropOverlayPivotXValue, Mode=TwoWay}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Pivot Y" VerticalAlignment="Center" Classes="muted"/>
                                    <NumericUpDown Grid.Row="2" Grid.Column="3" Minimum="-500" Maximum="500" Increment="1" FormatString="0" ShowButtonSpinner="False" Value="{Binding PropOverlayPivotYValue, Mode=TwoWay}"/>
                                </Grid>
                                <WrapPanel>
                                    <CheckBox Content="Flip H" IsChecked="{Binding PropOverlayFlipHorizontal}" Margin="0,0,10,0"/>
                                    <CheckBox Content="Flip V" IsChecked="{Binding PropOverlayFlipVertical}" Margin="0,0,10,0"/>
                                    <ComboBox Width="92" SelectedIndex="{Binding PropOverlayDrawOrderIndex}">
                                        <ComboBoxItem Content="Behind"/>
                                        <ComboBoxItem Content="Front"/>
                                    </ComboBox>
                                </WrapPanel>
                                <WrapPanel>
                                    <Button Content="Load"
                                            Command="{Binding LoadPropOverlayCommand}"
                                            ToolTip.Tip="Loads an image prop to preview over the animation."
                                            Margin="0,0,6,0"/>

                                    <Button Content="Apply Frame"
                                            Command="{Binding ApplyPropOverlayToCurrentFrameCommand}"
                                            ToolTip.Tip="Applies the prop overlay only to the selected frame."
                                            Margin="0,0,6,0"/>

                                    <Button Content="Apply Dir"
                                            Command="{Binding ApplyPropOverlayToCurrentDirectionCommand}"
                                            ToolTip.Tip="Applies the prop overlay to every frame in the current direction."
                                            Margin="0,0,6,0"/>

                                    <Button Content="Clear"
                                            Command="{Binding ClearPropOverlayCommand}"
                                            ToolTip.Tip="Removes the loaded prop overlay from preview."/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Live Effects" Classes="sectionTitle"/>
                                <WrapPanel>
                                    <CheckBox Content="Sharpen" IsChecked="{Binding LivePreviewSharpenEnabled}" Margin="0,0,8,0"/>
                                    <NumericUpDown Width="70" Minimum="0" Maximum="5" Increment="0.1" FormatString="0.0" ShowButtonSpinner="False" Value="{Binding LivePreviewSharpenAmountValue, Mode=TwoWay}" Margin="0,0,8,0"/>
                                    <ComboBox Width="100" SelectedIndex="{Binding LivePreviewSharpenModeIndex}">
                                        <ComboBoxItem Content="Gaussian"/>
                                        <ComboBoxItem Content="Pixel"/>
                                    </ComboBox>
                                </WrapPanel>
                                <WrapPanel>
                                    <CheckBox Content="Contrast" IsChecked="{Binding LivePreviewContrastEnabled}" Margin="0,0,8,0"/>
                                    <NumericUpDown Width="70" Minimum="0" Maximum="2" Increment="0.05" FormatString="0.00" ShowButtonSpinner="False" Value="{Binding LivePreviewContrastAmountValue, Mode=TwoWay}" Margin="0,0,14,0"/>
                                    <CheckBox Content="Outline" IsChecked="{Binding LivePreviewOutlineEnabled}" Margin="0,0,8,0"/>
                                    <NumericUpDown Width="70" Minimum="0" Maximum="1" Increment="0.05" FormatString="0.00" ShowButtonSpinner="False" Value="{Binding LivePreviewOutlineStrengthValue, Mode=TwoWay}"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Button Content="Hue..."
                                            Command="{Binding ConfigureLivePreviewHueCommand}"
                                            ToolTip.Tip="Opens hue settings for previewing the animation with a UO hue."
                                            Margin="0,0,6,0"/>

                                    <Button Content="Scale..."
                                            Command="{Binding ConfigureLivePreviewScaleCommand}"
                                            ToolTip.Tip="Opens scale settings for previewing or resizing the animation."
                                            Margin="0,0,6,0"/>

                                    <Button Content="Apply Direction"
                                            Command="{Binding ApplyLivePreviewToCurrentDirectionCommand}"
                                            ToolTip.Tip="Applies the current live effects to every frame in this direction."
                                            Margin="0,0,6,0"/>

                                    <Button Content="Reset"
                                            Command="{Binding ResetLivePreviewCommand}"
                                            ToolTip.Tip="Turns off all live preview effects and restores normal preview."/>
                                </WrapPanel>
                                <TextBlock Text="{Binding LivePreviewHueText}" Classes="muted" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding LivePreviewScaleText}" Classes="muted" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- BOTTOM TIMELINE -->
        <Border Grid.Row="2"
                Background="#11161D"
                BorderBrush="#2D3642"
                BorderThickness="0,1,0,0"
                Padding="10,8">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Timeline" Classes="panelTitle"/>
                    <TextBlock Text="{Binding CurrentFrameDisplayText}" Classes="muted" VerticalAlignment="Center"/>
                    <TextBlock Text="Right click frame: replace / remove" Classes="muted" VerticalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" MaxHeight="100">
                    <ListBox x:Name="ThumbnailList"
                             Classes="thumbnailList"
                             ItemsSource="{Binding FrameThumbnails}"
                             SelectedItem="{Binding SelectedFrameThumbnail, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             IsVisible="{Binding HasFrameThumbnails}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="thumbCard" Tag="{Binding $parent[ListBox].DataContext}">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Replace" Click="ReplaceThumbnailMenuItem_Click" Tag="{Binding}"/>
                                            <MenuItem Header="Remove" Click="RemoveThumbnailMenuItem_Click" Tag="{Binding}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                        <Border Classes="thumbImageHost">
                                            <Image Source="{Binding Bitmap}"
                                                   Width="44"
                                                   Height="44"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Classes="thumbLabel"
                                                   Text="{Binding DisplayText}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
