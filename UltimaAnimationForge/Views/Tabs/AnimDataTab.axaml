<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:UltimaAnimationForge.ViewModels"
             x:Class="UltimaAnimationForge.Views.Tabs.AnimDataTab"
             x:DataType="vm:MainWindowViewModel">

    <Grid RowDefinitions="Auto,*">

        <Border Grid.Row="0"
                Background="#1E232A"
                BorderBrush="#343B46"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
                <Button Content="Load AnimData"
                        Command="{Binding LoadAnimDataTabCommand}" />

                <Button Content="Save AnimData"
                        Command="{Binding SaveAnimDataCommand}" />

                <Button Content="Export"
                        Command="{Binding ExportAnimDataCommand}" />

                <Button Content="Import"
                        Command="{Binding ImportAnimDataCommand}" />

                <Button Content="Check All"
                        Command="{Binding CheckAllAnimDataCommand}" />

                <Button Content="Uncheck All"
                        Command="{Binding UncheckAllAnimDataCommand}" />

                <TextBlock Text="{Binding AnimDataStatusText}"
                           VerticalAlignment="Center"
                           Foreground="#C7D1DB" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="380,*,330"
              ColumnSpacing="10"
              Margin="10">

            <!-- Left: Filters + AnimData List -->
            <Grid Grid.Column="0"
                  RowDefinitions="Auto,*"
                  RowSpacing="8">

                <Border Grid.Row="0"
                        Background="#20262E"
                        BorderBrush="#343B46"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8">
                    <StackPanel Spacing="6">
                        <TextBox Watermark="Search ID / hex / name..."
                                 Text="{Binding AnimDataSearchText}" />

                        <StackPanel Orientation="Horizontal"
                                    Spacing="12">
                            <CheckBox Content="Missing Art"
                                      IsChecked="{Binding ShowAnimDataMissingArt}" />

                            <CheckBox Content="No Anim Flag"
                                      IsChecked="{Binding ShowAnimDataWithoutAnimationFlag}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="#20262E"
                        BorderBrush="#343B46"
                        BorderThickness="1"
                        CornerRadius="6">
                    <ListBox ItemsSource="{Binding AnimDataEntries}"
                             SelectedItem="{Binding SelectedAnimDataEntry}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8"
                                      Margin="6">
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsChecked}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,6,0" />

                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayText}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#E4EAF2" />

                                        <TextBlock Text="{Binding SecondaryText}"
                                                   FontSize="12"
                                                   Foreground="#AAB4C0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>

            <!-- Middle: Base + selected frame preview -->
            <Grid Grid.Column="1"
                  RowDefinitions="*,Auto,*"
                  RowSpacing="10">

                <Border Grid.Row="0"
                        Background="#20262E"
                        BorderBrush="#343B46"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0"
                                   Text="Base Graphic"
                                   FontWeight="Bold"
                                   Foreground="#E4EAF2"
                                   Margin="0,0,0,8" />

                        <ScrollViewer Grid.Row="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <Image Source="{Binding SelectedAnimDataBaseBitmap}"
                                   Stretch="None"
                                   RenderOptions.BitmapInterpolationMode="None"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Height="1"
                        Background="#343B46" />

                <Border Grid.Row="2"
                        Background="#20262E"
                        BorderBrush="#343B46"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0"
                                   Text="Selected Frame Graphic"
                                   FontWeight="Bold"
                                   Foreground="#E4EAF2"
                                   Margin="0,0,0,8" />

                        <ScrollViewer Grid.Row="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <Image Source="{Binding SelectedAnimDataFrameBitmap}"
                                   Stretch="None"
                                   RenderOptions.BitmapInterpolationMode="None"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right: frame list + info -->
            <Border Grid.Column="2"
                    Background="#20262E"
                    BorderBrush="#343B46"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <Grid RowDefinitions="Auto,170,Auto,Auto,*"
                      RowSpacing="8">

                    <StackPanel Grid.Row="0"
                                Spacing="4">
                        <TextBlock Text="AnimData Info"
                                   FontWeight="Bold"
                                   Foreground="#E4EAF2" />

                        <TextBlock Text="{Binding SelectedAnimDataEntry.DisplayText}"
                                   Foreground="#C7D1DB"
                                   TextWrapping="Wrap" />

                        <TextBlock Text="{Binding SelectedAnimDataEntry.SecondaryText}"
                                   Foreground="#AAB4C0"
                                   FontSize="12"
                                   TextWrapping="Wrap" />

                        <Grid ColumnDefinitions="*,*"
                              RowDefinitions="Auto,Auto,Auto,Auto"
                              ColumnSpacing="8"
                              RowSpacing="6"
                              Margin="0,8,0,0">
                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="Unknown"
                                       Foreground="#AAB4C0" />

                            <NumericUpDown Grid.Row="0"
                                           Grid.Column="1"
                                           Minimum="0"
                                           Maximum="255"
                                           Value="{Binding SelectedAnimDataEntry.Unknown}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="Frame Count"
                                       Foreground="#AAB4C0" />

                            <NumericUpDown Grid.Row="1"
                                           Grid.Column="1"
                                           Minimum="0"
                                           Maximum="64"
                                           Value="{Binding SelectedAnimDataEntry.FrameCount}" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Text="Frame Interval"
                                       Foreground="#AAB4C0" />

                            <NumericUpDown Grid.Row="2"
                                           Grid.Column="1"
                                           Minimum="0"
                                           Maximum="255"
                                           Value="{Binding SelectedAnimDataEntry.FrameInterval}" />

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Text="Frame Start"
                                       Foreground="#AAB4C0" />

                            <NumericUpDown Grid.Row="3"
                                           Grid.Column="1"
                                           Minimum="0"
                                           Maximum="255"
                                           Value="{Binding SelectedAnimDataEntry.FrameStart}" />
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="#151A20"
                            BorderBrush="#343B46"
                            BorderThickness="1"
                            CornerRadius="4">
                        <ListBox ItemsSource="{Binding SelectedAnimDataEntry.Frames}"
                                 SelectedItem="{Binding SelectedAnimDataFrame}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="6,4">
                                        <TextBlock Text="{Binding DisplayText}"
                                                   Foreground="#E4EAF2" />
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="11"
                                                   Foreground="#AAB4C0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Grid Grid.Row="2"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="5"
                          Margin="0,2,0,4">

                        <Grid Grid.Row="0"
                              ColumnDefinitions="90,Auto,58,78"
                              ColumnSpacing="6">
                            <TextBox Grid.Column="0"
                                     Watermark="0x091E"
                                     Text="{Binding AnimDataAddFrameGraphicText}" />

                            <CheckBox Grid.Column="1"
                                      Content="Rel"
                                      IsChecked="{Binding AnimDataAddFrameRelative}"
                                      VerticalAlignment="Center" />

                            <Button Grid.Column="2"
                                    Content="Add"
                                    Command="{Binding AddAnimDataFrameCommand}" />

                            <Button Grid.Column="3"
                                    Content="Remove"
                                    Command="{Binding RemoveAnimDataFrameCommand}" />
                        </Grid>

                        <Grid Grid.Row="1"
                              ColumnDefinitions="*,*,*"
                              ColumnSpacing="6">
                            <Button Grid.Column="0"
                                    Content="Move Up"
                                    Command="{Binding MoveAnimDataFrameUpCommand}" />

                            <Button Grid.Column="1"
                                    Content="Move Down"
                                    Command="{Binding MoveAnimDataFrameDownCommand}" />

                            <Button Grid.Column="2"
                                    Content="Play"
                                    Command="{Binding ToggleAnimDataAnimationCommand}" />
                        </Grid>
                    </Grid>

                    <Border Grid.Row="3"
                            Height="1"
                            Background="#343B46"
                            Margin="0,4" />

                    <ScrollViewer Grid.Row="4"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="12">

                            <StackPanel Spacing="4">
                                <TextBlock Text="Base TileData"
                                           FontWeight="Bold"
                                           Foreground="#E4EAF2" />

                                <TextBlock Text="{Binding SelectedAnimDataTileDataEntry.DisplayText}"
                                           Foreground="#C7D1DB"
                                           TextWrapping="Wrap" />

                                <TextBlock Text="{Binding SelectedAnimDataTileDataEntry.Flags, StringFormat='Flags: 0x{0:X16}'}"
                                           Foreground="#AAB4C0"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Frame TileData"
                                           FontWeight="Bold"
                                           Foreground="#E4EAF2" />

                                <TextBlock Text="{Binding SelectedAnimDataFrameTileDataEntry.DisplayText}"
                                           Foreground="#C7D1DB"
                                           TextWrapping="Wrap" />

                                <TextBlock Text="{Binding SelectedAnimDataFrameTileDataEntry.Flags, StringFormat='Flags: 0x{0:X16}'}"
                                           Foreground="#AAB4C0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
