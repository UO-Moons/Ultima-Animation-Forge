<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="UltimaAnimationForge.Views.EquipmentBinderWindow"
        Title="Equipment Binder Tool"
        Width="760"
        Height="820"
        MinWidth="640"
        MinHeight="700"
        Background="#11161C">
  <ScrollViewer>
    <Border Padding="14">
      <StackPanel Spacing="10">
        <TextBlock Text="Equipment Binder"
                   FontSize="20"
                   FontWeight="Bold" />

        <TextBlock Text="{Binding EquipmentBinderTargetSlotText}"
                   TextWrapping="Wrap"
                   Opacity="0.85" />

        <Grid ColumnDefinitions="Auto,*"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
              ColumnSpacing="8"
              RowSpacing="6">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Item Art ID:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="65535" Value="{Binding EquipmentBinderItemArtId}" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Name:" VerticalAlignment="Center" />
          <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EquipmentBinderName}" Watermark="flail" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Display/Gump:" VerticalAlignment="Center" />
          <DockPanel Grid.Row="2" Grid.Column="1">
            <Button DockPanel.Dock="Right" Content="Auto" Margin="6,0,0,0" Command="{Binding AutoFillEquipmentBinderDisplayBodyCommand}" />
            <NumericUpDown Minimum="0" Maximum="65534" Value="{Binding EquipmentBinderDisplayBodyId}" />
          </DockPanel>

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Anim Body:" VerticalAlignment="Center" />
          <NumericUpDown Grid.Row="3" Grid.Column="1" Minimum="1" Maximum="65535" Value="{Binding EquipmentBinderAnimationBodyId}" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="MobType:" VerticalAlignment="Center" />
          <TextBlock Grid.Row="4" Grid.Column="1" Text="EQUIPMENT" FontWeight="Bold" VerticalAlignment="Center" />

          <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
            <CheckBox Content="Overwrite body.def redirect" IsChecked="{Binding EquipmentBinderOverwriteBodyDef}" />
            <CheckBox Content="Overwrite mobtypes entry" IsChecked="{Binding EquipmentBinderOverwriteMobType}" />
            <CheckBox Content="Update tiledata.mul animation" IsChecked="{Binding EquipmentBinderUpdateTileDataAnimation}" />
          </StackPanel>
        </Grid>

        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
          <Button Grid.Row="0" Grid.Column="0" Content="Load Art" Command="{Binding LoadEquipmentArtPickerCommand}"/>
          <Button Grid.Row="0" Grid.Column="1" Content="Load Gumps" Command="{Binding LoadEquipmentGumpPickerCommand}"/>
          <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Content="Build Preview" Command="{Binding BuildEquipmentBinderPreviewCommand}"/>
          <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="Apply Binder" Command="{Binding ApplyEquipmentBinderCommand}"/>
        </Grid>


        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="Art Picker" FontWeight="Bold" />
            <TextBox Text="{Binding EquipmentArtPickerSearchText}" Watermark="Search art ID or hex..." />
            <ListBox ItemsSource="{Binding EquipmentArtPickerEntries}" SelectedItem="{Binding SelectedEquipmentArtPickerEntry}" MaxHeight="220">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Width="48" Height="48" BorderBrush="#39414D" BorderThickness="1">
                      <Image Source="{Binding Thumbnail}" Stretch="Uniform" />
                    </Border>
                    <TextBlock Text="{Binding DisplayText}" VerticalAlignment="Center" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>

          <StackPanel Grid.Column="1" Spacing="4">
            <TextBlock Text="Gump Picker" FontWeight="Bold" />
            <TextBox Text="{Binding EquipmentGumpPickerSearchText}" Watermark="Search gump ID or hex..." />
            <ListBox ItemsSource="{Binding EquipmentGumpPickerEntries}" SelectedItem="{Binding SelectedEquipmentGumpPickerEntry}" MaxHeight="220">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Width="48" Height="48" BorderBrush="#39414D" BorderThickness="1">
                      <Image Source="{Binding Thumbnail}" Stretch="Uniform" />
                    </Border>
                    <TextBlock Text="{Binding DisplayText}" VerticalAlignment="Center" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Grid>

        <TextBlock Text="{Binding EquipmentBinderExistsText}" TextWrapping="Wrap" Opacity="0.8"/>

        <TextBlock Text="tiledata.mul:" FontWeight="Bold"/>
        <TextBox Text="{Binding EquipmentBinderTileDataLine}" IsReadOnly="True"/>

        <TextBlock Text="body.def:" FontWeight="Bold"/>
        <TextBox Text="{Binding EquipmentBinderBodyDefLine}" IsReadOnly="True"/>

        <TextBlock Text="bodyconv.def:" FontWeight="Bold" />
        <TextBox Text="{Binding EquipmentBinderBodyConvLine}" IsReadOnly="True" />

        <TextBlock Text="mobtypes.txt:" FontWeight="Bold" />
        <TextBox Text="{Binding EquipmentBinderMobTypeLine}" IsReadOnly="True" />

        <TextBlock Text="{Binding EquipmentBinderSummary}" TextWrapping="Wrap" Opacity="0.85" />
        <TextBlock Text="{Binding EquipmentPickerStatusText}" TextWrapping="Wrap" Opacity="0.75" />
      </StackPanel>
    </Border>
  </ScrollViewer>
</Window>
